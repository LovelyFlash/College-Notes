,"updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"空间中存储的数据是可以发生改变"}]}]}]},{"ID":"20260305082131-dvp798u","Type":"NodeParagraph","Properties":{"id":"20260305082131-dvp798u","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"知道了，什么是变量后，下面我们来说一下变量的定义格式："}]},{"ID":"20260305082131-tqqj0vr","Type":"NodeList","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20260305082131-tqqj0vr","updated":"20260305082131"},"Children":[{"ID":"20260305082131-otl9yja","Type":"NodeListItem","Data":"-","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20260305082131-otl9yja","updated":"20260305082131"},"Children":[{"ID":"20260305082131-oapa8ic","Type":"NodeParagraph","Properties":{"id":"20260305082131-oapa8ic","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"格式：数据类型 变量名 = 变量值;"}]}]},{"ID":"20260305082131-eedom8n","Type":"NodeListItem","Data":"-","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20260305082131-eedom8n","updated":"20260305082131"},"Children":[{"ID":"20260305082131-i7274cy","Type":"NodeParagraph","Properties":{"id":"20260305082131-i7274cy","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"范例：int price = 998;"},{"Type":"NodeSoftBreak","Data":"\n"},{"Type":"NodeText","Data":"根据变量名进行使用，可以输出，也可以修改值"}]}]}]},{"ID":"20260305082131-c3ij6qm","Type":"NodeParagraph","Properties":{"id":"20260305082131-c3ij6qm","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"了解了变量的定义格式和使用方式后，下面我们到IDEA中去演示一下："}]},{"ID":"20260305082131-oajdwos","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"amF2YQ==","CodeBlockCloseFence":"YGBg","Properties":{"id":"20260305082131-oajdwos","updated":"20260305082131"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"amF2YQ=="},{"Type":"NodeCodeBlockCode","Data":"/*\n    格式：数据类型 变量名 = 变量值;\n */\npublic class VariableDemo01 {\n    public static void main(String[] args) {\n        //定义一个int类型的变量，用来表示价格\n        int price = 998;\n\n        //输出变量\n        System.out.println(price);\n\n        //修改变量的值\n        price = 888;\n\n        //再次输出变量的值\n        System.out.println(price);\n    }\n}\n123456789101112131415161718\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3}]},{"ID":"20260305082131-855usog","Type":"NodeParagraph","Properties":{"id":"20260305082131-855usog","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"学完了变量的定义，输出使用和修改值使用后，大家赶快动手练习一下吧。"}]},{"ID":"20260305082131-bqtnjy9","Type":"NodeHeading","HeadingLevel":4,"Properties":{"id":"20260305082131-bqtnjy9","updated":"20260305082131"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"#### "},{"Type":"NodeText","Data":"3.4 变量的案例"}]},{"ID":"20260305082131-py65xm9","Type":"NodeParagraph","Properties":{"id":"20260305082131-py65xm9","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"了解了变量的定义和基本使用后，下面我们来做两个案例，熟悉一下变量的使用："}]},{"ID":"20260305082131-itd5jxx","Type":"NodeHeading","HeadingLevel":5,"Properties":{"id":"20260305082131-itd5jxx","updated":"20260305082131"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"##### "},{"Type":"NodeText","Data":"3.4.1 手机信息描述"}]},{"ID":"20260305082131-i88f6gs","Type":"NodeParagraph","Properties":{"id":"20260305082131-i88f6gs","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"需求：分析下图指定数据，看看哪些可以通过变量表示，并思考采用那种数据类型，最后通过程序实现"}]},{"ID":"20260305082131-i588p5r","Type":"NodeParagraph","Properties":{"id":"20260305082131-i588p5r","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"指定数据：京东价，重量，颜色"}]},{"ID":"20260305082131-rcc76kj","Type":"NodeParagraph","Properties":{"id":"20260305082131-rcc76kj","updated":"20260305082131"},"Children":[{"Type":"NodeImage","Childr