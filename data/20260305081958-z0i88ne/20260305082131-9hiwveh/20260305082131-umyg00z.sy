(arr[3]);\n//        System.out.println(arr[4]);\n\n        //用循环改进\n//        for (int i=0; i\u003c5; i++) {\n//            System.out.println(arr[i]);\n//        }\n\n        //格式：数组名.length\n//        System.out.println(arr.length);\n\n        for (int i=0; i\u003carr.length; i++) {\n            System.out.println(arr[i]);\n        }\n    }\n}\n12345678910111213141516171819202122232425262728\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3}]},{"ID":"20260305082131-vv4xdqs","Type":"NodeParagraph","Properties":{"id":"20260305082131-vv4xdqs","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"最后，我们回到资料总结一下："}]},{"ID":"20260305082131-46gssv7","Type":"NodeParagraph","Properties":{"id":"20260305082131-46gssv7","updated":"20260305082131"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"什么是数组遍历："}]},{"ID":"20260305082131-qwdk2yp","Type":"NodeList","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20260305082131-qwdk2yp","updated":"20260305082131"},"Children":[{"ID":"20260305082131-kjdls68","Type":"NodeListItem","Data":"-","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20260305082131-kjdls68","updated":"20260305082131"},"Children":[{"ID":"20260305082131-ipjc4y6","Type":"NodeParagraph","Properties":{"id":"20260305082131-ipjc4y6","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"获取数组中的每一个元素，我们可以把获取到的元素输出在控制台"}]}]}]},{"ID":"20260305082131-msjuqz8","Type":"NodeParagraph","Properties":{"id":"20260305082131-msjuqz8","updated":"20260305082131"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"获取数组长度(元素个数)："}]},{"ID":"20260305082131-3lwmk9q","Type":"NodeList","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20260305082131-3lwmk9q","updated":"20260305082131"},"Children":[{"ID":"20260305082131-goxvjad","Typ