anner"}]},{"ID":"20260305082131-pp96og6","Type":"NodeHeading","HeadingLevel":4,"Properties":{"id":"20260305082131-pp96og6","updated":"20260305082131"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"#### "},{"Type":"NodeText","Data":"16.1 Scanner基本使用"}]},{"ID":"20260305082131-wbpjudl","Type":"NodeParagraph","Properties":{"id":"20260305082131-wbpjudl","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"了解了API相关的知识后，下面我们来学习一下Scanner的使用。"}]},{"ID":"20260305082131-wz4n4yw","Type":"NodeParagraph","Properties":{"id":"20260305082131-wz4n4yw","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"通过查看帮助文档，我们知道了如下的信息："}]},{"ID":"20260305082131-9y5azox","Type":"NodeParagraph","Properties":{"id":"20260305082131-9y5azox","updated":"20260305082131"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"Scanner："}]},{"ID":"20260305082131-5yjrwqu","Type":"NodeList","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20260305082131-5yjrwqu","updated":"20260305082131"},"Children":[{"ID":"20260305082131-99bz9nz","Type":"NodeListItem","Data":"-","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20260305082131-99bz9nz","updated":"20260305082131"},"Children":[{"ID":"20260305082131-72r0ul7","Type":"NodeParagraph","Properties":{"id":"20260305082131-72r0ul7","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"一个简单的文本扫描程序，可以获取基本类型数据和字符串数据"}]}]}]},{"ID":"20260305082131-q7utfx7","Type":"NodeParagraph","Properties":{"id":"20260305082131-q7utfx7","updated":"20260305082131"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"构造方法："}]},{"ID":"20260305082131-jof7jko","Type":"NodeList","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20260305082131-jof7jko","updated":"20260305082131"},"Children":[{"ID":"20260305082131-cif8alt","Type":"NodeListItem","Dat