":"NodeBackslash","Children":[{"Type":"NodeBackslashContent","Data":"*"}]},{"Type":"NodeBackslash","Children":[{"Type":"NodeBackslashContent","Data":"*"}]},{"Type":"NodeText","Data":"用 "},{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"运算符"},{"Type":"NodeText","Data":" 把字面量或者变量连接起来 "},{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"符合java语法的式子"},{"Type":"NodeText","Data":" 就可以称为表达式。不同运算符连接的表达式体现的是不同类型的表达式。"}]},{"ID":"20260305082131-npigti4","Type":"NodeParagraph","Properties":{"id":"20260305082131-npigti4","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"举例说明："},{"Type":"NodeBackslash","Children":[{"Type":"NodeBackslashContent","Data":"*"}]},{"Type":"NodeBackslash","Children":[{"Type":"NodeBackslashContent","Data":"*"}]}]},{"ID":"20260305082131-q9t9m1r","Type":"NodeParagraph","Properties":{"id":"20260305082131-q9t9m1r","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"int a = 10;"}]},{"ID":"20260305082131-jbgloeq","Type":"NodeParagraph","Properties":{"id":"20260305082131-jbgloeq","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"int b = 20;"}]},{"ID":"20260305082131-fw5lhx7","Type":"NodeParagraph","Properties":{"id":"20260305082131-fw5lhx7","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"int c = a + b;"}]},{"ID":"20260305082131-5igfecu","Type":"NodeParagraph","Properties":{"id":"20260305082131-5igfecu","updated":"20260305082131"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"+"},{"Type":"NodeText","Data":" ：是 "},{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"运算符"},{"Type":"NodeText","Data":" ，是算术运算符"}]},{"ID":"20260305082131-gwphe8s","Type":"NodeParagraph","Properties":{"id":"20260305082131-gwphe8s","updated":"20260305082131"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"a + b"},{"Type":"NodeText","Data":" ：是 "},{"Type":"NodeTextMark","TextMarkType":"strong",