"Data":"("},{"Type":"NodeLinkDest","Data":"https://i-blog.csdnimg.cn/direct/3d66d148cde34b06a35eba4893212de3.png"},{"Type":"NodeCloseParen","Data":")"}]}]},{"ID":"20260305082131-3ragtak","Type":"NodeParagraph","Properties":{"id":"20260305082131-3ragtak","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"刚才的场景中，重点介绍了两个跳转关键字："}]},{"ID":"20260305082131-schcyhu","Type":"NodeList","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20260305082131-schcyhu","updated":"20260305082131"},"Children":[{"ID":"20260305082131-mpliwna","Type":"NodeListItem","Data":"-","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20260305082131-mpliwna","updated":"20260305082131"},"Children":[{"ID":"20260305082131-7v6irb8","Type":"NodeParagraph","Properties":{"id":"20260305082131-7v6irb8","updated":"20260305082131"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"continue"},{"Type":"NodeText","Data":" 用在循环中，基于条件控制，跳过某次循环体内容的执行，继续下一次的执行"}]}]},{"ID":"20260305082131-vcug4zs","Type":"NodeListItem","Data":"-","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20260305082131-vcug4zs","updated":"20260305082131"},"Children":[{"ID":"20260305082131-526fj8y","Type":"NodeParagraph","Properties":{"id":"20260305082131-526fj8y","updated":"20260305082131"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"break"},{"Type":"NodeText","Data":" 用在循环中，基于条件控制，终止循环体内容的执行，也就是说结束当前的整个循环"}]}]}]},{"ID":"20260305082131-1trr3u3","Type":"NodeParagraph","Properties":{"id":"20260305082131-1trr3u3","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"了解了这两个跳转关键字之后，下面我们到IDEA中去体验一下："}]},{"ID":"20260305082131-hi1nns4","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"amF2YQ==","CodeBlockCloseFence":"YGBg","Properties":{"id":"20260305082131-hi1nns4","updated":"20260305082131"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"amF2YQ=="},{"Type":"NodeCodeBlockCode","Data":"/*\n   continue:用在循环中，基于条件控制，跳过某次循环体内容的执行，继续下一次的执行\n   break:用在循环中，基于条件控制，终止循环体内容的执行，也就是说结束当前的整个循环\n*/\npublic class ControlDemo {\n    public static void main(String[] args) {\n        for (int i = 1; i \u003c= 5; i++) {\n            if (i % 2 == 0) {\n//                continue;\n                break;\n            }\n\n            System.out.println(i);\n        }\n    }\n}\n12345678910111213141516\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3}]},{"ID":"20260305082131-uzurod9","Type":"NodeHeading","HeadingLevel":4,"Properties":{"id":"20260305082131-uzurod9","updated":"20260305082131"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"#### "},{"Type":"NodeText","Data":"9.2 综合案例(小芳存钱)"}]},{"ID":"20260305082131-qnbsw67","Type":"NodeParagraph","Properties":{"id":"20260305082131-qnbsw67","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"需求：小芳的妈妈每天给她2.5元钱，她都会存起来，但是，每当这一天是存钱的第5天或者5的倍数的话，"}]},{"ID":"20260305082131-mis72rr","Type":"NodeParagraph","Properties":{"id":"20260305082131-mis72rr","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"她都会花去6元钱，请问，经过多少天，小芳才可以存到100元钱。"}]},{"ID":"20260305082131-15yde5f","Type":"NodeParagraph","Properties":{"id":"20260305082131-15yde5f","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"关于这个案例呢，我们到IDEA中一边分析，一边实现："}]},{"ID":"20260305082131-8e8oufj","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"amF2YQ==","CodeBlockCloseFence":"YGBg","Properties":{"id":"20260305082131-8e8oufj","updated":"20260305082131"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"amF2YQ=="},{"Type":"NodeCodeBlockCode","Data":"/*\n    需求：小芳的妈妈每天给她2.5元钱，她都会存起来，但是，每当这一天是存钱的第5天或者5的倍数的话，她都会花去6元钱，请问，经过多少天，小芳才可以存到100元钱。\n*/\npublic class ControlTest {\n    public static void main(String[] args) {\n        //小芳的妈妈每天给她2.5元钱\n        double dayMoney = 2.5;\n\n        //她都会存起来，涉及到了求和思想，定义求和变量，初始化值为0\n        double sumMoney = 0;\n\n        //存到100元钱\n        int result = 100;\n\n        //定义一个统计变量，用来纪录存钱的天数，初始化值为1\n        int dayCount = 1;\n\n        //因为不知道要多少天才能够存到100元，所以，这里我们采用死循环来实现，当存到100元的时候，通过break跳转语句让循环结束\n        while (true) {\n            //存钱\n            sumMoney += dayMoney;\n\n            //判断存的钱是否大于等于100了，如果是，就退出循环\n            if(sumMoney \u003e= result) {\n                break;\n            }\n\n            //每当这一天是存钱的第5天或者5的倍数的话，她都会花去6元钱\n            if(dayCount%5 == 0) {\n                sumMoney -= 6;\n                System.out.println(\"第\" + dayCount + \"天花了6元\");\n            }\n\n            dayCount++;\n        }\n\n        //输出统计天数的变量\n        System.out.println(\"共花了\" + dayCount + \"天存了100元\");\n    }\n}\n12345678910111213141516171819202122232425262728293031323334353637383940\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3}]},{"ID":"20260305082131-6gg7xi1","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20260305082131-6gg7xi1","updated":"20260305082131"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"## "},{"Type":"NodeText","Data":"五、方法"}]},{"ID":"20260305082131-b8gnglq","Type":"NodeParagraph","Properties":{"id":"20260305082131-b8gnglq","updated":"20260305082131"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"本节目标："}]},{"ID":"20260305082131-w8k3zra","Type":"NodeList","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20260305082131-w8k3zra","updated":"20260305082131"},"Children":[{"ID":"20260305082131-fb474hs","Type":"NodeListItem","Data":"-","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20260305082131-fb474hs","updated":"20260305082131"},"Children":[{"ID":"20260305082131-ja1goa2","Type":"NodeParagraph","Properties":{"id":"20260305082131-ja1goa2","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"能够知道方法的好处"}]}]},{"ID":"20260305082131-z0ub9r5","Type":"NodeListItem","Data":"-","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20260305082131-z0ub9r5","updated":"20260305082131"},"Children":[{"ID":"20260305082131-9mawsl6","Type":"NodeParagraph","Properties":{"id":"20260305082131-9mawsl6","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"能够根据两个明确分析方法的参数和返回值"}]}]},{"ID":"20260305082131-ympeuin","Type":"NodeListItem","Data":"-","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20260305082131-ympeuin","updated":"20260305082131"},"Children":[{"ID":"20260305082131-l70ximm","Type":"NodeParagraph","Properties":{"id":"20260305082131-l70ximm","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"能够编写方法完成授课案例，并在主方法中完成方法的调用"}]}]},{"ID":"20260305082131-38uc239","Type":"NodeListItem","Data":"-","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20260305082131-38uc239","updated":"20260305082131"},"Children":[{"ID":"20260305082131-fitj40a","Type":"NodeParagraph","Properties":{"id":"20260305082131-fitj40a","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"能够知道方法重载及其特点"}]}]}]},{"ID":"20260305082131-a2nokiy","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20260305082131-a2nokiy","updated":"20260305082131"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"### "},{"Type":"NodeText","Data":"10：方法的定义和使用"}]},{"ID":"20260305082131-tbenduc","Type":"NodeHeading","HeadingLevel":4,"Properties":{"id":"20260305082131-tbenduc","updated":"20260305082131"},"Children":[{"Type":"NodeHeadingC