[] args) {\n        System.out.println(\"开始\");\n        System.out.println(\"语句A\");\n        System.out.println(\"语句B\");\n        System.out.println(\"语句C\");\n        System.out.println(\"结束\");\n    }\n}\n123456789101112\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3}]},{"ID":"20260305082131-h3jjyss","Type":"NodeParagraph","Properties":{"id":"20260305082131-h3jjyss","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"这个比较简单，也没什么好练习的。就不练了，我们继续往下学习。"}]},{"ID":"20260305082131-093gu4k","Type":"NodeHeading","HeadingLevel":4,"Properties":{"id":"20260305082131-093gu4k","updated":"20260305082131"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"#### "},{"Type":"NodeText","Data":"5.2 Debug的基本使用"}]},{"ID":"20260305082131-atrf7cj","Type":"NodeParagraph","Properties":{"id":"20260305082131-atrf7cj","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"为了帮助大家更好的理解程序的执行流程，我们来学习Debug，那什么是Debug呢？"}]},{"ID":"20260305082131-00dpt4a","Type":"NodeParagraph","Properties":{"id":"20260305082131-00dpt4a","updated":"20260305082131"},"Children":[{"Type":"NodeBackslash","Children":[{"Type":"NodeBackslashContent","Data":"*"}]},{"Type":"NodeBackslash","Children":[{"Type":"NodeBackslashContent","Data":"*"}]},{"Type":"NodeText","Data":"Debug："},{"Type":"NodeBackslash","Children":[{"Type":"NodeBackslashContent","Data":"*"}]},{"Type":"NodeBackslash","Children":[{"Type":"NodeBackslashContent","Data":"*"}]},{"Type":"NodeText","Data":"是供程序员使用的程序调试工具，它可以用于查看程序的执行流程，也可以用于追踪程序执行过程来调试程序"}]},{"ID":"20260305082131-gclox45","Type":"NodeParagraph","Properties":{"id":"20260305082131-gclox45","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"它的两大作用，查看程序执行流程，调试程序。由于目前我们每个程序的代码内容还比较少，"}]},{"ID":"20260305082131-1l7x87q","Type":"NodeParagraph","Properties":{"id":"20260305082131-1l7x87q","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"所以，今天重点掌握查看程序执行流程，当代码复杂的时候，我们需要通过debug来调试程序。那么，debug操作的流程是什么样子的呢？"}]},{"ID":"20260305082131-hmvysg3","Type":"NodeParagraph","Properties":{"id":"20260305082131-hmvysg3","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"在讲解操作流程前，我们来说一下："}]},{"ID":"20260305082131-jj69088","Type":"NodeParagraph","Properties":{"id":"20260305082131-jj69088","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"Debug，又被称为 "},{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"断点调试"},{"Type":"NodeText","Data":" ，断点其实是一个标记，告诉我们从哪里开始查看"}]},{"ID":"20260305082131-aete89y","Type":"NodeParagraph","Properties":{"id":"20260305082131-aete89y","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"知道了Debug被称为断点调试后，我们来讲一下Debug的操作流程："}]},{"ID":"20260305082131-dkaxapf","Type":"NodeParagraph","Properties":{"id":"20260305082131-dkaxapf","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"① 如何加断点"}]},{"ID":"20260305082131-vxsr4e9","Type":"NodeParagraph","Properties":{"id":"20260305082131-vxsr4e9","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"选择要设置断点的代码行，在行号的区域后面单击鼠标左键即可。如图"}]},{"ID":"20260305082131-flmg8po","Type":"NodeParagraph","Properties":{"id":"20260305082131-flmg8po","updated":"20260305082131"},"Children":[{"Type":"NodeImage","Children":[{"Type":"NodeBang","Data":"!"},{"Type":"NodeOpenBracket","Data":"["},{"Type":"NodeLinkText","Data":"在这里插入图片描述"},{"Type":"NodeCloseBracket","Data":"]"},{"Type":"NodeOpenParen","Data":"("},{"Type":"NodeLinkDest","Data":"https://i-blog.csdnimg.cn/direct/523d7e9f2d33449ea7621b7eea1c7c08.png"},{"Type":"NodeCloseParen","Data":")"}]}]},{"ID":"20260305082131-ae9aqtg","Type":"NodeParagraph","Properties":{"id":"20260305082131-ae9aqtg","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"② 如何运行加了断点的程序"}]},{"ID":"20260305082131-7xhcfme","Type":"NodeParagraph","Properties":{"id":"20260305082131-7xhcfme","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"在代码区域右键Debug执行"}]},{"ID":"20260305082131-31of887","Type":"NodeParagraph","Propertie