rue);\n        jf.setLayout(null);\n\n        //显示聊天信息的文本域\n        JTextArea messageArea = new JTextArea();\n        messageArea.setBounds(10,10,360,200);\n        jf.add(messageArea);\n\n        //输入聊天信息的文本框\n        JTextField messageField = new JTextField();\n        messageField.setBounds(10,230,180,20);\n        jf.add(messageField);\n\n        //发送按钮\n        JButton sendButton = new JButton(\"发送\");\n        sendButton.setBounds(200,230,70,20);\n        jf.add(sendButton);\n\n        //清空聊天按钮\n        JButton clearButton = new JButton(\"清空聊天\");\n        clearButton.setBounds(280,230,100,20);\n        jf.add(clearButton);\n\n        jf.setVisible(true);\n    }\n}\n12345678910111213141516171819202122232425262728293031323334353637383940\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3}]},{"ID":"20260305082131-d2y31hu","Type":"NodeHeading","HeadingLevel":5,"Properties":{"id":"20260305082131-d2y31hu","updated":"20260305082131"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"##### "},{"Type":"NodeText","Data":"18.3.3 案例3(猜数字)"}]},{"ID":"20260305082131-c8teule","Type":"NodeParagraph","Properties":{"id":"20260305082131-c8teule","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"需求：如图所示，做出界面"}]},{"ID":"20260305082131-c0xorj7","Type":"NodeParagraph","Properties":{"id":"20260305082131-c0xorj7","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"提示：给出的数据就是按照组件位置和大小给出的"}]},{"ID":"20260305082131-nww76ys","Type":"NodeParagraph","Properties":{"id":"20260305082131-nww76ys","updated":"20260305082131"},"Children":[{"Type":"NodeImage","Children":[{"Type":"NodeBang","Data":"!"},{"Type":"NodeOpenBracket","Data":"["},{"Type":"NodeLinkText","Data":"外链图片转存失败,源站可能有防盗链机制,建议将图片保存下来直接上传"},{"Type":"NodeCloseBracket","Data":"]"},{"Type":"NodeOpenParen","Data":"("},{"Type":"NodeLinkDest","Data":"https://i-blog.csdnimg.cn/direct/a4c51638b9fc4df582c45ddd739ac983.png"},{"Type":"NodeCloseParen","Data":")"}]}]},{"ID":"20260305082