ring[] args) {\n        //创建窗体对象\n        JFrame jf = new JFrame();\n\n        jf.setTitle(\"手机日期和时间显示\");\n        jf.setSize(400, 300);\n        jf.setDefaultCloseOperation(3);\n        jf.setLocationRelativeTo(null);\n        jf.setAlwaysOnTop(true);\n        jf.setLayout(null);\n\n        //提示日期\n        JLabel dateLable = new JLabel(\"日期\");\n        dateLable.setBounds(50,50,100,20);\n        jf.add(dateLable);\n\n        //按照格式显示日期的字符串\n        JLabel showDateLable = new JLabel(\"xxxx年xx月xx日\");\n        showDateLable.setBounds(50,80,200,20);\n        jf.add(showDateLable);\n\n        //提示时间\n        JLabel timeLable = new JLabel(\"时间\");\n        timeLable.setBounds(50,150,100,20);\n        jf.add(timeLable);\n\n        //按照格式显示时间的字符串\n        JLabel showTimeLable = new JLabel(\"xx:xx\");\n        showTimeLable.setBounds(50,180,200,20);\n        jf.add(showTimeLable);\n\n        jf.setVisible(true);\n    }\n}\n12345678910111213141516171819202122232425262728293031323334353637383940\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3}]},{"ID":"20260305082131-hugztpt","Type":"NodeHeading","HeadingLevel":5,"Properties":{"id":"20260305082131-hugztpt","updated":"20260305082131"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"##### "},{"Type":"NodeText","Data":"18.3.5 案例5(考勤查询)"}]},{"ID":"20260305082131-x11a02n","Type":"NodeParagraph","Properties":{"id":"20260305082131-x11a02n","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"需求：如图所示，做出界面"}]},{"ID":"20260305082131-62f0k27","Type":"NodeParagraph","Properties":{"id":"20260305082131-62f0k27","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"提示：给出的数据就是按照组件位置和大小给出的"}]},{"ID":"20260305082131-6fjbjin","Type":"NodeParagraph","Properties":{"id":"20260305082131-6fjbjin","updated":"20260305082131"},"Children":[{"Type":"NodeImage","Children":[{"Type":"NodeBang","Data":"!"},{"Type":"NodeOpenBracket","Data":"["},{"Type":"NodeLinkText","Data":"外链图片转存失败,源站可能有防盗链机制,建