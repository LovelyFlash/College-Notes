131"},"Children":[{"ID":"20260305082131-fhbfdso","Type":"NodeParagraph","Properties":{"id":"20260305082131-fhbfdso","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"注释是指在程序中添加的说明性信息"}]}]},{"ID":"20260305082131-fui9xt1","Type":"NodeListItem","Data":"-","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20260305082131-fui9xt1","updated":"20260305082131"},"Children":[{"ID":"20260305082131-imx6cx9","Type":"NodeParagraph","Properties":{"id":"20260305082131-imx6cx9","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"注释不参与程序运行，仅起到说明作用"}]}]}]},{"ID":"20260305082131-pp6ud7s","Type":"NodeParagraph","Properties":{"id":"20260305082131-pp6ud7s","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"这里我们再来介绍一下注释的分类："}]},{"ID":"20260305082131-iofo716","Type":"NodeParagraph","Properties":{"id":"20260305082131-iofo716","updated":"20260305082131"},"Children":[{"Type":"NodeImage","Children":[{"Type":"NodeBang","Data":"!"},{"Type":"NodeOpenBracket","Data":"["},{"Type":"NodeLinkText","Data":"外链图片转存失败,源站可能有防盗链机制,建议将图片保存下来直接上传"},{"Type":"NodeCloseBracket","Data":"]"},{"Type":"NodeOpenParen","Data":"("},{"Type":"NodeLinkDest","Data":"https://i-blog.csdnimg.cn/direct/a0ca63e856944692a665dbf002955fae.png"},{"Type":"NodeCloseParen","Data":")"}]}]},{"ID":"20260305082131-1ue4siy","Type":"NodeParagraph","Properties":{"id":"20260305082131-1ue4siy","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"了解了注释的作用和分类后，下面我们来对前面讲解过的HelloWorld案例添加注释："}]},{"ID":"20260305082131-f5u1mpk","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"amF2YQ==","CodeBlockCloseFence":"YGBg","Properties":{"id":"20260305082131-f5u1mpk","updated":"20260305082131"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"amF2YQ=="},{"Type":"NodeCodeBlockCode","Data":"/*\n    Java程序中最基本的组成单位是类\n\n    类的定义格式是：\n        public class 类名 {\n\n        }\n */\npublic class HelloWorld {\n    /*\n        这是main方法\n        main方法是程序的入口方法，代码的执行是从main方法开始的\n     */\n    public static void main(String[] args) {\n        //这是输出语句，能够将\"\"里面的内容输出到控制台，并且\"\"里面的内容是可以修改的\n        System.out.println(\"HelloWorld\");\n        System.out.println(\"Java\");\n    }\n}\n12345678910111213141516171819\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3}]},{"ID":"20260305082131-e8hw7hi","Type":"NodeParagraph","Properties":{"id":"20260305082131-e8hw7hi","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"有了注释以后，我们再来看这段代码，明显就容易理解了。后面大家自己在编写代码的时候，也要多写写注释，在实际开发中，我们编写的程序也是要添加注释的。"}]},{"ID":"20260305082131-s8fkxzw","Type":"NodeParagraph","Properties":{"id":"20260305082131-s8fkxzw","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"这样既方便自己阅读，也方便别人阅读。"}]},{"ID":"20260305082131-5v0ow74","Type":"NodeHeading","HeadingLevel":4,"Properties":{"id":"20260305082131-5v0ow74","updated":"20260305082131"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"#### "},{"Type":"NodeText","Data":"2.4 IDEA中常用快捷键"}]},{"ID":"20260305082131-je22nwm","Type":"NodeParagraph","Properties":{"id":"20260305082131-je22nwm","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"为了提高我们后续写程序的效率，这里呢，我们来讲一些IDEA中常用的快捷键："}]},{"ID":"20260305082131-jzmpdm3","Type":"NodeList","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20260305082131-jzmpdm3","updated":"20260305082131"},"Children":[{"ID":"20260305082131-fiun84k","Type":"NodeListItem","Data":"-","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20260305082131-fiun84k","updated":"20260305082131"},"Children":[{"ID":"20260305082131-pswf8hj","Type":"NodeParagraph","Properties":{"id":"20260305082131-pswf8hj","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data