60305082131"},"Children":[{"ID":"20260305082131-bj8mf24","Type":"NodeListItem","Data":"-","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20260305082131-bj8mf24","updated":"20260305082131"},"Children":[{"ID":"20260305082131-rlhnbfu","Type":"NodeParagraph","Properties":{"id":"20260305082131-rlhnbfu","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"带参方法定义时，参数中的 "},{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"数据类型"},{"Type":"NodeText","Data":" 与 "},{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"变量名"},{"Type":"NodeText","Data":" 都不能缺少，缺少任意一个程序将报错"}]}]},{"ID":"20260305082131-pjvhat6","Type":"NodeListItem","Data":"-","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20260305082131-pjvhat6","updated":"20260305082131"},"Children":[{"ID":"20260305082131-60mpmbw","Type":"NodeParagraph","Properties":{"id":"20260305082131-60mpmbw","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"带参方法定义时，多个参数之间使用 "},{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"逗号"},{"Type":"NodeText","Data":" (,)分隔"}]}]}]},{"ID":"20260305082131-whoe2hd","Type":"NodeParagraph","Properties":{"id":"20260305082131-whoe2hd","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"知道了带参数方法的定义格式后，我们到IDEA中去演示一下："}]},{"ID":"20260305082131-z5ekfb6","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"amF2YQ==","CodeBlockCloseFence":"YGBg","Properties":{"id":"20260305082131-z5ekfb6","updated":"20260305082131"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"amF2YQ=="},{"Type":"NodeCodeBlockCode","Data":"/*\n    带参数方法的定义和调用\n\n    定义格式：\n        public static void 方法名(参数) { … … }\n */\npublic class MethodDemo {\n    public static void main(String[] args) {\n        //字面量值调用\n        isEvenNumber(10);\n        isEvenNumber(9);\n\n        //变量的调用\n        int number = 11;\n        isEvenNumber(number);\n        number = 12;\n        isEvenNumber(number);\n    }\n\n    //需求：定义一个方法，该方法接收一个参数，判断该数据是否是偶数\n    public static void isEvenNumber(int number) {\n        if (number % 2 == 0) {\n            System.out.println(true);\n        } else {\n            System.out.println(false);\n        }\n    }\n}\n12345678910111213141516171819202122232425262728\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3}]},{"ID":"20260305082131-m75jqtf","Type":"NodeParagraph","Properties":{"id":"20260305082131-m75jqtf","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"演示完毕之后，回到资料我们总结一下带参数方法的调用和注意事项："}]},{"ID":"20260305082131-wvt0zy3","Type":"NodeParagraph","Properties":{"id":"20260305082131-wvt0zy3","updated":"20260305082131"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"格式："}]},{"ID":"20260305082131-cpjkxyb","Type":"NodeParagraph","Properties":{"id":"20260305082131-cpjkxyb","updated":"20260305082131"},"Children":[{"Type":"NodeImage","Children":[{"Type":"NodeBang","Data":"!"},{"Type":"NodeOpenBracket","Data":"["},{"Type":"NodeLinkText","Data":"外链图片转存失败,源站可能有防盗链机制,建议将图片保存下来直接上传"},{"Type":"NodeCloseBracket","Data":"]"},{"Type":"NodeOpenParen","Data":"("},{"Type":"NodeLinkDest","Data":"https://i-blog.csdnimg.cn/direct/cedf8f64db8a4bd2b92013d688e5ee31.png"},{"Type":"NodeCloseParen","Data":")"}]}]},{"ID":"20260305082131-y0r6mvb","Type":"NodeParagraph","Properties":{"id":"20260305082131-y0r6mvb","updated":"20260305082131"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"范例："}]},{"ID":"20260305082131-kzzz94f","Type":"NodeParagraph","Properties":{"id":"20260305082131-kzzz94f","updated":"20260305082131"},"Children":[{"Type":"NodeImage","Children":[{"Type":"NodeBang","Data":"!"},{"Type":"NodeOpenBracket","Data":"["