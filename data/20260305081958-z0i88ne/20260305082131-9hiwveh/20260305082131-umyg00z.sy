true);\n    }\n}\n12345678910111213141516171819202122\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3}]},{"ID":"20260305082131-zb136qg","Type":"NodeHeading","HeadingLevel":5,"Properties":{"id":"20260305082131-zb136qg","updated":"20260305082131"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"##### "},{"Type":"NodeText","Data":"18.2.2 JFrame(常用设置)"}]},{"ID":"20260305082131-qqaq4xe","Type":"NodeParagraph","Properties":{"id":"20260305082131-qqaq4xe","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"下面呢，我们再来学习几个JFrame窗体的常用方法："}]},{"ID":"20260305082131-9sccl6f","Type":"NodeList","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20260305082131-9sccl6f","updated":"20260305082131"},"Children":[{"ID":"20260305082131-b1lc6yd","Type":"NodeListItem","Data":"-","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20260305082131-b1lc6yd","updated":"20260305082131"},"Children":[{"ID":"20260305082131-arv3eqv","Type":"NodeParagraph","Properties":{"id":"20260305082131-arv3eqv","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"void setTitle(String title)：设置窗体标题"}]}]},{"ID":"20260305082131-o0n5r88","Type":"NodeListItem","Data":"-","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20260305082131-o0n5r88","updated":"20260305082131"},"Children":[{"ID":"20260305082131-9rw3dfk","Type":"NodeParagraph","Properties":{"id":"20260305082131-9rw3dfk","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"void setLocationRelativeTo(Component c)：设置位置，值为null，则窗体位于屏幕中央"}]}]},{"ID":"20260305082131-nj3qs5y","Type":"NodeListItem","Data":"-","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20260305082131-nj3qs5y","updated":"20260305082131"},"Children":[{"ID":"20260305082131-5uvfu6c","Type":"NodeParagraph","Properties":{"id":"20260305082131-5uvfu6c","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"void setDefaultCloseOperation(int operation)：设置窗体关闭时默认操作"}]},{"ID":"20260305082131-nbb0g7b","Type":"NodeList","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"MarkerOffset":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20260305082131-nbb0g7b","updated":"20260305082131"},"Children":[{"ID":"20260305082131-xbxgj7k","Type":"NodeListItem","Data":"-","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"MarkerOffset":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20260305082131-xbxgj7k","updated":"20260305082131"},"Children":[{"ID":"20260305082131-u02t6f0","Type":"NodeParagraph","Properties":{"id":"20260305082131-u02t6f0","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"整数3表示：窗口关闭时退出应用程序"}]}]}]}]},{"ID":"20260305082131-ntv2kui","Type":"NodeListItem","Data":"-","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20260305082131-ntv2kui","updated":"20260305082131"},"Children":[{"ID":"20260305082131-pve7nt1","Type":"NodeParagraph","Properties":{"id":"20260305082131-pve7nt1","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"void setAlwaysOnTop(boolean alwaysOnTop)：设置此窗口是否应始终位于其他窗口之上"}]}]}]},{"ID":"20260305082131-xaz5nxf","Type":"NodeParagraph","Properties":{"id":"20260305082131-xaz5nxf","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"了解了这几个方法后，我们到IDEA中去使用一下："}]},{"ID":"20260305082131-ehb19t9","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"amF2YQ==","CodeBlockCloseFence":"YGBg","Properties":{"id":"20260305082131-ehb19t9","updated":"20260305082131"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"amF2YQ=="},{"Type":"NodeCodeBlockCode","Data":"import javax.swing.*;\n\n/*\n    void setTitle(String title)：设置窗体标题\n    void setLocationRelativeTo(Component c)：设置位置，值为null，则窗体位于屏幕中央\n    void setDefaultCloseOperation(int operation)：设置窗体关闭时默认操作(整数3表示：窗口关闭时退出应用程序)\n    void setAlwaysOnTop(boolean alwaysOnTop)：设置此窗口是否应始终位于其他窗口之上\n */\npublic class JFrameDemo02 {\n    public static void main(String[] args) {\n        //创建窗体对象\n        JFrame jf = new JFrame();\n\n        //void setTitle(String title)：设置窗体标题\n        jf.setTitle(\"百度一下，你就知道\");\n        //设置窗体大小\n        jf.setSize(400, 300);\n        //void setDefaultCloseOperation(int operation)：设置窗体关闭时默认操作(整数3表示：窗口关闭时退出应用程序)\n        jf.setDefaultCloseOperation(3);\n        //void setLocationRelativeTo(Component c)：设置位置，值为null，则窗体位于屏幕中央\n        jf.setLocationRelativeTo(null);\n        //void setAlwaysOnTop(boolean alwaysOnTop)：设置此窗口是否应始终位于其他窗口之上\n        jf.setAlwaysOnTop(true);\n\n        //设置窗体可见\n        jf.setVisible(true);\n    }\n}\n12345678910111213141516171819202122232425262728\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3}]},{"ID":"20260305082131-gl0c6tu","Type":"NodeHeading","HeadingLevel":5,"Properties":{"id":"20260305082131-gl0c6tu","updated":"20260305082131"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"##### "},{"Type":"NodeText","Data":"18.2.3 JButton(窗口中添加按钮)"}]},{"ID":"20260305082131-n4x6c0k","Type":"NodeParagraph","Properties":{"id":"20260305082131-n4x6c0k","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"下面我们来学习JButton，它是按钮的实现。"}]},{"ID":"20260305082131-37ftsk1","Type":"NodeParagraph","Properties":{"id":"20260305082131-37ftsk1","updated":"20260305082131"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"JButton："}]},{"ID":"20260305082131-nutf6kc","Type":"NodeList","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20260305082131-nutf6kc","updated":"20260305082131"},"Children":[{"ID":"20260305082131-8hstgk7","Type":"NodeListItem","Data":"-","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20260305082131-8hstgk7","updated":"20260305082131"},"Children":[{"ID":"20260305082131-hkq7pq4","Type":"NodeParagraph","Properties":{"id":"20260305082131-hkq7pq4","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"按钮的实现"}]}]}]},{"ID":"20260305082131-tv3sfxu","Type":"NodeParagraph","Properties":{"id":"20260305082131-tv3sfxu","updated":"20260305082131"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"构造方法："}]},{"ID":"20260305082131-g2dg9w2","Type":"NodeList","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20260305082131-g2dg9w2","updated":"20260305082131"},"Children":[{"ID":"20260305082131-q5y901q","Type":"NodeListItem","Data":"-","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20260305082131-q5y901q","updated":"20260305082131"},"Children":[{"ID":"20260305082131-fp1tnd2","Type":"NodeParagraph","Properties":{"id":"20260305082131-fp1tnd2","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"JButton(String text)：创建一个带文本的按钮"}]}]}]},{"ID":"20260305082131-1du3y8m","Type":"NodeParagraph","Properties":{"id":"20260305082131-1du3y8m","updated":"20260305082131"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"成员方法："}]},{"ID":"20260305082131-3or2pvk","Type":"NodeList","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20260305082131-3or2pvk","updated":"20260305082131"},"Children":[{"ID":"20260305082131-kram8bw","Type":"NodeListItem","Data":"-","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20260305082131-kram8bw","updated":"20260305082131"},"Children":[{"ID":"20260305082131-jlucpis","Type":"NodeParagraph","Properties":{"id":"20260305082131-jlucpis","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"void setSize(int width, int height)：设置大小"}]}]},{"ID":"20260305082131-eggjakp","Type":"NodeListItem","Data":"-","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20260305082131-eggjakp","updated":"20260305082131"},"Children":[{"ID":"20260305082131-zgq3jna","Type":"NodeParagraph","Properties":{"id":"20260305082131-zgq3jna","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"void setLocation(int x, int y)：设置位置(x坐标，y坐标)"}]}]}]},{"ID":"20260305082131-4uyv2i1","Type":"NodeParagraph","Properties":{"id":"20260305082131-4uyv2i1","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"知道了JButton的构造方法和成员方法后，我们到IDEA中去使用一下："}]},{"ID":"20260305082131-d1heekd","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"amF2YQ==","CodeBlockCloseFence":"YGBg","Properties":{"id":"20260305082131-d1heekd","updated":"20260305082131"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"amF2YQ=="},{"Type":"NodeCodeBlockCode","Data":"import javax.swing.*;\n\n/*\n    构造方法\n        JButton(String text)：创建一个带文本的按钮\n\n    成员方法\n        void setSize(int width, int height)：设置大小\n        void setLocation(int x, int y)：设置位置(x坐标，y坐标)\n */\npublic class JButtonDemo {\n    public static void main(String[] args) {\n        //创建窗体对象\n        JFrame jf = new JFrame();\n\n        jf.setTitle(\"窗口中添加按钮\");\n        jf.setSize(400, 300);\n        jf.setDefaultCloseOperation(3);\n        jf.setLocationRelativeTo(null);\n        jf.setAlwaysOnTop(true);\n        jf.setLayout(null); //取消窗体的默认布局\n\n        //JButton(String text)：创建一个带文本的按钮\n        JButton btn = new JButton(\"我是按钮\");\n//        //void setSize(int width, int height)：设置大小\n//        btn.setSize(100,20);\n//        //void setLocation(int x, int y)：设置位置(x坐标，y坐标)\n        btn.setLocation(0,0);\n//        btn.setLocation(100,100);\n        btn.setBounds(100,100,100,20);\n\n        JButton btn2 = new JButton(\"我是按钮2\");\n        btn2.setBounds(100,120,100,20);\n\n        jf.add(btn);\n        jf.add(btn2);\n\n        //设置窗体可见\n        jf.setVisible(true);\n    }\n}\n1234567891011121314151617181920212223242526272829303132333435363738394041\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3}]},{"ID":"20260305082131-w0d69iu","Type":"NodeParagraph","Properties":{"id":"20260305082131-w0d69iu","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"演示完毕之后，回到资料再总结一下："}]},{"ID":"20260305082131-7vt7e6j","Type":"NodeParagraph","Properties":{"id":"20260305082131-7vt7e6j","updated":"20260305082131"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"JButton："}]},{"ID":"20260305082131-8nee5d0","Type":"NodeList","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20260305082131-8nee5d0","updated":"20260305082131"},"Children":[{"ID":"20260305082131-p93w125","Type":"NodeListItem","Data":"-","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20260305082131-p93w125","updated":"20260305082131"},"Children":[{"ID":"20260305082131-kjhoa6q","Type":"NodeParagraph","Properties":{"id":"20260305082131-kjhoa6q","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"按钮的实现"}]}]}]},{"ID":"20260305082131-99l03um","Type":"NodeParagraph","Properties":{"id":"20260305082131-99l03um","updated":"20260305082131"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"构造方法："}]},{"ID":"20260305082131-wqku4dn","Type":"NodeList","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20260305082131-wqku4dn","updated":"20260305082131"},"Children":[{"ID":"20260305082131-hytqh4b","Type":"NodeListItem","Data":"-","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","