messageLable = new JLabel(\"系统产生了一个1-100之间的数据，请猜一猜\");\n        messageLable.setBounds(70,50,350,20);\n        jf.add(messageLable);\n\n        //输入要猜的数字\n        JTextField numberField = new JTextField();\n        numberField.setBounds(120,100,150,20);\n        jf.add(numberField);\n\n        //猜数字的按钮\n        JButton guessButton = new JButton(\"我猜\");\n        guessButton.setBounds(150,150,100,20);\n        jf.add(guessButton);\n\n        jf.setVisible(true);\n    }\n}\n1234567891011121314151617181920212223242526272829303132333435\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3}]},{"ID":"20260305082131-kwulvo5","Type":"NodeHeading","HeadingLevel":5,"Properties":{"id":"20260305082131-kwulvo5","updated":"20260305082131"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"##### "},{"Type":"NodeText","Data":"18.3.4 案例4(手机日期和时间显示)"}]},{"ID":"20260305082131-uoz03yf","Type":"NodeParagraph","Properties":{"id":"20260305082131-uoz03yf","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"需求：如图所示，做出界面"}]},{"ID":"20260305082131-dki628j","Type":"NodeParagraph","Properties":{"id":"20260305082131-dki628j","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"提示：给出的数据就是按照组件位置和大小给出的"}]},{"ID":"20260305082131-9hojns3","Type":"NodeParagraph","Properties":{"id":"20260305082131-9hojns3","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"参照图："}]},{"ID":"20260305082131-zgmxffc","Type":"NodeParagraph","Properties":{"id":"20260305082131-zgmxffc","updated":"20260305082131"},"Children":[{"Type":"NodeImage","Children":[{"Type":"NodeBang","Data":"!"},{"Type":"NodeOpenBracket","Data":"["},{"Type":"NodeLinkText","Data":"外链图片转存失败,源站可能有防盗链机制,建议将图片保存下来直接上传"},{"Type":"NodeCloseBracket","Data":"]"},{"Type":"NodeOpenParen","Data":"("},{"Type":"NodeLinkDest","Data":"https://i-blog.csdnimg.cn/direct/77392ce16647416da8dc5ab7b452ba64.png"},{"Type":"NodeCloseParen","Data":")"}]}]},{"ID":"20260305082131-ebtlrcv","Type":"NodeParagraph