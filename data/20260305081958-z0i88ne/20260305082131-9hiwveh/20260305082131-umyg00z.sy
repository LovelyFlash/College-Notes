kFenceCloseMarker","Data":"```","CodeBlockFenceLen":3}]},{"ID":"20260305082131-30jgufg","Type":"NodeParagraph","Properties":{"id":"20260305082131-30jgufg","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"最后，我们来总结一下，刚才在演示代码的时候有个注意事项："}]},{"ID":"20260305082131-l8x53zt","Type":"NodeParagraph","Properties":{"id":"20260305082131-l8x53zt","updated":"20260305082131"},"Children":[{"Type":"NodeImage","Children":[{"Type":"NodeBang","Data":"!"},{"Type":"NodeOpenBracket","Data":"["},{"Type":"NodeLinkText","Data":"外链图片转存失败,源站可能有防盗链机制,建议将图片保存下来直接上传"},{"Type":"NodeCloseBracket","Data":"]"},{"Type":"NodeOpenParen","Data":"("},{"Type":"NodeLinkDest","Data":"https://i-blog.csdnimg.cn/direct/4eb007e095974b6db6751fe05e559a66.png"},{"Type":"NodeCloseParen","Data":")"}]}]},{"ID":"20260305082131-y949nh7","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20260305082131-y949nh7","updated":"20260305082131"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"### "},{"Type":"NodeText","Data":"5：选择语句"}]},{"ID":"20260305082131-rp6udi9","Type":"NodeParagraph","Properties":{"id":"20260305082131-rp6udi9","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"为了控制程序的执行流程，Java 就提供了一些流程控制语句，我们先来举例说明一下："}]},{"ID":"20260305082131-lkkqvo9","Type":"NodeParagraph","Properties":{"id":"20260305082131-lkkqvo9","updated":"20260305082131"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"顺序结构"},{"Type":"NodeText","Data":" ：从上往下，依次执行"}]},{"ID":"20260305082131-2k4dtzo","Type":"NodeParagraph","Properties":{"id":"20260305082131-2k4dtzo","updated":"20260305082131"},"Children":[{"Type":"NodeImage","Children":[{"Type":"NodeBang","Data":"!"},{"Type":"NodeOpenBracket","Data":"["},{"Type":"NodeLinkText","Data":"外链图片转存失败,源站可能有防盗链机制,建议将图片保存下来直接上传"},{"Type":"NodeCloseBracket","Data":"]"},{"Type":"NodeOpenParen","Data":"("},{"Type":"NodeLinkDest","Data":"https://i-blog.csdnimg.cn/direct/4852352b047b4cd098ae559b03d9b99e.png"},{"Type":"NodeCloseParen","Data