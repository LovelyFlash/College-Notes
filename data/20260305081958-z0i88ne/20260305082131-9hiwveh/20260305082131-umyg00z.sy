loseFence":"YGBg","Properties":{"id":"20260305082131-1cdu01z","updated":"20260305082131"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"amF2YQ=="},{"Type":"NodeCodeBlockCode","Data":"/*\n    需求：设计一个方法用于求1-n之间的数据和(n\u003e1)，返回求和结果。调用方法，把结果在控制台输出。\n */\npublic class MethodTest01 {\n    public static void main(String[] args) {\n        int result = sum(5);\n        System.out.println(\"1-5的和是：\" + result);\n\n        result = sum(100);\n        System.out.println(\"1-100的和是：\" + result);\n    }\n\n    /*\n       使用两个明确分析该方法的参数和返回值\n        参数：int n\n        返回值类型：int\n     */\n    public static int sum(int n) {\n        int sum = 0;\n\n        for (int i=1; i\u003c=n; i++) {\n            sum += i;\n        }\n\n        return sum;\n    }\n}\n123456789101112131415161718192021222324252627\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3}]},{"ID":"20260305082131-mid2y3r","Type":"NodeHeading","HeadingLevel":4,"Properties":{"id":"20260305082131-mid2y3r","updated":"20260305082131"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"#### "},{"Type":"NodeText","Data":"11.3 练习2(比较相等)"}]},{"ID":"20260305082131-0tll9ur","Type":"NodeParagraph","Properties":{"id":"20260305082131-0tll9ur","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"需求：设计一个方法用于比较两个整数是否相等，调用方法，把结果在控制台输出。"}]},{"ID":"20260305082131-pcuyvrg","Type":"NodeParagraph","Properties":{"id":"20260305082131-pcuyvrg","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"首先，我们来简单的分析一下："}]},{"ID":"20260305082131-dypyedy","Type":"NodeParagraph","Properties":{"id":"20260305082131-dypyedy","updated":"20260305082131"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"分析："}]},{"ID":"20260305082131-bli4pvw","Type":"NodeParagraph","Properties":{"id":"20260305082131-bli4pvw","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"① 方法定义"}