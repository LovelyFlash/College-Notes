cket","Data":"]"},{"Type":"NodeOpenParen","Data":"("},{"Type":"NodeLinkDest","Data":"https://i-blog.csdnimg.cn/direct/2d417a536e7645c8a77843aa9d5e01ee.png"},{"Type":"NodeCloseParen","Data":")"}]}]},{"ID":"20260305082131-lyntjwe","Type":"NodeParagraph","Properties":{"id":"20260305082131-lyntjwe","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"这样我们就实现了啤酒杯和红酒杯里面的酒进行交换。这种思想同样也适合我们程序中的数据交换。"}]},{"ID":"20260305082131-02mgb2r","Type":"NodeParagraph","Properties":{"id":"20260305082131-02mgb2r","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"下面我们到IDEA中去演示一下数据的交换："}]},{"ID":"20260305082131-zcwxo6e","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"amF2YQ==","CodeBlockCloseFence":"YGBg","Properties":{"id":"20260305082131-zcwxo6e","updated":"20260305082131"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"amF2YQ=="},{"Type":"NodeCodeBlockCode","Data":"/*\n    数据交换\n */\npublic class DataSwap {\n    public static void main(String[] args) {\n//        int a = 10;\n//        int b = 20;\n//        System.out.println(\"交换前：a=\" + a + \",b=\" + b);\n//        int temp = a;\n//        a = b;\n//        b = temp;\n//        System.out.println(\"交换后：a=\" + a + \",b=\" + b);\n\n        int[] arr = {11, 22, 33, 44, 55};\n        System.out.println(\"交换前：arr[0]=\" + arr[0] + \",arr[4]=\" + arr[4]);\n        int temp = arr[0];\n        arr[0] = arr[4];\n        arr[4] = temp;\n        System.out.println(\"交换后：arr[0]=\" + arr[0] + \",arr[4]=\" + arr[4]);\n    }\n}\n123456789101112131415161718192021\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3}]},{"ID":"20260305082131-xdiokzp","Type":"NodeParagraph","Properties":{"id":"20260305082131-xdiokzp","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"数据的交换演示完毕后，下面我们就可以来实现把数组中的元素打乱了："}]},{"ID":"20260305082131-fj0w3oo","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"amF2YQ==","CodeBlockCloseFence":"YGBg","Properties":{"id":"20260305082131-fj0w3oo","updated":"20260305082131"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"amF2YQ=="},{"Type":"NodeCodeBlockCode","Data":"import java.util.Random;\n\n/*\n    元素打乱\n */\npublic class ArrayTest03 {\n    public static void main(String[] args) {\n        //定义数组\n        int[] arr = {12, 45, 98, 73, 60};\n\n//        Random r = new Random();\n//        int index = r.nextInt(arr.length);\n//\n//        //第一次交换\n//        int temp = arr[0];\n//        arr[0] = arr[index];\n//        arr[index] = temp;\n//\n//        //第二次交换\n//        index = r.nextInt(arr.length);\n//        temp = arr[1];\n//        arr[1] = arr[index];\n//        arr[index] = temp;\n\n        Random r = new Random();\n        for (int i = 0; i \u003c arr.length; i++) {\n            int index = r.nextInt(arr.length);\n\n            int temp = arr[i];\n            arr[i] = arr[index];\n            arr[index] = temp;\n        }\n\n        //遍历数组\n        for (int i = 0; i \u003c arr.length; i++) {\n            System.out.println(arr[i]);\n        }\n    }\n}\n123456789101112131415161718192021222324252627282930313233343536373839\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3}]},{"ID":"20260305082131-0yczz6e","Type":"NodeHeading","HeadingLevel":4,"Properties":{"id":"20260305082131-0yczz6e","updated":"20260305082131"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"#### "},{"Type":"NodeText","Data":"13.7 数组动态初始化"}]},{"ID":"20260305082131-5bo0k19","Type":"NodeParagraph","Properties":{"id":"20260305082131-5bo0k19","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"下面我们来学习数组初始化之动态初始化。"}]},{"ID":"20260305082131-9nmjicz","Type":"NodeParagraph","Properties":{"id":"20260305082131-9nmjicz","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"前面呢，我们已经学习过了静态初始化，也就是初始化时指定每个数组元素的初始值。"}]},{"ID":"20260305082131-cpfltwb","Type":"NodeParagraph","Properties":{"id":"20260305082131-cpfltwb","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"而动态初始化呢？初始化时只指定数组长度，由系统为数组分配初始值"}]},{"ID":"20260305082131-dc0133e","Type":"NodeParagraph","Properties":{"id":"20260305082131-dc0133e","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"这里我们来看一下动态初始化的格式："}]},{"ID":"20260305082131-ol3na5l","Type":"NodeList","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20260305082131-ol3na5l","updated":"20260305082131"},"Children":[{"ID":"20260305082131-njw3nwd","Type":"NodeListItem","Data":"-","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20260305082131-njw3nwd","updated":"20260305082131"},"Children":[{"ID":"20260305082131-nsdl5j2","Type":"NodeParagraph","Properties":{"id":"20260305082131-nsdl5j2","updated":"20260305082131"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"格式："},{"Type":"NodeText","Data":" 数据类型"},{"Type":"NodeBackslash","Children":[{"Type":"NodeBackslashContent","Data":"["}]},{"Type":"NodeBackslash","Children":[{"Type":"NodeBackslashContent","Data":"]"}]},{"Type":"NodeText","Data":" 变量名 = new 数据类型"},{"Type":"NodeBackslash","Children":[{"Type":"NodeBackslashContent","Data":"["}]},{"Type":"NodeText","Data":"数组长度"},{"Type":"NodeBackslash","Children":[{"Type":"NodeBackslashContent","Data":"]"}]},{"Type":"NodeText","Data":";"}]}]},{"ID":"20260305082131-3zodncu","Type":"NodeListItem","Data":"-","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20260305082131-3zodncu","updated":"20260305082131"},"Children":[{"ID":"20260305082131-g3qaoqu","Type":"NodeParagraph","Properties":{"id":"20260305082131-g3qaoqu","updated":"20260305082131"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"范例："},{"Type":"NodeText","Data":" int"},{"Type":"NodeBackslash","Children":[{"Type":"NodeBackslashContent","Data":"["}]},{"Type":"NodeBackslash","Children":[{"Type":"NodeBackslashContent","Data":"]"}]},{"Type":"NodeText","Data":" arr = new int"},{"Type":"NodeBackslash","Children":[{"Type":"NodeBackslashContent","Data":"["}]},{"Type":"NodeText","Data":"3"},{"Type":"NodeBackslash","Children":[{"Type":"NodeBackslashContent","Data":"]"}]},{"Type":"NodeText","Data":";"}]}]}]},{"ID":"20260305082131-k9uubvn","Type":"NodeParagraph","Properties":{"id":"20260305082131-k9uubvn","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"表示我们定义了一个int类型的数组，初始化为3个元素。"}]},{"ID":"20260305082131-jj189z7","Type":"NodeParagraph","Properties":{"id":"20260305082131-jj189z7","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"知道了如何对数组进行动态初始化之后，下面我们到IDEA中去使用一下："}]},{"ID":"20260305082131-v0qvuag","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"amF2YQ==","CodeBlockCloseFence":"YGBg","Properties":{"id":"20260305082131-v0qvuag","updated":"20260305082131"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"amF2YQ=="},{"Type":"NodeCodeBlockCode","Data":"/*\n    动态初始化：初始化时只指定数组长度，由系统为数组分配初始值\n    格式：数据类型[] 变量名 = new 数据类型[数组长度];\n    范例：int[] arr = new int[3];\n */\npublic class ArrayDemo {\n    public static void main(String[] args) {\n        //格式：数据类型[] 变量名 = new 数据类型[数组长度];\n        int[] arr = new int[3];\n\n        //输出数组名\n        System.out.println(arr); //[I@776ec8df\n\n        //输出数组中的元素\n        System.out.println(arr[0]);\n        System.out.println(arr[1]);\n        System.out.println(arr[2]);\n        System.out.println(\"------------\");\n\n        //修改数组中的元素\n        arr[0] = 10;\n        arr[1] = 20;\n        arr[2] = 30;\n\n        //再次输出数组中的元素\n        System.out.println(arr[0]);\n        System.out.println(arr[1]);\n        System.out.println(arr[2]);\n    }\n}\n123456789101112131415161718192021222324252627282930\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3}]},{"ID":"20260305082131-qbjmeg1","Type":"NodeParagraph","Properties":{"id":"20260305082131-qbjmeg1","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"演示完毕之后，回到资料我们总结一下数组初始化的两种方式的 "},{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"各自使用场景："}]},{"ID":"20260305082131-48iupq6","Type":"NodeList","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20260305082131-48iupq6","updated":"20260305082131"},"Children":[{"ID":"20260305082131-1ngc49a","Type":"NodeListItem","Data":"-","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20260305082131-1ngc49a","updated":"20260305082131"},"Children":[{"ID":"20260305082131-lxouixy","Type":"NodeParagraph","Properties":{"id":"20260305082131-lxouixy","updated":"20260305082131"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"静态初始化："},{"Type":"NodeText","Data":" 开始就存入元素值，适合一开始就能确定元素值的业务场景"}]}]},{"ID":"20260305082131-44pr6g2","Type":"NodeListItem","Data":"-","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20260305082131-44pr6g2","updated":"20260305082131"},"Children":[{"ID":"20260305082131-eyin5tx","Type":"NodeParagraph","Properties":{"id":"20260305082131-eyin5tx","updated":"20260305082131"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"动态初始化："},{"Type":"NodeText","Data":" 指定数组长度，后期赋值，适合开始知道数据的数量，但是不确定具体元素值的业务场景"}]}]},{"ID":"20260305082131-t94gjaq","Type":"NodeListItem","Data":"-","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20260305082131-t94gjaq","updated":"20260305082131"},"Children":[{"ID":"20260305082131-ibxvqmd","Type":"NodeParagraph","Properties":{"id":"20260305082131-ibxvqmd","updated":"20260305082131"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"注意："},{"Type":"NodeText","Data":" 两种初始化的方式是独立的，不可以混用"}]}]}]},{"ID":"20260305082131-0hlhvm1","Type":"NodeParagraph","Properties":{"id":"20260305082131-0hlhvm1","updated":"20260305082131"},"Children":[{"Type":"NodeImage","Children":[{"Type":"NodeBang","Data":"!"},{"Type":"NodeOpenBracket","Data":"["},{"Type":"NodeLinkText","Data":"外链图片转存失败,源站可能有防盗链机制,建议将图片保存下来直接上传"},{"Type":"NodeCloseBracket","Data":"]"},{"Type":"NodeOpenParen","Data":"("},{"Type":"NodeLinkDest","Data":"https://i-blog.csdnimg.cn/direct/dffa8b3a3e4741c1af4c3d99ef2a86b8.png"},{"Type":"NodeCloseParen","Data":")"}]}]},{"ID":"20260305082131-9yihnuq","Type":"NodeParagraph","Properties":{"id":"20260305082131-9yihnuq","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"好了，关于数组初始化之动态初始化我们就先讲到这里。"}]},{"ID":"20260305082131-g0xkpyx","Type":"NodeHeading","HeadingLevel":4,"Properties":{"id":"20260305082131-g0xkpyx","updated":"20260305082131"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"#### "},{"Type":"NodeText","Data":"13.8 案例4(数组元来自键盘录入)"}]},{"ID":"20260305082131-y4m7zir","Type":"NodeParagraph","Properties":{"id":"20260305082131-y4m7zir","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"下面我们来做一个案例：数组元素来自键盘录入"}]},{"ID":"20260305082131-3i8yrog","Type":"NodeParagraph","Properties":{"id":"20260305082131-3i8yrog","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"首先呢，我们来看一下具体的需求："}]},{"ID":"20260305082131-yg3r84u","Type":"NodeList","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20260305082131-yg3r84u","updated":"20260305082131"},"Children":[{"ID":"20260305082131-fe5oj8v","Type":"NodeListItem","Data":"-","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20260305082131-fe5oj8v","updated":"20260305082131"},"Children":[{"ID":"20260305082131-b7c2gu2","Type":"NodeParagraph","Properties":{"id":"20260305082131-b7c2gu2","updated":"20260305082131"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"需求："},{"Type":"NodeText","Data":" 定义一个可以存储5个元素的int数组，数据来自于键盘录入，最后遍历数组，把元素输出在控制台"}]}]}]},{"ID":"20260305082131-8xe3r00","Type":"NodeParagraph","Properties":{"id":"20260305082131-8xe3r00","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"首先，我们来简单的分析一下："}]},{"ID":"20260305082131-dr1s2fs","Type":"NodeParagraph","Properties":{"id":"20260305082131-dr1s2fs","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"这个数组可以存储5个int类型的元素，但是数据来自于键盘录入，也就是先指定数组长度，后期赋值。"}]},{"ID":"20260305082131-hw3pke9","Type":"NodeParagraph","Properties":{"id":"20260305082131-hw3pke9","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"这很明显适合使用数组的动态初始化，所以，这里我们将采用动态初始化对数组进行初始化。"}]},{"ID":"20260305082131-tr0e618","Type":"NodeParagraph","Properties":{"id":"20260305082131-tr0e618","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"接着，数据来自于键盘录入，我们得知道这里要使用Scanner来实现。"}]},{"ID":"20260305082131-c1w7h3s","Type":"NodeParagraph","Properties":{"id":"20260305082131-c1w7h3s","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"明确了这两个内容后，下面我们到IDEA中一起去实现一下："}]},{"ID":"20260305082131-cypivry","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"amF2YQ==","CodeBlockCloseFence":"YGBg","Properties":{"id":"20260305082131-cypivry","updated":"20260305082131"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"amF2YQ=="},{"Type":"NodeCodeBlockCode","Data":"import java.util.Scanner;\n\n/*\n    需求：定义一个可以存储5个元素的int数组，数据来自于键盘录入，最后遍历数组，把元素输出在控制台\n */\npublic class ArrayTest {\n    public static void main(String[] args) {\n        //定义一个数组，并进行动态初始化\n        int[] arr = new int[5];\n\n        //创建键盘录入对象\n        Scanner sc = new Scanner(System.in);\n\n//        //录入第1个数据\n//        System.out.println(\"请输入第1个数据：\");\n        int i = sc.nextInt();\n        arr[0] = i;\n//        arr[0] = sc.nextInt();\n//\n//        //录入第2个数据\n//        System.out.println(\"请输入第2个数据：\");\n//        arr[1] = sc.nextInt();\n\n        for (int i = 0; i \u003c arr.length; i++) {\n            System.out.println(\"请输入第\" + (i + 1) + \"个元素：\");\n            arr[i] = sc.nextInt();\n        }\n\n        printArray(arr);\n\n            //输出内容并换行\n//        System.out.println(\"hello\");\n//        System.out.println(\"world\");\n            //输出内容不换行\n//        System.out.print(\"hello\");\n//        System.out.print(\"world\");\n    }\n\n    public static void printArray(int[] arr) {\n        System.out.print(\"[\");\n        for (int i = 0; i \u003c arr.length; i++) {\n            if(i==arr.length-1) {\n                System.out.print(arr[i]);\n            }else {\n                System.out.print(arr[i] + \", \");\n            }\n        }\n        System.out.println(\"]\");\n    }\n\n    /*\n        参数：int[] arr\n        返回值：void\n     */\n//    public static void printArray(int[] arr) {\n//        for (int i = 0; i \u003c arr.length; i++) {\n//            System.out.println(arr[i]);\n//        }\n//    }\n}\n123456789101112131415161718192021222324252627282930313233343536373839404142434445464748495051525354555657585960\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3}]},{"ID":"20260305082131-mssfmpt","Type":"NodeParagraph","Properties":{"id":"20260305082131-mssfmpt","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"在讲解过程中，我们讲到了一个新的输出语句，不带ln的方法，它只输出内容，不换行。"}]},{"ID":"20260305082131-q6445vx","Type":"NodeParagraph","Properties":{"id":"20260305082131-q6445vx","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"而以前我们使用的输出语句，不仅仅把内容输出，而且在输出内容后，会加一个换行。"}]},{"ID":"20260305082131-0uujyq9","Type":"NodeParagraph","Properties":{"id":"20260305082131-0uujyq9","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"好了，关于案例数组元素来自键盘录入我们就先讲到这里。"}]},{"ID":"20260305082131-e5y5a9w","Type":"NodeHeading","HeadingLevel":4,"Properties":{"id":"20260305082131-e5y5a9w","updated":"20260305082131"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"#### "},{"Type":"NodeText","Data":"13.9 数组内存图"}]},{"ID":"20260305082131-9i8685c","Type":"NodeParagraph","Properties":{"id":"20260305082131-9i8685c","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"下面我们来学习数组内存图。"}]},{"ID":"20260305082131-uuaqig4","Type":"NodeParagraph","Properties":{"id":"20260305082131-uuaqig4","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"这里呢，我们通过单个数组的内存图让大家了解一下数组在内存中的存储和使用就可以了。"}]},{"ID":"20260305082131-07l5j64","Type":"NodeParagraph","Properties":{"id":"20260305082131-07l5j64","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"整个过程讲解的是下图代码的执行流程，大家能够听懂即可。"}]},{"ID":"20260305082131-7ym0r9o","Type":"NodeParagraph","Properties":{"id":"20260305082131-7ym0r9o","updated":"20260305082131"},"Children":[{"Type":"NodeImage","Children":[{"Type":"NodeBang","Data":"!"},{"Type":"NodeOpenBracket","Data":"["},{"Type":"NodeLinkText","Data":"外链图片转存失败,源站可能有防盗链机制,建议将图片保存下来直接上传"},{"Type":"NodeCloseBracket","Data":"]"},{"Type":"NodeOpenParen","Data":"("},{"Type":"NodeLinkDest","Data":"https://i-blog.csdnimg.cn/direct/610b700dd64449809230715004e43cb6.png"},{"Type":"NodeCloseParen","Data":")"}]}]},{"ID":"20260305082131-jnao72d","Type":"NodeParagraph","Properties":{"id":"20260305082131-jnao72d","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"最后，我们自己编写代码验证一下："}]},{"ID":"20260305082131-z0nwsx8","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"amF2YQ==","CodeBlockCloseFence":"YGBg","Properties":{"id":"20260305082131-z0nwsx8","updated":"20260305082131"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"amF2YQ=="},{"Type":"NodeCodeBlockCode","Data":"/*\n    数组内存图代码\n */\npublic class ArrayTest01 {\n    public static void main(String[] args) {\n        int[] arr = new int[3];\n\n        //输出数组名及元素\n        System.out.println(arr);\n        System.out.println(arr[0]);\n        System.out.println(arr[1]);\n        System.out.println(arr[2]);\n\n        //给数组中的元素赋值\n        arr[0] = 100;\n        arr[2] = 200;\n\n        //再次输出数组名及元素\n        System.out.println(arr);\n        System.out.println(arr[0]);\n        System.out.println(arr[1]);\n        System.out.println(arr[2]);\n    }\n}\n123456789101112131415161718192021222324\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3}]},{"ID":"20260305082131-y6mwpsd","Type":"NodeParagraph","Properties":{"id":"20260305082131-y6mwpsd","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"由于仅仅是验证讲解的结论，故不需要练习。"}]},{"ID":"20260305082131-e7ek5ah","Type":"NodeHeading","HeadingLevel":4,"Properties":{"id":"20260305082131-e7ek5ah","updated":"20260305082131"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"#### "},{"Type":"NodeText","Data":"13.10 数组使用中的两个小问题"}]},{"ID":"20260305082131-pnnnxfi","Type":"NodeParagraph","Properties":{"id":"20260305082131-pnnnxfi","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"下面我们来讲解一下数组使用中的两个小问题。"}]},{"ID":"20260305082131-yr3cp7j","Type":"NodeParagraph","Properties":{"id":"20260305082131-yr3cp7j","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"先来看第一个问题：请问下列代码有问题吗？如果有，是什么问题？如何解决？"}]},{"ID":"20260305082131-g5xv57y","Type":"NodeParagraph","Properties":{"id":"20260305082131-g5xv57y","updated":"20260305082131"},"Children":[{"Type":"NodeImage","Children":[{"Type":"NodeBang","D