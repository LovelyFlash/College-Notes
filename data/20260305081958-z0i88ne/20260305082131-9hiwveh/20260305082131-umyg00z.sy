= new JFrame();\n\n        jf.setTitle(\"考勤查询\");\n        jf.setSize(400, 300);\n        jf.setDefaultCloseOperation(3);\n        jf.setLocationRelativeTo(null);\n        jf.setAlwaysOnTop(true);\n        jf.setLayout(null);\n\n        //显示考勤日期的文本\n        JLabel dateLable = new JLabel(\"考勤日期\");\n        dateLable.setBounds(50,20,100,20);\n        jf.add(dateLable);\n\n        //显示开始时间文本\n        JLabel startDateLable = new JLabel(\"开始时间\");\n        startDateLable.setBounds(50,70,100,20);\n        jf.add(startDateLable);\n\n        //开始时间输入框\n        JTextField startDateField = new JTextField();\n        startDateField.setBounds(50,100,100,20);\n        jf.add(startDateField);\n\n        //显示结束时间文本\n        JLabel endDateLable = new JLabel(\"结束时间\");\n        endDateLable.setBounds(250,70,100,20);\n        jf.add(endDateLable);\n\n        //结束时间输入框\n        JTextField endDateField = new JTextField();\n        endDateField.setBounds(250,100,100,20);\n        jf.add(endDateField);\n\n        //确定按钮\n        JButton confirmButton = new JButton(\"确定\");\n        confirmButton.setBounds(250,180,60,20);\n        jf.add(confirmButton);\n\n        jf.setVisible(true);\n    }\n}\n1234567891011121314151617181920212223242526272829303132333435363738394041424344454647484950\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3}]},{"ID":"20260305082131-kfi3suz","Type":"NodeHeading","HeadingLevel":5,"Properties":{"id":"20260305082131-kfi3suz","updated":"20260305082131"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"##### "},{"Type":"NodeText","Data":"18.3.6 案例5(考勤查询之日历控件)"}]},{"ID":"20260305082131-o5ci1yh","Type":"NodeParagraph","Properties":{"id":"20260305082131-o5ci1yh","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"需求：用日历控件改进考勤查询的日期字符串填写"}]},{"ID":"20260305082131-ylkp9cr","Type":"NodeParagraph","Properties":{"id":"20260305082131-ylkp9cr","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"下面我们来学习考勤查询之日历控件"}]},{"ID":"20260305082131-t38nkf0","Type":"NodeParagraph","Properties":{"id":"20260305082131-t38nkf0","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"首先，我们看一下需求：用日历控件改进考勤查询的日期字符串填写"}]},{"ID":"20260305082131-qu1p68u","Type":"NodeParagraph","Properties":{"id":"20260305082131-qu1p68u","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"什么意思呢？我们刚在做的考勤查询系统，是需要手动输入日期字符串的，而在实际开发中，我们一般会选择使用日历控件来实现，"}]},{"ID":"20260305082131-loxzsay","Type":"NodeParagraph","Properties":{"id":"20260305082131-loxzsay","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"也就是下面这个样子的，我们点击一下，就会出现日历控件，我们选择日期就可以了。"}]},{"ID":"20260305082131-6ldajqh","Type":"NodeParagraph","Properties":{"id":"20260305082131-6ldajqh","updated":"20260305082131"},"Children":[{"Type":"NodeImage","Children":[{"Type":"NodeBang","Data":"!"},{"Type":"NodeOpenBracket","Data":"["},{"Type":"NodeLinkText","Data":"外链图片转存失败,源站可能有防盗链机制,建议将图片保存下来直接上传"},{"Type":"NodeCloseBracket","Data":"]"},{"Type":"NodeOpenParen","Data":"("},{"Type":"NodeLinkDest","Data":"https://i-blog.csdnimg.cn/direct/75874a08616e4930ac935e637f0f7ff5.png"},{"Type":"NodeCloseParen","Data":")"}]}]},{"ID":"20260305082131-1xb3i00","Type":"NodeParagraph","Properties":{"id":"20260305082131-1xb3i00","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"这个相信大家有见过。"}]},{"ID":"20260305082131-wb9u6ce","Type":"NodeParagraph","Properties":{"id":"20260305082131-wb9u6ce","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"知道了要做什么之后，下面我们来说一下，怎么做。"}]},{"ID":"20260305082131-hqmuffj","Type":"NodeParagraph","Properties":{"id":"20260305082131-hqmuffj","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"我们可以自己写这个日历控件，也可以使用别人写好的日历控件。鉴于目前所学知识有限，我们先使用别人提供的日历控件。"}]},{"ID":"20260305082131-si57x0s","Type":"NodeParagraph","Properties":{"id":"20260305082131-si57x0s","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"这里呢，我准备好了一个 "},{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"日历控件类(DateChooser.java)"},{"Type":"NodeText","Data":" ，我们到IDEA中一起去看一下如何使用："}]},{"ID":"20260305082131-rkzxc2j","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"amF2YQ==","CodeBlockCloseFence":"YGBg","Properties":{"id":"20260305082131-rkzxc2j","updated":"20260305082131"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"amF2YQ=="},{"Type":"NodeCodeBlockCode","Data":"public static void main(String[] args) {\n    //创建窗体\n    JFrame jf = new JFrame();\n\n    //设置窗体大小\n    jf.setSize(400, 300);\n    //设置窗体标题\n    jf.setTitle(\"日历控件\");\n    //设置位置，值为null，则窗体位于屏幕中央\n    jf.setLocationRelativeTo(null);\n    //设置窗体关闭时默认操作，窗口关闭时退出应用程序\n    jf.setDefaultCloseOperation(3);\n    //设置此窗口是否应始终位于其他窗口之上\n    jf.setAlwaysOnTop(true);\n    //取消窗体默认布局：窗体对象.setLayout(null);\n    jf.setLayout(null);\n\n    //创建日期选择器对象，指定日期字符串格式\n    DateChooser dateChooser = DateChooser.getInstance(\"yyyy-MM-dd\");\n\n    JTextField showDateField = new JTextField(\"单击选择日期\");\n    showDateField.setBounds(50, 50, 100, 20);\n\n    //把日历控件和文本框进行绑定\n    dateChooser.register(showDateField);\n\n    jf.add(showDateField);\n\n    jf.setVisible(true);\n}\n123456789101112131415161718192021222324252627282930\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3}]},{"ID":"20260305082131-rzsvl7v","Type":"NodeParagraph","Properties":{"id":"20260305082131-rzsvl7v","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"了解了如何使用日历控件后，我们把开始写的代码改进一下："}]},{"ID":"20260305082131-hytpk6b","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"amF2YQ==","CodeBlockCloseFence":"YGBg","Properties":{"id":"20260305082131-hytpk6b","updated":"20260305082131"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"amF2YQ=="},{"Type":"NodeCodeBlockCode","Data":"import javax.swing.*;\n\n/*\n    考勤查询\n */\npublic class AttendanceQuery02 {\n    public static void main(String[] args) {\n        //创建窗体对象\n        JFrame jf = new JFrame();\n\n        jf.setTitle(\"考勤查询\");\n        jf.setSize(400, 300);\n        jf.setDefaultCloseOperation(3);\n        jf.setLocationRelativeTo(null);\n        jf.setAlwaysOnTop(true);\n        jf.setLayout(null);\n\n        //显示考勤日期的文本\n        JLabel dateLable = new JLabel(\"考勤日期\");\n        dateLable.setBounds(50,20,100,20);\n        jf.add(dateLable);\n\n        //显示开始时间文本\n        JLabel startDateLable = new JLabel(\"开始时间\");\n        startDateLable.setBounds(50,70,100,20);\n        jf.add(startDateLable);\n\n        DateChooser dateChooser1 = DateChooser.getInstance(\"yyyy/MM/dd\");\n        DateChooser dateChooser2 = DateChooser.getInstance(\"yyyy/MM/dd\");\n        //开始时间输入框\n        JTextField startDateField = new JTextField();\n        startDateField.setBounds(50,100,100,20);\n        dateChooser1.register(startDateField);\n        jf.add(startDateField);\n\n        //显示结束时间文本\n        JLabel endDateLable = new JLabel(\"结束时间\");\n        endDateLable.setBounds(250,70,100,20);\n        jf.add(endDateLable);\n\n        //结束时间输入框\n        JTextField endDateField = new JTextField();\n        endDateField.setBounds(250,100,100,20);\n        dateChooser2.register(endDateField);\n        jf.add(endDateField);\n\n        //确定按钮\n        JButton confirmButton = new JButton(\"确定\");\n        confirmButton.setBounds(250,180,60,20);\n        jf.add(confirmButton);\n\n        jf.setVisible(true);\n    }\n}\n123456789101112131415161718192021222324252627282930313233343536373839404142434445464748495051525354\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3}]},{"ID":"20260305082131-t67mmo1","Type":"NodeHeading","HeadingLevel":4,"Properties":{"id":"20260305082131-t67mmo1","updated":"20260305082131"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"#### "},{"Type":"NodeText","Data":"18.4 事件监听机制"}]},{"ID":"20260305082131-2o9ifr0","Type":"NodeParagraph","Properties":{"id":"20260305082131-2o9ifr0","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"目前呢，我们做好了几个GUI的界面，但是具体的功能，我们没法实现。因为要想实现功能，就必须要学习一下事件监听机制。"}]},{"ID":"20260305082131-pea4uj8","Type":"NodeParagraph","Properties":{"id":"20260305082131-pea4uj8","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"这里，我们一起来说一下 "},{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"事件监听机制的组成："}]},{"ID":"20260305082131-iau47rz","Type":"NodeList","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20260305082131-iau47rz","updated":"20260305082131"},"Children":[{"ID":"20260305082131-65b5o17","Type":"NodeListItem","Data":"-","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20260305082131-65b5o17","updated":"20260305082131"},"Children":[{"ID":"20260305082131-pb91guu","Type":"NodeParagraph","Properties":{"id":"20260305082131-pb91guu","updated":"20260305082131"},"Children":[{"Type":"NodeBackslash","Children":[{"Type":"NodeBackslashContent","Data":"*"}]},{"Type":"NodeBackslash","Children":[{"Type":"NodeBackslashContent","Data":"*"}]},{"Type":"NodeText","Data":"事件源："},{"Type":"NodeBackslash","Children":[{"Type":"NodeBackslashContent","Data":"*"}]},{"Type":"NodeBackslash","Children":[{"Type":"NodeBackslashContent","Data":"*"}]},{"Type":"NodeText","Data":"事件发生的地方。可以是按钮，窗体，图片等"}]}]},{"ID":"20260305082131-wijsp22","Type":"NodeListItem","Data":"-","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20260305082131-wijsp22","updated":"20260305082131"},"Children":[{"ID":"20260305082131-8cwm3on","Type":"NodeParagraph","Properties":{"id":"20260305082131-8cwm3on","updated":"20260305082131"},"Children":[{"Type":"NodeBackslash","Children":[{"Type":"NodeBackslashContent","Data":"*"}]},{"Type":"NodeBackslash","Children":[{"Type":"NodeBackslashContent","Data":"*"}]},{"Type":"NodeText","Data":"事件："},{"Type":"NodeBackslash","Children":[{"Type":"NodeBackslashContent","Data":"*"}]},{"Type":"NodeBackslash","Children":[{"Type":"NodeBackslashContent","Data":"*"}]},{"Type":"NodeText","Data":"发生了什么事情。例如：鼠标点击事件，键盘按下事件等"}]}]},{"ID":"20260305082131-214soxe","Type":"NodeListItem","Data":"-","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20260305082131-214soxe","updated":"20260305082131"},"Children":[{"ID":"20260305082131-srz943d","Type":"NodeParagraph","Properties":{"id":"20260305082131-srz943d","updated":"20260305082131"},"Children":[{"Type":"NodeBackslash","Children":[{"Type":"NodeBackslashContent","Data":"*"}]},{"Type":"NodeBackslash","Children":[{"Type":"NodeBackslashContent","Data":"*"}]},{"Type":"NodeText","Data":"事件绑定："},{"Type":"NodeBackslash","Children":[{"Type":"NodeBackslashContent","Data":"*"}]},{"Type":"NodeBackslash","Children":[{"Type":"NodeBackslashContent","Data":"*"}]},{"Type":"NodeText","Data":"把事件绑定到事件源上，当发生了某个事件，则触发对应的处理逻辑"}]},{"ID":"20260305082131-6bwptfl","Type":"NodeList","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"MarkerOffset":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20260305082131-6bwptfl","updated":"20260305082131"},"Children":[{"ID":"20260305082131-ct4j2v9","Type":"NodeListItem","Data":"-","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"MarkerOffset":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20260305082131-ct4j2v9","updated":"20260305082131"},"Children":[{"ID":"20260305082131-pl86xd7","Type":"NodeParagraph","Properties":{"id":"20260305082131-pl86xd7","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"事件源对象. addXXXListener(事件);"}]}]}]}]}]},{"ID":"20260305082131-6iuhis9","Type":"NodeParagraph","Properties":{"id":"20260305082131-6iuhis9","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"GUI中的事件比较多，这里呢，我们先告诉一下大家如何给按钮添加事件，能够把我们前面的案例给实现就可以了。至于其他事件，后面我们用到的时候再去学习。"}]},{"ID":"20260305082131-cry2bo9","Type":"NodeParagraph","Properties":{"id":"20260305082131-cry2bo9","updated":"20260305082131"},"Children":[{"Type":"NodeImage","Children":[{"Type":"NodeBang","Data":"!"},{"Type":"NodeOpenBracket","Data":"["},{"Type":"NodeLinkText","Data":"外链图片转存失败,源站可能有防盗链机制,建议将图片保存下来直接上传"},{"Type":"NodeCloseBracket","Data":"]"},{"Type":"NodeOpenParen","Data":"("},{"Type":"NodeLinkDest","Data":"https://i-blog.csdnimg.cn/direct/eb4fc209e6544e648826387349fc2e90.png"},{"Type":"NodeCloseParen","Data":")"}]}]},{"ID":"20260305082131-wsk6i2h","Type":"NodeParagraph","Properties":{"id":"20260305082131-wsk6i2h","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"了解了如何给按钮添加事件后，我们到IDEA中去体验一下："}]},{"ID":"20260305082131-ud2ddcc","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"amF2YQ==","CodeBlockCloseFence":"YGBg","Properties":{"id":"20260305082131-ud2ddcc","updated":"20260305082131"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"amF2YQ=="},{"Type":"NodeCodeBlockCode","Data":"import javax.swing.*;\nimport java.awt.event.ActionEvent;\nimport java.awt.event.ActionListener;\n\n/*\n    事件监听机制\n */\npublic class ActionListenerDemo {\n    public static void main(String[] args) {\n        //创建窗体对象\n        JFrame jf = new JFrame();\n\n        jf.setTitle(\"事件监听机制\");\n        jf.setSize(400, 300);\n        jf.setDefaultCloseOperation(3);\n        jf.setLocationRelativeTo(null);\n        jf.setAlwaysOnTop(true);\n        jf.setLayout(null);\n\n        //创建按钮\n        JButton jButton = new JButton(\"你点我啊\");\n        jButton.setBounds(0, 0, 100, 100);\n        jf.add(jButton);\n\n        jButton.addActionListener(new ActionListener() {\n            @Override\n            public void actionPerformed(ActionEvent e) {\n                System.out.println(\"你点我啊\");\n            }\n        });\n\n        jf.setVisible(true);\n    }\n}\n12345678910111213141516171819202122232425262728293031323334\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3}]},{"ID":"20260305082131-2ovvc07","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20260305082131-2ovvc07","updated":"20260305082131"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"## "},{"Type":"NodeText","Data":"八、常用API(2)"}]},{"ID":"20260305082131-wvrckd4","Type":"NodeParagraph","Properties":{"id":"20260305082131-wvrckd4","updated":"20260305082131"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"本节目标："}]},{"ID":"20260305082131-x0fqe8k","Type":"NodeList","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20260305082131-x0fqe8k","updated":"20260305082131"},"Children":[{"ID":"20260305082131-6wgzgwr","Type":"NodeListItem","Data":"-","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20260305082131-6wgzgwr","updated":"20260305082131"},"Children":[{"ID":"20260305082131-9ck31zj","Type":"NodeParagraph","Properties":{"id":"20260305082131-9ck31zj","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"能够使用String类的功能完成用户登录案例"}]}]},{"ID":"20260305082131-5ez5xvr","Type":"NodeListItem","Data":"-","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20260305082131-5ez5xvr","updated":"20260305082131"},"Children":[{"ID":"20260305082131-fvaz1h8","Type":"NodeParagraph","Properties":{"id":"20260305082131-fvaz1h8","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"能够使用String类的功能完成聊天室案例"}]}]},{"ID":"20260305082131-pq5m8ov","Type":"NodeListItem","Data":"-","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20260305082131