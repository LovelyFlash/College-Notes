"updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"格式：数据类型 变量名 = (目标数据类型)(数值或者变量)"}]},{"ID":"20260305082131-cze7ert","Type":"NodeParagraph","Properties":{"id":"20260305082131-cze7ert","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"IDEA中代码演示如下："}]},{"ID":"20260305082131-swr3mmt","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"amF2YQ==","CodeBlockCloseFence":"YGBg","Properties":{"id":"20260305082131-swr3mmt","updated":"20260305082131"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"amF2YQ=="},{"Type":"NodeCodeBlockCode","Data":"/*\n    数字相加\n */\npublic class OperatorDemo01 {\n    public static void main(String[] args) {\n        int a = 10;\n        double b = 13.14;\n        System.out.println(a + b);\n\n        int c = (int)(a + b);\n        System.out.println(c);\n//        double d = a + b;\n\n        short s = 10;\n        int i = 20;\n        int j = s + i;\n//        short ss = s + i;\n\n        short ss = (short) (s + i);\n    }\n}\n123456789101112131415161718192021\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3}]},{"ID":"20260305082131-9whkedr","Type":"NodeHeading","HeadingLevel":5,"Properties":{"id":"20260305082131-9whkedr","updated":"20260305082131"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"##### "},{"Type":"NodeText","Data":"4.3.2 字符相加"}]},{"ID":"20260305082131-0pdhlmi","Type":"NodeParagraph","Properties":{"id":"20260305082131-0pdhlmi","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"这里我们再来说一下字符参与+操作。"}]},{"ID":"20260305082131-8tgnpj3","Type":"NodeParagraph","Properties":{"id":"20260305082131-8tgnpj3","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"先到IDEA中去讲解，然后再回来总结。"}]},{"ID":"20260305082131-f7of5kx","Type":"NodeParagraph","Properties":{"id":"20260305082131-f7of5kx","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"IDEA中代码演示如下："}]},{"ID":"20260305082131-cz2nj51","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"amF2YQ==","CodeBlockCloseFence":"YGBg","Properties":{"id":"20260305082131-cz2nj51","updated":"20260305082131"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"amF2YQ=="},{"Type":"NodeCodeBlockCode","Data":"/*\n    字符相加\n */\npublic class OperatorDemo02 {\n    public static void main(String[] args) {\n        //定义两个变量\n        int i = 10;\n        char ch = 'A';//'A'的值是65\n        ch = 'a';//'a'的值是97\n        ch = '0';//'0'的值是48\n        System.out.println(i + ch);\n    }\n}\n12345678910111213\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3}]},{"ID":"20260305082131-k19ujsq","Type":"NodeParagraph","Properties":{"id":"20260305082131-k19ujsq","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"代码演示完毕后，回到资料总结："}]},{"ID":"20260305082131-adhxrvi","Type":"NodeParagraph","Properties":{"id":"20260305082131-adhxrvi","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"字符参与+操作，其实就是拿字符在计算机底层对应的数值来进行计算的，这里我们了解一下英文大小写字符和数字字符对应的数据值："}]},{"ID":"20260305082131-pf3erhw","Type":"NodeList","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20260305082131-pf3erhw","updated":"20260305082131"},"Children":[{"ID":"20260305082131-bz6j08h","Type":"NodeListItem","Data":"-","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20260305082131-bz6j08h","updated":"20260305082131"},"Children":[{"ID":"20260305082131-ir2iqcv","Type":"NodeParagraph","Properties":{"id":"20260305082131-ir2iqcv","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"‘A’ 65 A-Z是连续的"}]}]},{"ID":"20260305082131