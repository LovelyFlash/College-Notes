"20260305082131-afrccw0","Type":"NodeParagraph","Properties":{"id":"20260305082131-afrccw0","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"了解了Java中的算术运算符之后，下面我们到IDEA中去使用一下："}]},{"ID":"20260305082131-6o39rmw","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"amF2YQ==","CodeBlockCloseFence":"YGBg","Properties":{"id":"20260305082131-6o39rmw","updated":"20260305082131"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"amF2YQ=="},{"Type":"NodeCodeBlockCode","Data":"/*\n    算术运算符\n */\npublic class OperatorDemo {\n    public static void main(String[] args) {\n        //定义两个int类型的变量\n        int a = 6;\n        int b = 4;\n\n        System.out.println(a + b);//10\n        System.out.println(a - b);//2\n        System.out.println(a * b);//24\n        System.out.println(a / b);//1.5? 1\n        System.out.println(a % b);//2\n\n        //整数相除只能得到整数，要想得到小数，必须有浮点数的参与\n        System.out.println(6.0 / 4);\n    }\n}\n\n1234567891011121314151617181920\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3}]},{"ID":"20260305082131-lg5nbew","Type":"NodeParagraph","Properties":{"id":"20260305082131-lg5nbew","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"最后，我们来总结一下，刚才在演示代码的时候有两个注意事项："}]},{"ID":"20260305082131-0mute36","Type":"NodeParagraph","Properties":{"id":"20260305082131-0mute36","updated":"20260305082131"},"Children":[{"Type":"NodeImage","Children":[{"Type":"NodeBang","Data":"!"},{"Type":"NodeOpenBracket","Data":"["},{"Type":"NodeLinkText","Data":"外链图片转存失败,源站可能有防盗链机制,建议将图片保存下来直接上传"},{"Type":"NodeCloseBracket","Data":"]"},{"Type":"NodeOpenParen","Data":"("},{"Type":"NodeLinkDest","Data":"https://i-blog.csdnimg.cn/direct/e2ddec984cba4c9d8d65c97757b2e85c.png"},{"Type":"NodeCloseParen","Data":")"}]}]},{"ID":"20260305082131-hw6jpwy","Type":"NodeHeading","HeadingLevel":4,"Properties":{"id":"20260305082131-hw6jpwy","updated":"20260305082131"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"#### "},{"Type":"NodeText","Data":"4.2 案例数值拆分"}]},{"ID":"20260305082131-nwaecm2","Type":"NodeParagraph","Properties":{"id":"20260305082131-nwaecm2","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"需求：定义一个三位数，将其拆分为个位、十位、百位后，输出在控制台"}]},{"ID":"20260305082131-7ut1w5y","Type":"NodeParagraph","Properties":{"id":"20260305082131-7ut1w5y","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"什么意思呢？下面我们举例来说明一下："}]},{"ID":"20260305082131-qbu63ku","Type":"NodeParagraph","Properties":{"id":"20260305082131-qbu63ku","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"举例：int number = 123；"}]},{"ID":"20260305082131-f8q3o8f","Type":"NodeParagraph","Properties":{"id":"20260305082131-f8q3o8f","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"在控制台输出结果："}]},{"ID":"20260305082131-209sz1j","Type":"NodeParagraph","Properties":{"id":"20260305082131-209sz1j","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"个位是：3"}]},{"ID":"20260305082131-fb14noi","Type":"NodeParagraph","Properties":{"id":"20260305082131-fb14noi","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"十位是：2"}]},{"ID":"20260305082131-gx402og","Type":"NodeParagraph","Properties":{"id":"20260305082131-gx402og","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"百位是：1"}]},{"ID":"20260305082131-w2fhajl","Type":"NodeParagraph","Properties":{"id":"20260305082131-w2fhajl","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"知道了要做什么后，下面我们来分析一下如何获取个位，十位，百位："}]},{"ID":"20260305082131-goul0jz","Type":"NodeParagraph","Properties":{"id":"20260305082131-goul0jz","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"分析："}]},{"ID":"20260305082131-yorp6vz","Type":"NodeParagraph","Properties":{"id":"20260305082131-yorp6vz","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"① 个位的计算：数值 % 10"}]},{"ID":"20260305082131-0ubxfbn","Type":"NodeParagraph","Properties":{"id":"20260305082131-0ubxfbn","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"123 除以 10（商12，余数为3）"}]},{"ID":"20260305082131-i3isix4","Type":"NodeParagraph","Properties":{"id":"20260305082131-i3isix4","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"② 十位的计算：数值 / 10 % 10"}]},{"ID":"20260305082131-10b22jv","Type":"NodeParagraph","Properties":{"id":"20260305082131-10b22jv","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"123 除以 10 （商12，余数为3，整数相除只能得到整数）"}]},{"ID":"20260305082131-kjayhgk","Type":"NodeParagraph","Properties":{"id":"20260305082131-kjayhgk","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"12 除以 10 （商1，余数为2）"}]},{"ID":"20260305082131-pf4qupb","Type":"NodeParagraph","Properties":{"id":"20260305082131-pf4qupb","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"③ 百位的计算：数值 / 10 / 10 % 10"}]},{"ID":"20260305082131-01cmb2o","Type":"NodeParagraph","Properties":{"id":"20260305082131-01cmb2o","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"123 / 10 / 10 % 10（123 / 10 得到12，12 / 10 得到1，1 % 10 得到 1）"}]},{"ID":"20260305082131-9ayt1c1","Type":"NodeParagraph","Properties":{"id":"20260305082131-9ayt1c1","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"分析完毕之后，下面我们到IDEA中去实现一下："}]},{"ID":"20260305082131-88r5dyi","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"amF2YQ==","CodeBlockCloseFence":"YGBg","Properties":{"id":"20260305082131-88r5dyi","updated":"20260305082131"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"amF2YQ=="},{"Type":"NodeCodeBlockCode","Data":"/*\n    需求：定义一个三位数，将其拆分为个位、十位、百位后，输出在控制台\n */\npublic class OperatorTest {\n    public static void main(String[] args) {\n        //定义一个三位数\n        int number = 123;\n\n        //获取个，十，百位数据\n        int ge = number % 10;\n        int shi = number / 10 % 10;\n        int bai = number / 100 % 10;\n\n        //输出结果\n        System.out.println(\"个位是：\" + ge);\n        System.out.println(\"十位是：\" + shi);\n        System.out.println(\"百位是：\" + bai);\n    }\n}\n12345678910111213141516171819\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3}]},{"ID":"20260305082131-7eoo1uv","Type":"NodeHeading","HeadingLevel":4,"Properties":{"id":"20260305082131-7eoo1uv","updated":"20260305082131"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"#### "},{"Type":"NodeText","Data":"4.3 +操作的三种情况"}]},{"ID":"20260305082131-c5hanx1","Type":"NodeHeading","HeadingLevel":5,"Properties":{"id":"20260305082131-c5hanx1","updated":"20260305082131"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"##### "},{"Type":"NodeText","Data":"4.3.1 数字相加(类型转换)"}]},{"ID":"20260305082131-4pup9bo","Type":"NodeParagraph","Properties":{"id":"20260305082131-4pup9bo","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"在Java程序中，数据参与运算，要求类型一致。这里就涉及到了数据的类型转换。而类型转换又分为两种："}]},{"ID":"20260305082131-jfkdo43","Type":"NodeList","ListData":{"Typ":1,"Tight":true,"Start":1,"Delimiter":46,"Padding":3,"Marker":"MS4=","Num":1},"Properties":{"id":"20260305082131-jfkdo43","updated":"20260305082131"},"Children":[{"ID":"20260305082131-g2cidbn","Type":"NodeListItem","Data":"1.","ListData":{"Typ":1,"Tight":true,"Start":1,"Delimiter":46,"Padding":3,"Marker":"MS4=","Num":1},"Properties":{"id":"20260305082131-g2cidbn","updated":"20260305082131"},"Children":[{"ID":"20260305082131-ny5bn17","Type":"NodeParagraph","Properties":{"id":"20260305082131-ny5bn17","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"隐式转换"}]}]},{"ID":"20260305082131-bjzy74f","Type":"NodeListItem","Data":"2.","ListData":{"Typ":1,"Tight":true,"Start":2,"Delimiter":46,"Padding":3,"Marker":"Mi4=","Num":2},"Properti