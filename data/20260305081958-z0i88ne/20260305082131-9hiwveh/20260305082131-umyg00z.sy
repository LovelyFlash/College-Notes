-inbr27c","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"int nextInt()：获取一个int类型的数据"}]}]},{"ID":"20260305082131-s8i6j6y","Type":"NodeListItem","Data":"-","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20260305082131-s8i6j6y","updated":"20260305082131"},"Children":[{"ID":"20260305082131-rn23vpy","Type":"NodeParagraph","Properties":{"id":"20260305082131-rn23vpy","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"int i = sc.nextInt();"}]}]}]},{"ID":"20260305082131-m7grt2i","Type":"NodeParagraph","Properties":{"id":"20260305082131-m7grt2i","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"知道了Scanner的构造方法和成员方法后，我们到IDEA中去使用一下："}]},{"ID":"20260305082131-64r4qdz","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"amF2YQ==","CodeBlockCloseFence":"YGBg","Properties":{"id":"20260305082131-64r4qdz","updated":"20260305082131"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"amF2YQ=="},{"Type":"NodeCodeBlockCode","Data":"import java.util.Scanner;\n\n/*\n    Scanner的基本使用\n */\npublic class ScannerDemo {\n    public static void main(String[] args) {\n        //Scanner(InputStream source)：创建 Scanner 对象\n        Scanner sc = new Scanner(System.in);\n\n        //int nextInt()：获取一个int类型的数据\n        System.out.println(\"请输入一个整数：\");\n        int i = sc.nextInt();\n\n        //输出获取到的数据\n        System.out.println(\"你输入的数据是：\" + i);\n    }\n}\n123456789101112131415161718\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3}]},{"ID":"20260305082131-00vhpgk","Type":"NodeHeading","HeadingLevel":4,"Properties":{"id":"20260305082131-00vhpgk","updated":"20260305082131"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"#### "},{"Type":"NodeText","Data":"16.2 练习(数据求和)"}]},{"ID":"20260305082131-npwrd9v","Type":"NodeParagraph","Properties":{"id":"20260305082131-npwrd9v","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"需求：键盘录入两个整数，求两个数据和，并在控制台输出求和结果"}]},{"ID":"20260305082131-bariyti","Type":"NodeParagraph","Properties":{"id":"20260305082131-bariyti","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"首先，我们来简单的分析一下："}]},{"ID":"20260305082131-exow9il","Type":"NodeParagraph","Properties":{"id":"20260305082131-exow9il","updated":"20260305082131"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"分析："}]},{"ID":"20260305082131-lhdp93r","Type":"NodeParagraph","Properties":{"id":"20260305082131-lhdp93r","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"① 创建键盘录入数据对象"}]},{"ID":"20260305082131-8yp2ns0","Type":"NodeParagraph","Properties":{"id":"20260305082131-8yp2ns0","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"② 通过键盘录入数据对象调用nextInt()方法获取数据"}]},{"ID":"20260305082131-pifcwbr","Type":"NodeParagraph","Properties":{"id":"20260305082131-pifcwbr","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"③ 对获取的两个整数求和"}]},{"ID":"20260305082131-kgk52kr","Type":"NodeParagraph","Properties":{"id":"20260305082131-kgk52kr","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"④ 在控制台输出求和结果"}]},{"ID":"20260305082131-zg9wbrq","Type":"NodeParagraph","Properties":{"id":"20260305082131-zg9wbrq","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"分析完毕后，我们到IDEA中去实现一下："}]},{"ID":"20260305082131-g18uu0o","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"amF2YQ==","CodeBlockCloseFence":"YGBg","Properties":{"id":"20260305082131-g18uu0o","updated":"20260305082131"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"amF2YQ=="},{"Type":"NodeCodeBlockCode","Data":"/*\n    需求：键盘录入两个整数，求两个数据和，并在控制台输出求和结果\n    分析：\n        1:创建键盘录入数据对象\n        2:通过键盘录入数据对象调用nextInt()方法获取数据\n        3:对获取的两个整数求和\n        4:在控制台输出求和结果\n */\npublic class ScannerTest {\n    public static void main(String[] args) {\n        //创建键盘录入数据对象\n        Scanner sc = new Scanner(System.in);\n\n        //通过键盘录入数据对象调用nextInt()方法获取数据\n        System.out.println(\"请输入第一个整数：\");\n        int firstNumber = sc.nextInt();\n\n        System.out.println(\"请输入第二个整数：\");\n        int secondNumber = sc.nextInt();\n\n        //对获取的两个整数求和\n        int sum = firstNumber + secondNumber;\n\n        //在控制台输出求和结果\n        System.out.println(\"求和结果是：\" + sum);\n    }\n}\n123456789101112131415161718192021222324252627\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3}]},{"ID":"20260305082131-smbn0hh","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20260305082131-smbn0hh","updated":"20260305082131"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"### "},{"Type":"NodeText","Data":"17：Random"}]},{"ID":"20260305082131-ltdmb8t","Type":"NodeHeading","HeadingLevel":4,"Properties":{"id":"20260305082131-ltdmb8t","updated":"20260305082131"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"#### "},{"Type":"NodeText","Data":"17.1 Random基本使用"}]},{"ID":"20260305082131-el3fd2b","Type":"NodeParagraph","Properties":{"id":"20260305082131-el3fd2b","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"下面我们来学习一下Random的使用。"}]},{"ID":"20260305082131-4dmd3f8","Type":"NodeParagraph","Properties":{"id":"20260305082131-4dmd3f8","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"通过查看帮助文档，我们知道了如下的信息："}]},{"ID":"20260305082131-h8aadjx","Type":"NodeParagraph","Properties":{"id":"20260305082131-h8aadjx","updated":"20260305082131"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"Random："}]},{"ID":"20260305082131-8dr2z77","Type":"NodeList","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20260305082131-8dr2z77","updated":"20260305082131"},"Children":[{"ID":"20260305082131-pl9743l","Type":"NodeListItem","Data":"-","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20260305082131-pl9743l","updated":"20260305082131"},"Children":[{"ID":"20260305082131-1ao5utv","Type":"NodeParagraph","Properties":{"id":"20260305082131-1ao5utv","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"该类的实例用于生成随机数"}]}]}]},{"ID":"20260305082131-1stfph9","Type":"NodeParagraph","Properties":{"id":"20260305082131-1stfph9","updated":"20260305082131"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"构造方法："}]},{"ID":"20260305082131-bf19t93","Type":"NodeList","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20260305082131-bf19t93","updated":"20260305082131"},"Children":[{"ID":"20260305082131-phrhsmq","Type":"NodeListItem","Data":"-","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20260305082131-phrhsmq","updated":"20260305082131"},"Children":[{"ID":"20260305082131-uvhlizk","Type":"NodeParagraph","Properties":{"id":"20260305082131-uvhlizk","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"Random()：创建一个新的随机数生成器"}]}]}]},{"ID":"20260305082131-nqxckyw","Type":"NodeParagraph","Properties":{"id":"20260305082131-nqxckyw","updated":"20260305082131"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"成员方法："}]},{"ID":"20260305082131-j0ebzol","Type":"NodeList","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20260305082131-j0ebzol","updated":"20260305082131"},"Children":[{"ID":"20260305082131-t6w7ldj","Type":"NodeListItem","Data":"-","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20260305082131-t6w7ldj","updated":"20260305082131"},"Children":[{"ID":"20260305082131-jgzjyb7","Type":"NodeParagraph","Properties":{"id":"20260305082131-jgzjyb7","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"int nextInt(int bound)：获取一个int类型的随机数，参数bound表示获取到的随机数在"},{"Type":"NodeBackslash","Children":[{"Type":"NodeBackslashContent","Data":"["}]},{"Type":"NodeText","Data":"0,bound)之间"}]}]}]},{"ID":"20260305082131-qb310ex","Type":"NodeParagraph","Properties":{"id":"20260305082131-qb310ex","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"知道了Random的构造方法和成员方法后，我们到IDEA中去使用一下："}]},{"ID":"20260305082131-kpzpdpi","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"amF2YQ==","CodeBlockCloseFence":"YGBg","Properties":{"id":"20260305082131-kpzpdpi","updated":"20260305082131"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"amF2YQ=="},{"Type":"NodeCodeBlockCode","Data":"import java.util.Random;\n\n/*\n    Random的基本使用\n */\npublic class RandomDemo {\n    public static void main(String[] args) {\n        //Random()：创建一个新的随机数生成器\n        Random r = new Random();\n\n        //int nextInt(int bound)：获取一个int类型的随机数，参数bound表示获取到的随机数在[0,bound)之间\n//        int i = r.nextInt(10);\n//        System.out.println(i);\n\n//        for (int i=1; i\u003c=10; i++) {\n//            int j = r.nextInt(10);\n//            System.out.println(j);\n//        }\n\n        //需求：如何获取1-100之间的随机数呢？\n//        int number = r.nextInt(100);//0-99\n//        int number = r.nextInt(101);//0-100\n        int number = r.nextInt(100) + 1;\n        System.out.println(number);\n    }\n}\n1234567891011121314151617181920212223242526\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3}]},{"ID":"20260305082131-qwacsfa","Type":"NodeHeading","HeadingLevel":4,"Properties":{"id":"20260305082131-qwacsfa","updated":"20260305082131"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"#### "},{"Type":"NodeText","Data":"17.2 练习(猜数字游戏)"}]},{"ID":"20260305082131-gt2s5d7","Type":"NodeParagraph","Properties":{"id":"20260305082131-gt2s5d7","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"需求：系统自动产生一个1-100之间的整数，使用程序实现猜这个数字是多少？"}]},{"ID":"20260305082131-ooiiqqe","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"amF2YQ==","CodeBlockCloseFence":"YGBg","Properties":{"id":"20260305082131-ooiiqqe","updated":"20260305082131"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"amF2YQ=="},{"Type":"NodeCodeBlockCode","Data":"猜的时候根据不同情况给出相应的提示\n\n如果猜的数字比真实数字大，提示你猜的数据大了\n\n如果猜的数字比真实数字小，提示你猜的数据小了\n\n如果猜的数字与真实数字相等，提示恭喜你猜中了\n1234567\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3}]},{"ID":"20260305082131-1hgmh2q","Type":"NodeParagraph","Properties":{"id":"20260305082131-1hgmh2q","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"首先，我们来简单的分析一下："}]},{"ID":"20260305082131-fnocpei","Type":"NodeParagraph","Properties":{"id":"20260305082131-fnocpei","updated":"20260305082131"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"分析："}]},{"ID":"20260305082131-ge04zrv","Type":"NodeParagraph","Properties":{"id":"20260305082131-ge04zrv","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"① 使用Random获取一个1-100之间的整数"}]},{"ID":"20260305082131-5ab4k3y","Type":"NodeParagraph","Properties":{"id":"20260305082131-5ab4k3y","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"② 使用Scanner实现键盘录入猜的数据值"}]},{"ID":"20260305082131-m3mh9j3","Type":"NodeParagraph","Properties":{"id":"20260305082131-m3mh9j3","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"③ 使用if…else if…else 的格式实现猜数字，并给出对应的提示"}]},{"ID":"20260305082131-8lz6gsj","Type":"NodeParagraph","Properties":{"id":"20260305082131-8lz6gsj","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"分析完毕后，我们到IDEA中去实现一下："}]},{"ID":"20260305082131-438drgq","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"amF2YQ==","CodeBlockCloseFence":"YGBg","Properties":{"id":"20260305082131-438drgq","updated":"20260305082131"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"amF2YQ=="},{"Type":"NodeCodeBlockCode","Data":"import java.util.Random;\nimport java.util.Scanner;\n\n/*\n    需求：系统自动产生一个1-100之间的整数，使用程序实现猜这个数字是多少？\n        猜的时候根据不同情况给出相应的提示\n        如果猜的数字比真实数字大，提示你猜的数据大了\n        如果猜的数字比真实数字小，提示你猜的数据小了\n        如果猜的数字与真实数字相等，提示恭喜你猜中了\n    分析：\n        1:使用Random获取一个1-100之间的整数\n        2:使用Scanner实现键盘录入猜的数据值\n        3:使用if…else if…else 的格式实现猜数字，并给出对应的提示\n */\npublic class RandomTest {\n    public static void main(String[] args) {\n        //使用Random获取一个1-100之间的整数\n        Random r = new Random();\n        int number = r.nextInt(100) + 1;\n        System.out.println(\"系统已经产生了一个1-100之间的整数\");\n\n        while (true) {\n            //使用Scanner实现键盘录入猜的数据值\n            Scanner sc = new Scanner(System.in);\n            System.out.println(\"请输入你要猜的数字：\");\n            int guessNumber = sc.nextInt();\n\n            //使用if…else if…else 的格式实现猜数字，并给出对应的提示\n            if (guessNumber \u003e number) {\n                System.out.println(\"你猜的数据\" + guessNumber + \"大了\");\n            } else if (guessNumber \u003c number) {\n                System.out.println(\"你猜的数据\" + guessNumber + \"小了\");\n            } else {\n                System.out.println(\"恭喜你猜中了\");\n                break;\n            }\n        }\n    }\n}\n123456789101112131415161718192021222324252627282930313233343536373839\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3}]},{"ID":"20260305082131-hom9du4","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20260305082131-hom9du4","updated":"20260305082131"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"### "},{"Type":"NodeText","Data":"18：GUI"}]},{"ID":"20260305082131-8e6v98m","Type":"NodeHeading","HeadingLevel":4,"Properties":{"id":"20260305082131-8e6v98m","updated":"20260305082131"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"#### "},{"Type":"NodeText","Data":"18.1 GUI概述"}]},{"ID":"20260305082131-dqs9vic","Type":"NodeParagraph","Properties":{"id":"20260305082131-dqs9vic","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"下面呢我们来学习GUI相关的API。"}]},{"ID":"20260305082131-5axvkq6","Type":"NodeParagraph","Properties":{"id":"20260305082131-5axvkq6","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"首先呢，我们来说一下，什么是GUI："}]},{"ID":"20260305082131-1cd44hm","Type":"NodeList","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20260305082131-1cd44hm","updated":"20260305082131"},"Children":[{"ID":"20260305082131-w7p95ap","Type":"NodeListItem","Data":"-","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20260305082131-w7p95ap","updated":"20260305082131"},"Children":[{"ID":"20260305082131-l5hew5l","Type":"NodeParagraph","Properties":{"id":"20260305082131-l5hew5l","updated":"20260305082131"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"GUI："},{"Type":"NodeText","Data":" Graphical User Interface(图形用户接口)"}]}]},{"ID":"20260305082131-ad5nw1n","Type":"NodeListItem","Data":"-","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20260305082131-ad5nw1n","updated":"20260305082131"},"Children":[{"ID":"20260305082131-4rmlt1z","Type":"NodeParagraph","Properties":{"id":"20260305082131-4rmlt1z","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"用图形的方式，来显示计算机操作的界面"}]}]}]},{"ID":"20260305082131-zz34qy1","Type":"NodeParagraph","Properties":{"id":"20260305082131-zz34qy1","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"怎么理解呢？我们把后面要做的案例拿来举例说明一下："}]},{"ID":"20260305082131-h9xshk2","Type":"NodeParagraph","Properties":{"id":"20260305082131-h9xshk2","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"看这里："}]},{"ID":"20260305082131-yfkqmh5","Type":"NodeParagraph","Properties":{"id":"20260305082131-yfkqmh5","updated":"20260305082131"},"Children":[{"Type":"NodeImage","Children":[{"Type":"NodeBang","Data":"!"},{"Type":"NodeOpenBracket","Data":"["},{"Type":"NodeLinkText","Data":"外链图片转存失败,源站可能有防盗链机制,建议将图片保存下来直接上传"},{"Type":"NodeCloseBracket","Data":"]"},{"Type":"NodeOpenParen","Data":"("},{"Type":"NodeLinkDest","Data":"https://i-blog.csdnimg.cn/direct/a67b7e113310485cb531e5faa2c9c8c1.png"},{"Type":"NodeCloseParen","Data":")"}]}]},{"ID":"20260305082131-383fcg5","Type":"NodeParagraph","Properties":{"id":"20260305082131-383fcg5","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"这是用户登录的案例，在这个界面上，有显示文本的标签，显示输入内容的文本框以及按钮。"}]},{"ID":"20260305082131-cmlz262","Type":"NodeParagraph","Properties":{"id":"20260305082131-cmlz262","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"再来看一个："}]},{"ID":"20260305082131-nwdcezj","Type":"NodeParagraph","Properties":{"id":"20260305082131-nwdcezj","updated":"20260305082131"},"Children":[{"Type":"NodeImage","Children":[{"Type":"NodeBang","Data":"!"},{"Type":"NodeOpenBracket","Data":"["},{"Type":"NodeLinkText","Data":"外链图片转存失败,源站可能有防盗链机制,建议将图片保存下来直接上传"},{"Type":"NodeCloseBracket","Data":"]"},{"Type":"NodeOpenParen","Data":"("},{"Type":"NodeLinkDest","Data":"https://i-blog.csdnimg.cn/direct/010f84b4f3d440ee936dfd07d4dc2d9e.png"},{"Type":"NodeCloseParen","Data":")"}]}]},{"ID":"20260305082131-sq626v0","Type":"NodeParagraph","Properties":{"id":"20260305082131-sq626v0","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"聊天室的案例，在这个界面上，有显示聊天内容的文本域，显示输入内容的文本框以及操作的按钮。"}]},{"ID":"20260305082131-l7jzixj","Type":"NodeParagraph","Properties":{"id":"20260305082131-l7jzixj","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"给出这样的界面，我们自己就能够看明白，非常的方便直观，这就是使用GUI相关的API来实现的。"}]},{"ID":"20260305082131-e9du3pt","Type":"NodeParagraph","Properties":{"id":"20260305082131-e9du3pt","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"而Java为GUI提供的API都存在java.awt和javax.Swing两个包中，我们分别来看一下这两个包："}]},{"ID":"20260305082131-k4p3alp","Type":"NodeList","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20260305082131-k4p3alp","updated":"20260305082131"},"Children":[{"ID":"20260305082131-ffs95i6","Type":"NodeListItem","Data":"-","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20260305082131-ffs95i6","updated":"20260305082131"},"Children":[{"ID":"20260305082131-nw2lvzw","Type":"NodeParagraph","Properties":{"id":"20260305082131-nw2lvzw","updated":"20260305082131"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"java.awt 包："}]},{"ID":"20260305082131-xsow1ro","Type":"NodeList","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"MarkerOffset":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20260305082131-xsow1ro","updated":"20260305082131"},"Children":[{"ID":"20260305082131-b2e9jtn","Type":"NodeListItem","Data":"-","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"MarkerOffset":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20260305082131-b2e9jtn","updated":"20260305082131"},"Children":[{"ID":"20260305082131-fkmrwfi","Type":"NodeParagraph","Properties":{"id":"20260305082131-fkmrwfi","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"awt是这三个单词首字母的缩写，翻译过来是抽象窗口工具包，只不过这个包的API，需要调用本地系统方法实现功能，和本地系统有关联，不利于代码移植，属重量级控件"}]}]}]}]},{"ID":"20260305082131-5h8n3n5","Type":"NodeListItem","Data":"-","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20260305082131-5h8n3n5","updated":"20260305082131"},"Children":[{"ID":"20260305082131-pag3qc6","Type":"NodeParagraph","Properties":{"id":"20260305082131-pag3qc6","updated":"20260305082131"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"javax.swing 包："}]},{"ID":"20260305082131-jeu1tgu","Type":"NodeList","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"MarkerOffset":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20260305082131-jeu1tgu","updated":"20260305082131"},"Children":[{"ID":"20260305082131-eoqi1ib","Type":"NodeListItem","Data":"-","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"MarkerOffset":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20260305082131-eoqi1ib","updated":"20260305082131"},"Children":[{"ID":"20260305082131-wgehjre","Type":"NodeParagraph","Properties":{"id":"20260305082131-wgehjre","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"它是在awt的基础上，建立的一套图形界面系统，提供了更多的组件，而且完全由Java实现。增强了移植性，属轻量级控件"}]}]}]}]}]},{"ID":"20260305082131-6lwezv6","Type":"NodeParagraph","Properties":{"id":"20260305082131-6lwezv6","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"所以，我们做图形界面开发使用的是swing包下的类。"}]},{"ID":"20260305082131-9phvp1i","Type":"NodeParagraph","Properties":{"id":"20260305082131-9phvp1i","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"这里出现了一个名词：组件。那什么是组件呢？"}]},{"ID":"20260305082131-wvu0uaf","Type":"NodeList","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20260305082131-wvu0uaf","updated":"20260305082131"},"Children":[{"ID":"20260305082131-a33u5fh","Type":"NodeListItem","Data":"-","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20260305082131-a33u5fh","updated":"20260305082131"},"Children":[{"ID":"20260305082131-a22thra","Type":"NodeParagraph","Properties":{"id":"20260305082131-a22thra","updated":"20260305082131"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"组件"},{"Type":"NodeText","Data":" 是具有图形表示的对象，该图形表示可以显示在屏幕上并且可以与用户交互"}]}]}]},{"ID":"20260305082131-7qmaxbe","Type":"NodeParagraph","Properties":{"id":"20260305082131-7qmaxbe","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"比如说，在用户登录中，文本框和按钮等，都是能够表示图形的对象，所以它们都称为组件。"}]},{"ID":"20260305082131-t5nzdly","Type":"NodeParagraph","Properties":{"id":"20260305082131-t5nzdly","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"最后，我们来说一下，我们会用到的常用组件，"}]},{"ID":"20260305082131-bcthom8","Type":"NodeParagraph","Properties":{"id":"20260305082131-bcthom8","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"看这里："}]},{"ID":"20260305082131-0hmlz3f","Type":"NodeParagraph","Properties":{"id":"20260305082131-0hmlz3f","updated":"20260305082131"},"Children":[{"Type":"NodeImage","Children":[{"Type":"NodeBang","Data":"!"},{"Type":"NodeOpenBracket","Data":"["},{"Type":"NodeLinkText","Data":"外链图片转存失败,源站可能有防盗链机制,建议将图片保存下来直接上传"},{"Type":"NodeCloseBracket","Data":"]"},{"Type":"NodeOpenParen","Data":"("},{"Type":"NodeLinkDest","Data":"https://i-blog.csdnimg.cn/direct/674182f45d4040ddbf5c8844a908d330.png"},{"Type":"NodeCloseParen","Data":")"}]}]},{"ID":"20260305082131-4q470tk","Type":"NodeParagraph","Properties":{"id":"20260305082131-4q470tk","updated":"20260305082131"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"组件："}]},{"ID":"20260305082131-exprk4q","Type":"NodeList","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20260305082131-exprk4q","updated":"20260305082131"},"Children":[{"ID":"20260305082131-x6tkp31","Type":"NodeListItem","Data":"-","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20260305082131-x6tkp31","updated":"20260305082131"},"Children":[{"ID":"20260305082131-3pmh7wq","Type":"NodeParagraph","Properties":{"id":"20260305082131-3pmh7wq","updated":"20260305082131"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"基本组件："},{"Type":"NodeText","Data":" 具有图形表示的对象"}]}]},{"ID":"20260305082131-dzkunow","Type":"NodeListItem","Data":"-","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20260305082131-dzkunow","updated":"20260305082131"},"Children":[{"ID":"20260305082131-gzyb5e4","Type":"NodeParagraph","Properties":{"id":"20260305082131-gzyb5e4","updated":"20260305082131"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"容器组件："},{"Type":"NodeText","Data":" 是可以添加组件的组件。也就是在容器中可以通过add方法添加组件，既可以添加基本组件，也可以添加容器组件。"}]}]}]},{"ID":"20260305082131-6giuh6h","Type":"NodeParagraph","Properties":{"id":"20260305082131-6giuh6h","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"我们先来看常用的基本组件："}]},{"ID":"20260305082131-9bvlv7d","Type":"NodeList","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20260305082131-9bvlv7d","updated":"20260305082131"},"Children":[{"ID":"20260305082131-vwyot87","Type":"NodeListItem","Data":"-","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20260305082131-vwyot87","updated":"20260305082131"},"Children":[{"ID":"20260305082131-8o46irj","Type":"NodeParagraph","Properties":{"id":"20260305082131-8o46irj","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"JButton，这是按钮"}]}]},{"ID":"20260305082131-12cv7ff","Type":"NodeListItem","Data":"-","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20260305082131-12cv7ff","updated":"20260305082131"},"Children":[{"ID":"20260305082131-hwyeabq","Type":"NodeParagraph","Properties":{"id":"20260305082131-hwyeabq","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"JLabel，这是用来显示文本内容的，或者展示图片使用"}]}]},{"ID":"20260305082131-mpjol3y","Type":"NodeListItem","Data":"-","ListData":{"Tight":true,"BulletChar":45,"Padding":