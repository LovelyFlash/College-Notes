:"(int i=1)"}]}]},{"ID":"20260305082131-8cfeph0","Type":"NodeListItem","Data":"-","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20260305082131-8cfeph0","updated":"20260305082131"},"Children":[{"ID":"20260305082131-9yy28q0","Type":"NodeParagraph","Properties":{"id":"20260305082131-9yy28q0","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"条件判断语句：这里使用一个结果值为boolean类型的表达式，这个表达式能决定是否执行循环体语句 "},{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"(i\u0026lt;=1000)"}]}]},{"ID":"20260305082131-hlstsom","Type":"NodeListItem","Data":"-","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20260305082131-hlstsom","updated":"20260305082131"},"Children":[{"ID":"20260305082131-ituk44x","Type":"NodeParagraph","Properties":{"id":"20260305082131-ituk44x","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"循环体语句：这里可以是任意语句，这些语句可能被多次执行 "},{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"(展示手机信息)"}]}]},{"ID":"20260305082131-97wvopk","Type":"NodeListItem","Data":"-","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20260305082131-97wvopk","updated":"20260305082131"},"Children":[{"ID":"20260305082131-uczvzlm","Type":"NodeParagraph","Properties":{"id":"20260305082131-uczvzlm","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"条件控制语句：这里通常是使用一条语句来改变变量的值，从而达到控制循环是否继续向下执行的效果 "},{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"(i+=1)"}]}]}]},{"ID":"20260305082131-513uxgv","Type":"NodeParagraph","Properties":{"id":"20260305082131-513uxgv","updated":"20260305082131"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"范例："}]},{"ID":"20260305082131-ch0vqbf","Type":"NodeParagraph","Properties":{"id":"20260305082131-ch0vqbf","updated":"20260305082131"},"Children":[{"Type":"NodeImage","Children":[{"Type":"NodeBang","Data":"!"},{"Type":"NodeOpenBracket","Data":"["},{"Type":"NodeLinkText","Data":"外链图片转存失败,源站可能有防盗链机制,建议将图片保存下来直接上传"},{"Type":"NodeCloseBracket","Data":"]"},{"Type":"NodeOpenParen","Data":"("},{"Type":"NodeLinkDest","Data":"https://i-blog.csdnimg.cn/direct/ca4eb26a58664be2a136e1f4265e4c4d.png"},{"Type":"NodeCloseParen","Data":")"}]}]},{"ID":"20260305082131-tbufuxh","Type":"NodeParagraph","Properties":{"id":"20260305082131-tbufuxh","updated":"20260305082131"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"执行流程："}]},{"ID":"20260305082131-cf1f7l8","Type":"NodeParagraph","Properties":{"id":"20260305082131-cf1f7l8","updated":"20260305082131"},"Children":[{"Type":"NodeImage","Children":[{"Type":"NodeBang","Data":"!"},{"Type":"NodeOpenBracket","Data":"["},{"Type":"NodeLinkText","Data":"外链图片转存失败,源站可能有防盗链机制,建议将图片保存下来直接上传"},{"Type":"NodeCloseBracket","Data":"]"},{"Type":"NodeOpenParen","Data":"("},{"Type":"NodeLinkDest","Data":"https://i-blog.csdnimg.cn/direct/b772ed3b373440158c975031301addfb.png"},{"Type":"NodeCloseParen","Data":")"}]}]},{"ID":"20260305082131-crwjkts","Type":"NodeParagraph","Properties":{"id":"20260305082131-crwjkts","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"知道了for循环的格式和执行流程后，下面我们到IDEA中去演示一下："}]},{"ID":"20260305082131-gi3farj","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"amF2YQ==","CodeBlockCloseFence":"YGBg","Properties":{"id":"20260305082131-gi3farj","updated":"20260305082131"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"amF2YQ=="},{"Type":"NodeCodeBlockCode","Data":"/*\n    for循环结构\n */\npublic class ForDemo {\n    public static void main(String[] args) {\n        for(int i=1; i\u003c=5; i+=1) {\n            System.out.println(\"HelloWorld\");\n        }\n    }\n}\n12345678910\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3}]},{"ID":"20260305082131-t346tqd","Type":"NodeParagraph","Properties":{"id":"20260305082131-t346tqd","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"代码演示后，通过Debug查看了一下程序的执行流程，让我们更清晰for循环的执行流程。"}]},{"ID":"20260305082131-4vh8u7j","Type":"NodeHeading","HeadingLevel":4,"Properties":{"id":"20260305082131-4vh8u7j","updated":"20260305082131"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"#### "},{"Type":"NodeText","Data":"6.2 案例1(输出数据)"}]},{"ID":"20260305082131-dp53r2r","Type":"NodeParagraph","Properties":{"id":"20260305082131-dp53r2r","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"需求：在控制台输出1-5的数据"}]},{"ID":"20260305082131-fi5w8ut","Type":"NodeParagraph","Properties":{"id":"20260305082131-fi5w8ut","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"首先，我们来简单的分析一下："}]},{"ID":"20260305082131-77ivz55","Type":"NodeParagraph","Properties":{"id":"20260305082131-77ivz55","updated":"20260305082131"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"分析："}]},{"ID":"20260305082131-g7vyiwz","Type":"NodeParagraph","Properties":{"id":"20260305082131-g7vyiwz","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"① 反复进行输出的动作，使用循环结构"}]},{"ID":"20260305082131-oyq7rws","Type":"NodeParagraph","Properties":{"id":"20260305082131-oyq7rws","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"② 从1开始到5结束，设置初始化从1开始"}]},{"ID":"20260305082131-woyanl2","Type":"NodeParagraph","Properties":{"id":"20260305082131-woyanl2","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"③ 从1开始到5结束，设置判断条件为没有到5的时候继续执行，执行到超过5程序结束"}]},{"ID":"20260305082131-7dljpmk","Type":"NodeParagraph","Properties":{"id":"20260305082131-7dljpmk","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"④ 从1到5，每次增加1，设置条件控制每次+1"}]},{"ID":"20260305082131-clrvhhu","Type":"NodeParagraph","Properties":{"id":"20260305082131-clrvhhu","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"⑤ 将反复进行的事情写入循环结构内部，打印对应数据"}]},{"ID":"20260305082131-s5if24l","Type":"NodeParagraph","Properties":{"id":"20260305082131-s5if24l","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"分析完毕之后，我们到IDEA中去实现一下："}]},{"ID":"20260305082131-na1geph","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"amF2YQ==","CodeBlockCloseFence":"YGBg","Properties":{"id":"20260305082131-na1geph","updated":"20260305082131"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"amF2YQ=="},{"Type":"NodeCodeBlockCode","Data":"/*\n    需求：在控制台输出1-5的数据\n */\npublic class ForTest01 {\n    public static void main(String[] args) {\n        System.out.println(1);\n        System.out.println(2);\n        System.out.println(3);\n        System.out.println(4);\n        System.out.println(5);\n        System.out.println(\"--------------\");\n\n        for (int i = 1; i \u003c= 5; i += 1) {\n            System.out.println(i);\n        }\n        System.out.println(\"--------------\");\n\n        for (int i = 1; i \u003c= 5; i += 2) {\n            System.out.println(i);\n        }\n        System.out.println(\"--------------\");\n\n        //自增运算符：++\n        //它跟在变量的后面表示变量的值+1\n        for (int i = 1; i \u003c= 5; i++) {\n            System.out.println(i);\n        }\n        System.out.println(\"--------------\");\n\n        for (int i = 1; i \u003c= 5; i++,i++) {\n            System.out.println(i);\n        }\n        System.out.println(\"--------------\");\n\n        //我要获取数据5-1该怎么办呢？\n        for (int i=5; i\u003e=1; i-=1) {\n            System.out.println(i);\n        }\n        System.out.println(\"--------------\");\n\n        for (int i=5; i\u003e=1; i--) {\n            System.out.println(i);\n        }\n\n    }\n}\n12345678910111213141516171819202122232425262728293031323334353637383940414243444546\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3}]},{"ID":"20260305082131-kgdq086","Type":"NodeParagraph","Properties":{"id":"20260305082131-kgdq086","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"在讲解的过程中，我们还提出了自增运算符：++和自减运算符：–，并且演示了如何获取数据5-1。"}]},{"ID":"20260305082131-f6o2wo8","Type":"NodeHeading","HeadingLevel":4,"Properties":{"id":"20260305082131-f6o2wo8","updated":"20260305082131"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"#### "},{"Type":"NodeText","Data":"6.3 案例2(求和思想)"}]},{"ID":"20260305082131-0jcm1tu","Type":"NodeParagraph","Properties":{"id":"20260305082131-0jcm1tu","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"需求：求1-5之间的数据和，并把求和结果在控制台输出"}]},{"ID":"20260305082131-blxks8k","Type":"NodeParagraph","Properties":{"id":"20260305082131-blxks8k","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"首先，我们先到IDEA中去实现一下，然后再回来总结。"}]},{"ID":"20260305082131-r84l0kz","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"amF2YQ==","CodeBlockCloseFence":"YGBg","Properties":{"id":"20260305082131-r84l0kz","updated":"20260305082131"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"amF2YQ=="},{"Type":"NodeCodeBlockCode","Data":"/*\n    需求：求1-5之间的数据和，并把求和结果在控制台输出\n */\npublic class ForTest02 {\n    public static void main(String[] args) {\n        //定义一个求和变量，用于保存求和的结果\n        int sum = 0;\n\n        //我们通过for循环实现获取数据1-5\n        for (int i=1; i\u003c=5; i++) {\n            //i,1,2,3,4,5\n//            sum = sum + i;\n            sum += i;\n            /*\n                第一次求和：sum = sum + i = 0 + 1 = 1\n                第二次求和：sum = sum + i = 1 + 2 = 3\n                第三次求和：sum = sum + i = 3 + 3 = 6\n                第四次求和：sum = sum + i = 6 + 4 = 10\n                第五次求和：sum = sum + i = 10 + 5 = 15\n             */\n        }\n\n        //输出结果\n        System.out.println(\"1-5的求和结果是：\" + sum);\n    }\n}\n1234567891011121314151617181920212223242526\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3}]},{"ID":"20260305082131-owuutlx","Type":"NodeParagraph","Properties":{"id":"20260305082131-owuutlx","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"最后，我们来总结一下求和思想的实现步骤："}]},{"ID":"20260305082131-4boqy8m","Type":"NodeParagraph","Properties":{"id":"20260305082131-4boqy8m","updated":"20260305082131"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"实现步骤："}]},{"ID":"20260305082131-pcdu57q","Type":"NodeParagraph","Properties":{"id":"20260305082131-pcdu57q","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"① 求和的最终结果必须保存起来，需要定义一个变量，用于保存求和的结果，初始值为0"}]},{"ID":"20260305082131-lgx86yf","Type":"NodeParagraph","Properties":{"id":"20260305082131-lgx86yf","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"② 从1开始到5结束的数据，使用循环结构完成"}]},{"ID":"20260305082131-ilihj65","Type":"NodeParagraph","Properties":{"id":"20260305082131-ilihj65","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"③ 将反复进行的事情写入循环结构内部"}]},{"ID":"20260305082131-s5senmt","Type":"NodeParagraph","Properties":{"id":"20260305082131-s5senmt","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"此处反复进行的事情是将数据 i 加到用于保存最终求和的变量 sum 中"}]},{"ID":"20260305082131-84r7n0a","Type":"NodeParagraph","Properties":{"id":"20260305082131-84r7n0a","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"④ 当循环执行完毕时，将最终数据打印出来"}]},{"ID":"20260305082131-pm3hp4v","Type":"NodeHeading","HeadingLevel":4,"Properties":{"id":"20260305082131-pm3hp4v","updated":"20260305082131"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"#### "},{"Type":"NodeText","Data":"6.4 案例3(求偶数和)"}]},{"ID":"20260305082131-vzwow37","Type":"NodeParagraph","Properties":{"id":"20260305082131-vzwow37","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"需求：求1-100之间的偶数和，并把求和结果在控制台输出"}]},{"ID":"20260305082131-dsqrh6k","Type":"NodeParagraph","Properties":{"id":"20260305082131-dsqrh6k","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"首先，我们来简单的分析一下："}]},{"ID":"20260305082131-vxo0wsd","Type":"NodeParagraph","Properties":{"id":"20260305082131-vxo0wsd","updated":"20260305082131"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"分析："}]},{"ID":"20260305082131-9icek65","Type":"NodeParagraph","Properties":{"id":"20260305082131-9icek65","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"① 对1-100的数据求和与1-5的数据求和几乎完全一样，仅仅是结束条件不同"}]},{"ID":"20260305082131-qk70zqj","Type":"NodeParagraph","Properties":{"id":"20260305082131-qk70zqj","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"② 对1-100的偶数求和，需要对求和操作添加限制条件"}]},{"ID":"20260305082131-vs1zar7","Type":"NodeParagraph","Properties":{"id":"20260305082131-vs1zar7","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"③ 限制条件是偶数才参与运算，因此条件应该是判断是否是偶数"}]},{"ID":"20260305082131-sgaqtdo","Type":"NodeParagraph","Properties":{"id":"20260305082131-sgaqtdo","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"④ 当循环执行完毕时，将最终数据打印出来"}]},{"ID":"20260305082131-0s9y2vm","Type":"NodeParagraph","Properties":{"id":"20260305082131-0s9y2vm","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"分析完毕之后，我们到IDEA中去实现一下："}]},{"ID":"20260305082131-vrp8zsv","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"amF2YQ==","CodeBlockCloseFence":"YGBg","Properties":{"id":"20260305082131-vrp8zsv","updated":"20260305082131"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"amF2YQ=="},{"Type":"NodeCodeBlockCode","Data":"/*\n    需求：求1-100之间的偶数和，并把求和结果在控制台输出\n */\npublic class ForTest03 {\n    public static void main(String[] args) {\n        //1:求和的最终结果必须保存起来，需要定义一个变量，用于保存求和的结果，初始值为0\n        int sum = 0;\n\n        //2:对1-100的数据求和与1-5的数据求和几乎完全一样，仅仅是结束条件不同\n        for (int i=1; i\u003c=100; i++) {\n            //3:对1-100的偶数求和，需要对求和操作添加限制条件，判断是否是偶数\n            if(i % 2 == 0) {\n                sum += i;\n            }\n        }\n\n        //4:当循环执行完毕时，将最终数据打印出来\n        System.out.println(\"1-100之间的偶数和是：\" + sum);\n    }\n}\n1234567891011121314151617181920\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3}]},{"ID":"20260305082131-osiww3p","Type":"NodeHeading","HeadingLevel":4,"Properties":{"id":"20260305082131-osiww3p","updated":"20260305082131"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"#### "},{"Type":"NodeText","Data":"6.5 案例4(水仙花数)"}]},{"ID":"20260305082131-t7lz6b1","Type":"NodeParagraph","Properties":{"id":"20260305082131-t7lz6b1","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"需求：在控制台输出所有的“水仙花数”"}]},{"ID":"20260305082131-bxnqwg0","Type":"NodeParagraph","Properties":{"id":"20260305082131-bxnqwg0","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"看到这个需求，我们首先要解决的问题就是，什么样的数据是“水仙花数”？它满足如下两个条件："}]},{"ID":"20260305082131-yl93cmv","Type":"NodeParagraph","Properties":{"id":"20260305082131-yl93cmv","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"① 水仙花数是一个三位数"}]},{"ID":"20260305082131-jv2us9x","Type":"NodeParagraph","Properties":{"id":"20260305082131-jv2us9x","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"比如： "},{"Type":"NodeTextMark","TextMarkType":"a","TextMarkAHref":"https://blog.csdn.net/m0_63815035/article/details/","TextMarkTextContent":"111 222 333 370 371"},{"Type":"NodeText","Data":" 520 999"}]},{"ID":"20260305082131-y08ebci","Type":"NodeParagraph","Properties":{"id":"20260305082131-y08ebci","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"② 水仙花数的个位、十位、百位的数字立方和等于原数"}]},{"ID":"20260305082131-wosarm3","Type":"NodeParagraph","Properties":{"id":"20260305082131-wosarm3","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"比如："}]},{"ID":"20260305082131-k8um3zw","Type":"NodeParagraph","Properties":{"id":"20260305082131-k8um3zw","updated":"20260305082131"},"Children":[{"Type":"NodeImage","Children":[{"Type":"NodeBang","Data":"!"},{"Type":"NodeOpenBracket","Data":"["},{"Type":"NodeLinkText","Data":"外链图片转存失败,源站可能有防盗链机制,建议将图片保存下来直接上传"},{"Type":"NodeCloseBracket","Data":"]"},{"Type":"NodeOpenParen","Data":"("},{"Type":"NodeLinkDest","Data":"https://i-blog.csdnimg.cn/direct/1e2add470ee840559d9a704a1b1baa86.png"},{"Type":"NodeCloseParen","Data":")"}]}]},{"ID":"20260305082131-pl5krmd","Type":"NodeParagraph","Properties":{"id":"20260305082131-pl5krmd","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"知道了什么是水仙花数后，我们再来回顾一下如何获取一个数据的个位，十位，百位："}]},{"ID":"20260305082131-nkmmae2","Type":"NodeParagraph","Properties":{"id":"20260305082131-nkmmae2","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"假设一个三位数为x，则"}]},{"ID":"20260305082131-8yc0xjf","Type":"NodeList","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20260305082131-8yc0xjf","updated":"20260305082131"},"Children":[{"ID":"20260305082131-kbfq0eh","Type":"NodeListItem","Data":"-","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20260305082131-kbfq0eh","updated":"20260305082131"},"Children":[{"ID":"20260305082131-ysz2v82","Type":"NodeParagraph","Properties":{"id":"20260305082131-ysz2v82","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"个位：x%10"}]}]},{"ID":"20260305082131-66mptpo","Type":"NodeListItem","Data":"-","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20260305082131-66mptpo","updated":"20260305082131"},"Children":[{"ID":"20260305082131-9vc2zin","Type":"NodeParagraph","Properties":{"id":"20260305082131-9vc2zin","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"十位：x/10%10"}]}]},{"ID":"20260305082131-rbqc42n","Type":"NodeListItem","Data":"-","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20260305082131-rbqc42n","updated":"20260305082131"},"Children":[{"ID":"20260305082131-z1p4w2l","Type":"NodeParagraph","Properties":{"id":"20260305082131-z1p4w2l","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"百位：x/100%10"}]}]}]},{"ID":"20260305082131-v8932ok","Type":"NodeParagraph","Properties":{"id":"20260305082131-v8932ok","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"了解了水仙花数相关的基础知识后，下面我们来说一下这个案例的实现步骤："}]},{"ID":"20260305082131-3r6a3s9","Type":"NodeParagraph","Properties":{"id":"20260305082131-3r6a3s9","updated":"20260305082131"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"实现步骤："}]},{"ID":"20260305082131-g68sgkg","Type":"NodeParagraph","Properties":{"id":"20260305082131-g68sgkg","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"① 获取三位数，通过循环实现"}]},{"ID":"20260305082131-eb4sfom","Type":"NodeParagraph","Properties":{"id":"20260305082131-eb4sfom","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"② 获取每一个三位数的个位，十位，百位"}]},{"ID":"20260305082131-o6mpheq","Type":"NodeParagraph","Properties":{"id":"20260305082131-o6mpheq","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"③ 判断该三位数是否是水仙花数"}]},{"ID":"20260305082131-itnhovz","Type":"NodeParagraph","Properties":{"id":"20260305082131-itnhovz","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"④ 输出水仙花数"}]},{"ID":"20260305082131-iraljlt","Type":"NodeParagraph","Properties":{"id":"20260305082131-iraljlt","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"知道了实现步骤，下面我们到IDEA中去实现一下："}]},{"ID":"20260305082131-71ag8d8","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"amF2YQ==","CodeBlockCloseFence":"YGBg","Properties":{"id":"20260305082131-71ag8d8","updated":"20260305082131"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"amF2YQ=="},{"Type":"NodeCodeBlockCode","Data":"/*\n    需求：在控制台输出所有的“水仙花数”\n */\npublic class ForTest04 {\n    public static void main(String[] args) {\n        //1:获取三位数，通过循环实现\n//        for (int i=100; i\u003c=999; i++) {\n//\n//        }\n\n        for (int i = 100; i \u003c 1000; i++) {\n            //2:获取每一个三位数的个位，十位，百位\n            int ge = i % 10;\n            int shi = i / 10 % 10;\n            int bai = i / 100 % 10;\n\n            //3:判断该三位数是否是水仙花数\n            if ((ge * ge * ge + shi * shi * shi + bai * bai * bai) == i) {\n                //4:输出水仙花数\n                System.out.println(i);\n            }\n\n        }\n\n    }\n}\n1234567891011121314151617181920212223242526\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3}]},{"ID":"20260305082131-j9jj3lz","Type":"NodeHeading","HeadingLevel":4,"Properties":{"id":"20260305082131-j9jj3lz","updated":"20260305082131"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"#### "},{"Type":"NodeText","Data":"6.6 案例5(统计思想)"}]},{"ID":"20260305082131-08koty6","Type":"NodeParagraph","Properties":{"id":"20260305082131-08koty6","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"需求：统计“水仙花数”一共有多少个，并在控制台输出个数"}]},{"ID":"20260305082131-mmu0wvi","Type":"NodeParagraph","Properties":{"id":"20260305082131-mmu0wvi","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"首先，我们先到IDEA中去实现一下，然后再回来总结。"}]},{"ID":"20260305082131-0wd5hky","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"amF2YQ==","CodeBlockCloseFence":"YGBg","Properties":{"id":"20260305082131-0wd5hky","updated":"20260305082131"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"amF2YQ=="},{"Type":"NodeCodeBlockCode","Data":"/*\n    需求：统计“水仙花数”一共有多少个，并在控制台输出个数\n */\npublic class ForTest05 {\n    public static void main(String[] args) {\n        //定义一个统计变量，用于数据的统计，初始化值为0\n        int count = 0;\n\n        for (int i = 100; i \u003c 1000; i++) {\n            int ge = i % 10;\n            int shi = i / 10 % 10;\n            int bai = i / 100 % 10;\n\n            if ((ge * ge * ge + shi * shi * shi + bai * bai * bai) == i) {\n//                System.out.println(i);\n                //1,2,3,...\n                count++;\n            }\n        }\n\n        //输出水仙花的个数\n        System.out.println(\"水仙花数一共有：\" + count + \"个\");\n    }\n}\n123456789101112131415161718192021222324\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3}]},{"ID":"20260305082131-19valgp","Type":"NodeParagraph","Properties":{"id":"20260305082131-19valgp","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"最后，我们来总结一下统计思想的实现步骤："}]},{"ID":"20260305082131-9wu3oqj","Type":"NodeParagraph","Properties":{"id":"20260305082131-9wu3oqj","updated":"20260305082131"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"实现步骤："}]},{"ID":"20260305082131-ji96iys","Type":"NodeParagraph","Properties":{"id":"20260305082131-ji96iys","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"① 定义统计变量count，初始化值为0"}]},{"ID":"20260305082131-bymygfg","Type":"NodeParagraph","Properties":{"id":"20260305082131-bymygfg","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"② 在判定水仙花数的过程中，满足条件不再输出，更改为修改count的值，使count+1"}]},{"ID":"20260305082131-nbyck7f","Type":"NodeParagraph","Properties":{"id":"20260305082131-nbyck7f","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"③ 输出统计变量的值"}]},{"ID":"20260305082131-35cxoeo","Type":"NodeHeading","HeadingLevel":4,"Properties":{"id":"20260305082131-35cxoeo","updated":"20260305082131"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"#### "},{"Type":"NodeText","Data":"6.7 案例6(回文数)"}]},{"ID":"20260305082131-2urdwe4","Type":"NodeParagraph","Properties":{"id":"20260305082131-2urdwe4","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"需求：输出所有五位数的回文数"}]},{"ID":"20260305082131-8rmugzs","Type":"NodeParagraph","Properties":{"id":"20260305082131-8rmugzs","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"看到这个需求，我们首先要解决的问题就是，什么样的数据是“回文数”？"}]},{"ID":"20260305082131-5f8h4e9","Type":"NodeParagraph","Properties":{"id":"20260305082131-5f8h4e9","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"那什么是“回文数”呢？一个数，无论是从左往右读,还是从右往左读，读起来都相同的数,叫做“回文数”"}]},{"ID":"20260305082131-gjrdxt9","Type":"NodeParagraph","Properties":{"id":"20260305082131-gjrdxt9","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"举例："}]},{"ID":"20260305082131-u0fotry","Type":"NodeParagraph","Properties":{"id":"20260305082131-u0fotry","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"10101，12321：是回文数"}]},{"ID":"20260305082131-g3aptik","Type":"NodeParagraph","Properties":{"id":"20260305082131-g3aptik","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"12345：不是回文数"}]},{"ID":"20260305082131-mc4hd49","Type":"NodeParagraph","Properties":{"id":"20260305082131-mc4hd49","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"规律："}]},{"ID":"20260305082131-huq9ubv","Type":"NodeParagraph","Properties":{"id":"20260305082131-huq9ubv","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"个位 = 万位"}]},{"ID":"20260305082131-0i9hfsv","Type":"NodeParagraph","Properties":{"id":"20260305082131-0i9hfsv","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"十位 = 千位"}]},{"ID":"20260305082131-2ohsgsy","Type":"NodeParagraph","Properties":{"id":"20260305082131-2ohsgsy","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"和百位无关"}]},{"ID":"20260305082131-hux91ok","Type":"NodeParagraph","Properties":{"id":"20260305082131-hux91ok","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"了解了回文数相关的基础知识后，我们来说一下这个案例的实现步骤："}]},{"ID":"20260305082131-p9wl23z","Type":"NodeParagraph","Properties":{"id":"20260305082131-p9wl23z","updated":"20260305082131"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"实现步骤："}]},{"ID":"20260305082131-wyrwnlk","Type":"NodeParagraph","Properties":{"id":"20260305082131-wyrwnlk","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"① 获取五位数，通过循环实现"}]},{"ID":"20260305082131-py87dn5","Type":"NodeParagraph","Properties":{"id":"20260305082131-py87dn5","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"② 获取每一个五位数的个位，十位，千位，万位"}]},{"ID":"20260305082131-82y30ce","Type":"NodeParagraph","Properties":{"id":"20260305082131-82y30ce","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"③ 判断该五位数是否是回文数"}]},{"ID":"20260305082131-uori4fg","Type":"NodeParagraph","Properties":{"id":"20260305082131-uori4fg","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"④ 输出回文数"}]},{"ID":"20260305082131-u00v5xe","Type":"NodeParagraph","Properties":{"id":"20260305082131-u00v5xe","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"知道了实现步骤，下面我们到IDEA中去实现一下："}]},{"ID":"20260305082131-7eoi4c1","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"amF2YQ==","CodeBlockCloseFence":"YGBg","Properties":{"id":"20260305082131-7eoi4c1","updated":"20260305082131"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"amF2YQ=="},{"Type":"NodeCodeBlockCode","Data":"/*\n    需求：输出所有五位数的回文数\n */\npublic class ForTest06 {\n    public static void main(String[] args) {\n        //1:获取五位数，通过循环实现\n        for (int i = 10000; i \u003c 100000; i++) {\n            //2:获取每一个五位数的个位，十位，千位，万位\n            int ge = i % 10;\n            int shi = i / 10 % 10;\n            int qian = i / 1000 % 10;\n            int wan = i / 10000 % 10;\n\n            //3:判断该五位数是否是回文数\n            if ((ge == wan) \u0026\u0026 (shi == qian)) {\n                //4:输出回文数\n                System.out.println(i);\n            }\n        }\n\n        //练习：统计五位数的回文数个数，并在控制台输出个数\n\n    }\n}\n123456789101112131415161718192021222324\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3}]},{"ID":"20260305082131-tqlivxn","Type":"NodeParagraph","Properties":{"id":"20260305082131-tqlivxn","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"在案例的最后，我们留下了一个练习，大家记得完成哦。"}]},{"ID":"20260305082131-mpp2yvb","Type":"NodeHeading","HeadingLevel":4,"Properties":{"id":"20260305082131-mpp2yvb","updated":"20260305082131"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"#### "},{"Type":"NodeText","Data":"6.8 案例7(逢七过)"}]},{"ID":"20260305082131-phsha8u","Type":"NodeParagraph","Properties":{"id":"20260305082131-phsha8u","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"需求：朋友聚会的时候可能会玩一个游戏：逢七过。"}]},{"ID":"20260305082131-2zcu38c","Type":"NodeParagraph","Properties":{"id":"20260305082131-2zcu38c","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"规则是：从任意一个数字开始报数，当你要报的数字包含7或者是7的倍数时都要说：过。"}]},{"ID":"20260305082131-v07pgae","Type":"NodeParagraph","Properties":{"id":"20260305082131-v07pgae","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"为了帮助大家更好的玩这个游戏，这里我们直接在控制台打印出1-100之间的满足逢七必过规则的数据。"}]},{"ID":"20260305082131-m5l500o","Type":"NodeParagraph","Properties":{"id":"20260305082131-m5l500o","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"这样，大家将来在玩游戏的时候，就知道哪些数据要说：过。"}]},{"ID":"20260305082131-cwfr1qt","Type":"NodeParagraph","Properties":{"id":"20260305082131-cwfr1qt","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"首先，我们来简单的分析一下："}]},{"ID":"20260305082131-x9df13e","Type":"NodeParagraph","Properties":{"id":"20260305082131-x9df13e","updated":"20260305082131"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"分析："}]},{"ID":"20260305082131-g54cj7z","Type":"NodeParagraph","Properties":{"id":"20260305082131-g54cj7z","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"① 数据的范围1-100之间，用循环很容易实现"}]},{"ID":"20260305082131-jezdpl6","Type":"NodeParagraph","Properties":{"id":"20260305082131-jezdpl6","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"② 要满足的条件是：数字包含7(个位是7，或者十位是7)，或者是7的倍数"}]},{"ID":"20260305082131-6uiwvqo","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"amF2YQ==","CodeBlockCloseFence":"YGBg","Properties":{"id":"20260305082131-6uiwvqo","updated":"20260305082131"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"amF2YQ=="},{"Type":"NodeCodeBlockCode","Data":"假如有一个数据：x\n\n判断个位为7：x%10 == 7\n\n判断十位为7：x/10%10 == 7\n\n判断是7的倍数：x%7 == 0\n1234567\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3}]},{"ID":"20260305082131-v97ocuh","Type":"NodeParagraph","Properties":{"id":"20260305082131-v97ocuh","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"分析完毕后，我们来说一下实现步骤："}]},{"ID":"20260305082131-110b782","Type":"NodeParagraph","Properties":{"id":"20260305082131-110b782","updated":"20260305082131"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"实现步骤："}]},{"ID":"20260305082131-spetq7f","Type":"NodeParagraph","Properties":{"id":"20260305082131-spetq7f","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"① 获取1-100之间的数据，通过循环实现"}]},{"ID":"20260305082131-lwvc926","Type":"NodeParagraph","Properties":{"id":"20260305082131-lwvc926","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"② 判断数字包含7或者是7的倍数"}]},{"ID":"20260305082131-l2ilbc6","Type":"NodeParagraph","Properties":{"id":"20260305082131-l2ilbc6","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"判断数据：要么个位是7，要么十位是7，要么能够被7整除"}]},{"ID":"20260305082131-fvfeti7","Type":"NodeParagraph","Properties":{"id":"20260305082131-fvfeti7","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"③ 在控制台输出满足条件的数据"}]},{"ID":"20260305082131-t55j9nr","Type":"NodeParagraph","Properties":{"id":"20260305082131-t55j9nr","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"知道了实现步骤，下面我们到IDEA中去实现一下："}]},{"ID":"20260305082131-m36hwbr","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"amF2YQ==","CodeBlockCloseFence":"YGBg","Properties":{"id":"20260305082131-m36hwbr","updated":"20260305082131"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"amF2YQ=="},{"Type":"NodeCodeBlockCode","Data":"/*\n    需求：朋友聚会的时候可能会玩一个游戏：逢七过。\n */\npublic class ForTest07 {\n    public static void main(String[] args) {\n        //1:获取1-100之间的数据，通过循环实现\n        for (int i = 1; i \u003c= 100; i++) {\n            //2:判断数字包含7或者是7的倍数(判断数据：要么个位是7，要么十位是7，要么能够被7整除)\n            if ((i % 10 == 7) || (i / 10 % 10 == 7) || (i % 7 == 0)) {\n                //3:在控制台输出满足条件的数据\n                System.out.println(i);\n            }\n        }\n\n    }\n}\n12345678910111213141516\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3}]},{"ID":"20260305082131-aztwvwl","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20260305082131-aztwvwl","updated":"20260305082131"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"### "},{"Type":"NodeText","Data":"7：while循环结构"}]},{"ID":"20260305082131-6g7mppx","Type":"NodeHeading","HeadingLevel":4,"Properties":{"id":"20260305082131-6g7mppx","updated":"20260305082131"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"#### "},{"Type":"NodeText","Data":"7.1 while循环结构"}]},{"ID":"20260305082131-es8mzgb","Type":"NodeParagraph","Properties":{"id":"20260305082131-es8mzgb","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"接下来，我们学习while循环结构语句"}]},{"ID":"20260305082131-jwrikei","Type":"NodeParagraph","Properties":{"id":"20260305082131-jwrikei","updated":"20260305082131"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"格式："}]},{"ID":"20260305082131-uc5pv5g","Type":"NodeParagraph","Properties":{"id":"20260305082131-uc5pv5g","updated":"20260305082131"},"Children":[{"Type":"NodeImage","Children":[{"Type":"NodeBang","Data":"!"},{"Type":"NodeOpenBracket","Data":"["},{"Type":"NodeLinkText","Data":"外链图片转存失败,源站可能有防盗链机制,建议将图片保存下来直接上传"},{"Type":"NodeCloseBracket","Data":"]"},{"Type":"NodeOpenParen","Data":"("},{"Type":"NodeLinkDest","Data":"https://i-blog.csdnimg.cn/direct/38035234cc8d4239acd64889efe5b136.png"},{"Type":"NodeCloseParen","Data":")"}]}]},{"ID":"20260305082131-mbeubld","Type":"NodeParagraph","Properties":{"id":"20260305082131-mbeubld","updated":"20260305082131"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"范例："}]},{"ID":"20260305082131-4mgorjl","Type":"NodeParagraph","Properties":{"id":"20260305082131-4mgorjl","updated":"20260305082131"},"Children":[{"Type":"NodeImage","Children":[{"Type":"NodeBang","Data":"!"},{"Type":"NodeOpenBracket","Data":"["},{"Type":"NodeLinkText","Data":"外链图片转存失败,源站可能有防盗链机制,建议将图片保存下来直接上传"},{"Type":"NodeCloseBracket","Data":"]"},{"Type":"NodeOpenParen","Data":"("},{"Type":"NodeLinkDest","Data":"https://i-blog.csdnimg.cn/direct/352daa437ade433ab13b447e77f48c54.png"},{"Type":"NodeCloseParen","Data":")"}]}]},{"ID":"20260305082131-h3h1qpy","Type":"NodeParagraph","Properties":{"id":"20260305082131-h3h1qpy","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"知道了while循环的格式后，下面我们到IDEA中去演示一下："}]},{"ID":"20260305082131-xpt3v3m","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"amF2YQ==","CodeBlockCloseFence":"YGBg","Properties":{"id":"20260305082131-xpt3v3m","updated":"20260305082131"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"amF2YQ=="},{"Type":"NodeCodeBlockCode","Data":"/*\n    while循环结构\n */\npublic class WhileDemo {\n    public static void main(String[] args) {\n        int i = 1;\n        while (i\u003c=5) {\n            System.out.println(\"HelloWorld\");\n            i++;\n        }\n    }\n}\n123456789101112\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3}]},{"ID":"20260305082131-zsuhno1","Type":"NodeParagraph","Properties":{"id":"20260305082131-zsuhno1","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"代码演示后，通过Debug查看了一下程序的执行流程，让我们更清晰while循环的执行流程。"}]},{"ID":"20260305082131-a16glyr","Type":"NodeParagraph","Properties":{"id":"20260305082131-a16glyr","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"最后，我们再来总结一下while循环的执行流程："}]},{"ID":"20260305082131-q4864uh","Type":"NodeParagraph","Properties":{"id":"20260305082131-q4864uh","updated":"20260305082131"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"执行流程："}]},{"ID":"20260305082131-jwuy9cz","Type":"NodeParagraph","Properties":{"id":"20260305082131-jwuy9cz","updated":"20260305082131"},"Children":[{"Type":"NodeImage","Children":[{"Type":"NodeBang","Data":"!"},{"Type":"NodeOpenBracket","Data":"["},{"Type":"NodeLinkText","Data":"外链图片转存失败,源站可能有防盗链机制,建议将图片保存下来直接上传"},{"Type":"NodeCloseBracket","Data":"]"},{"Type":"NodeOpenParen","Data":"("},{"Type":"NodeLinkDest","Data":"https://i-blog.csdnimg.cn/direct/9bc097eedcb1448ba5200af8149341bb.png"},{"Type":"NodeCloseParen","Data":")"}]}]},{"ID":"20260305082131-otvj39w","Type":"NodeHeading","HeadingLevel":4,"Properties":{"id":"20260305082131-otvj39w","updated":"20260305082131"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"#### "},{"Type":"NodeText","Data":"7.2 案例1(求奇数和)"}]},{"ID":"20260305082131-d3ay8vp","Type":"NodeParagraph","Properties":{"id":"20260305082131-d3ay8vp","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"需求：求1-100之间的奇数和，并把求和结果在控制台输出"}]},{"ID":"20260305082131-m2kjn3n","Type":"NodeParagraph","Properties":{"id":"20260305082131-m2kjn3n","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"首先，我们来简单的分析一下："}]},{"ID":"20260305082131-nz7goqw","Type":"NodeParagraph","Properties":{"id":"20260305082131-nz7goqw","updated":"20260305082131"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"分析："}]},{"ID":"20260305082131-tbjy073","Type":"NodeParagraph","Properties":{"id":"20260305082131-tbjy073","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"① 对1-100的奇数求和，和前面讲解的偶数求和几乎是完全一样，仅仅是判断条件不同"}]},{"ID":"20260305082131-hijxvar","Type":"NodeParagraph","Properties":{"id":"20260305082131-hijxvar","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"② 判断条件是奇数才参与运算，因此条件应该是判断是否是奇数"}]},{"ID":"20260305082131-pztq3h5","Type":"NodeParagraph","Properties":{"id":"20260305082131-pztq3h5","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"③ 当循环执行完毕时，将最终数据打印出来"}]},{"ID":"20260305082131-n2ig2sf","Type":"NodeParagraph","Properties":{"id":"20260305082131-n2ig2sf","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"分析完毕之后，我们到IDEA中去实现一下："}]},{"ID":"20260305082131-3vxjiv4","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"amF2YQ==","CodeBlockCloseFence":"YGBg","Properties":{"id":"20260305082131-3vxjiv4","updated":"20260305082131"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"amF2YQ=="},{"Type":"NodeCodeBlockCode","Data":"/*\n    需求：求1-100之间的奇数和，并把求和结果在控制台输出\n */\npublic class WhileTest01 {\n    public static void main(String[] args) {\n        //定义求和变量，初始化值为0\n        int sum = 0;\n\n        //获取1-100之间的数据\n//        int i = 1;\n//        while (i\u003c=100) {\n//            //判断数据是否是奇数\n            if(i%2 != 0) {\n                sum += i;\n            }\n//\n//            if(i%2 == 1) {\n//                sum += i;\n//            }\n//\n//            i++;\n//        }\n\n        int i = 1;\n        while (i \u003c= 100) {\n            sum += i;\n            i += 2; //1,3,5,7...99,101\n        }\n\n        //输出结果\n        System.out.println(\"1-100之间的奇数和是：\" + sum);\n    }\n}\n123456789101112131415161718192021222324252627282930313233\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3}]},{"ID":"20260305082131-kx1fmyp","Type":"NodeHeading","HeadingLevel":4,"Properties":{"id":"20260305082131-kx1fmyp","updated":"20260305082131"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"#### "},{"Type":"NodeText","Data":"7.3 案例2(珠穆朗玛峰)"}]},{"ID":"20260305082131-4z0af2u","Type":"NodeParagraph","Properties":{"id":"20260305082131-4z0af2u","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"需求：世界最高峰珠穆朗玛峰(8848.86m)，我现在有一张足够大的纸张，厚度为：0.001m。请问，我折叠多少次，就可以保证厚度不低于珠穆朗玛峰的高度?"}]},{"ID":"20260305082131-nfb7gfw","Type":"NodeParagraph","Properties":{"id":"20260305082131-nfb7gfw","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"首先，我们来简单的分析一下："}]},{"ID":"20260305082131-ev4hp4h","Type":"NodeParagraph","Properties":{"id":"20260305082131-ev4hp4h","updated":"20260305082131"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"分析："}]},{"ID":"20260305082131-5oeyy66","Type":"NodeParagraph","Properties":{"id":"20260305082131-5oeyy66","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"① 因为要反复折叠，所以要使用循环，该选for循环还是while循环呢？"}]},{"ID":"20260305082131-fode97v","Type":"NodeParagraph","Properties":{"id":"20260305082131-fode97v","updated":"20260305082131"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"小技巧：循环次数明确，使用for循环；循环次数不明确，使用while循环"}]},{"ID":"20260305082131-e04ynqx","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"amF2YQ==","CodeBlockCloseFence":"YGBg","Properties":{"id":"20260305082131-e04ynqx","updated":"20260305082131"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"amF2YQ=="},{"Type":"NodeCodeBlockCode","Data":"这里不知道折叠多少次，这种情况下更适合使用while循环\n1\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3}]},{"ID":"20260305082131-bb9bv8x","Type":"NodeParagraph","Properties":{"id":"20260305082131-bb9bv8x","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"② 纸张每折叠一次，厚度加倍，因此要先定义纸张厚度，在循环中使厚度加倍"}]},{"ID":"20260305082131-qtheryj","Type":"NodeParagraph","Properties":{"id":"20260305082131-qtheryj","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"③ 什么时候就停止折叠了呢？直到纸张的厚度大于等于珠峰的高度，反言之，就要折叠"}]},{"ID":"20260305082131-p34dt18","Type":"NodeParagraph","Properties":{"id":"20260305082131-p34dt18","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"④ 要求的是统计折叠次数，所以会用到统计思想"}]},{"ID":"20260305082131-tr4ewr8","Type":"NodeParagraph","Properties":{"id":"20260305082131-tr4ewr8","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"分析完毕后，我们来说一下实现步骤："}]},{"ID":"20260305082131-0brtjt8","Type":"NodeParagraph","Properties":{"id":"20260305082131-0brtjt8","updated":"20260305082131"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"实现步骤："}]},{"ID":"20260305082131-pt83c0b","Type":"NodeParagraph","Properties":{"id":"20260305082131-pt83c0b","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"① 定义统计变量，初始化值为0"}]},{"ID":"20260305082131-4nk5syx","Type":"NodeParagraph","Properties":{"id":"20260305082131-4nk5syx","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"② 定义纸张厚度变量和珠峰高度变量"}]},{"ID":"20260305082131-kwtqsst","Type":"NodeParagraph","Properties":{"id":"20260305082131-kwtqsst","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"③ 用while循环实现反复折叠，判断条件是纸张厚度小于珠峰高度"}]},{"ID":"20260305082131-pil8346","Type":"NodeParagraph","Properties":{"id":"20260305082131-pil8346","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"④ 循环体中要做两件事情：一是纸张厚度加倍，二是统计变量+1"}]},{"ID":"20260305082131-u0f4p4a","Type":"NodeParagraph","Properties":{"id":"20260305082131-u0f4p4a","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"⑤ 当循环结束，输出统计变量的值"}]},{"ID":"20260305082131-lu4d7p8","Type":"NodeParagraph","Properties":{"id":"20260305082131-lu4d7p8","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"知道了实现步骤，下面我们到IDEA中去实现一下："}]},{"ID":"20260305082131-6lffega","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"amF2YQ==","CodeBlockCloseFence":"YGBg","Properties":{"id":"20260305082131-6lffega","updated":"20260305082131"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"amF2YQ=="},{"Type":"NodeCodeBlockCode","Data":"/*\n    需求：世界最高峰珠穆朗玛峰(8848.86m)，我现在有一张足够大的纸张，厚度为：0.001m。\n         请问，我折叠多少次，就可以保证厚度不低于珠穆朗玛峰的高度?\n */\npublic class WhileTest02 {\n    public static void main(String[] args) {\n        //1:定义统计变量，初始化值为0\n        int count = 0;\n\n        //2:定义纸张厚度变量和珠峰高度变量\n        double paper = 0.001;\n        double zf = 8848.86;\n\n        //3:用while循环实现反复折叠，判断条件是纸张厚度小于珠峰高度\n        while (paper \u003c zf) {\n            //4:循环体中要做两件事情：一是纸张厚度加倍，二是统计变量+1\n            paper *= 2;\n\n            count++;\n        }\n\n        //5:当循环结束，输出统计变量的值\n        System.out.println(\"要折叠\" + count + \"次\");\n    }\n}\n12345678910111213141516171819202122232425\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3}]},{"ID":"20260305082131-2s5jq19","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20260305082131-2s5jq19","updated":"20260305082131"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"### "},{"Type":"NodeText","Data":"8：do-while循环结构"}]},{"ID":"20260305082131-hs3geo0","Type":"NodeHeading","HeadingLevel":4,"Properties":{"id":"20260305082131-hs3geo0","updated":"20260305082131"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"#### "},{"Type":"NodeText","Data":"8.1 do-while循环结构"}]},{"ID":"20260305082131-sphj0t5","Type":"NodeParagraph","Properties":{"id":"20260305082131-sphj0t5","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"接下来，我们学习do-while循环结构语句"}]},{"ID":"20260305082131-4k273z1","Type":"NodeParagraph","Properties":{"id":"20260305082131-4k273z1","updated":"20260305082131"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"格式："}]},{"ID":"20260305082131-9vyb151","Type":"NodeParagraph","Properties":{"id":"20260305082131-9vyb151","updated":"20260305082131"},"Children":[{"Type":"NodeImage","Children":[{"Type":"NodeBang","Data":"!"},{"Type":"NodeOpenBracket","Data":"["},{"Type":"NodeLinkText","Data":"外链图片转存失败,源站可能有防盗链机制,建议将图片保存下来直接上传"},{"Type":"NodeCloseBracket","Data":"]"},{"Type":"NodeOpenParen","Data":"("},{"Type":"NodeLinkDest","Data":"https://i-blog.csdnimg.cn/direct/3040d58b86db4e478eca4c9ea142320c.png"},{"Type":"NodeCloseParen","Data":")"}]}]},{"ID":"20260305082131-u9sfe99","Type":"NodeParagraph","Properties":{"id":"20260305082131-u9sfe99","updated":"20260305082131"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"范例："}]},{"ID":"20260305082131-byicxpw","Type":"NodeParagraph","Properties":{"id":"20260305082131-byicxpw","updated":"20260305082131"},"Children":[{"Type":"NodeImage","Children":[{"Type":"NodeBang","Data":"!"},{"Type":"NodeOpenBracket","Data":"["},{"Type":"NodeLinkText","Data":"外链图片转存失败,源站可能有防盗链机制,建议将图片保存下来直接上传"},{"Type":"NodeCloseBracket","Data":"]"},{"Type":"NodeOpenParen","Data":"("},{"Type":"NodeLinkDest","Data":"https://i-blog.csdnimg.cn/direct/d8c552e7a31845ce9e299e67554188f4.png"},{"Type":"NodeCloseParen","Data":")"}]}]},{"ID":"20260305082131-aipz9iu","Type":"NodeParagraph","Properties":{"id":"20260305082131-aipz9iu","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"知道了do-while循环的格式后，下面我们到IDEA中去演示一下："}]},{"ID":"20260305082131-45gmui0","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"amF2YQ==","CodeBlockCloseFence":"YGBg","Properties":{"id":"20260305082131-45gmui0","updated":"20260305082131"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"amF2YQ=="},{"Type":"NodeCodeBlockCode","Data":"/*\n    do...while循环结构\n */\npublic class DoWhileDemo {\n    public static void main(String[] args) {\n        int i = 1;\n        do {\n            System.out.println(\"HelloWorld\");\n            i++;\n        } while (i\u003c=5);\n    }\n}\n123456789101112\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3}]},{"ID":"20260305082131-1lyw08d","Type":"NodeParagraph","Properties":{"id":"20260305082131-1lyw08d","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"代码演示后，通过Debug查看了一下程序的执行流程，让我们更清晰do-while循环的执行流程。"}]},{"ID":"20260305082131-wgvrp1g","Type":"NodeParagraph","Properties":{"id":"20260305082131-wgvrp1g","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"最后，我们再来总结一下do-while循环的执行流程："}]},{"ID":"20260305082131-n3kwod6","Type":"NodeParagraph","Properties":{"id":"20260305082131-n3kwod6","updated":"20260305082131"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"执行流程："}]},{"ID":"20260305082131-1j342pm","Type":"NodeParagraph","Properties":{"id":"20260305082131-1j342pm","updated":"20260305082131"},"Children":[{"Type":"NodeImage","Children":[{"Type":"NodeBang","Data":"!"},{"Type":"NodeOpenBracket","Data":"["},{"Type":"NodeLinkText","Data":"外链图片转存失败,源站可能有防盗链机制,建议将图片保存下来直接上传"},{"Type":"NodeCloseBracket","Data":"]"},{"Type":"NodeOpenParen","Data":"("},{"Type":"NodeLinkDest","Data":"https://i-blog.csdnimg.cn/direct/dfa210cd399641f49959ddfd1cf3771d.png"},{"Type":"NodeCloseParen","Data":")"}]}]},{"ID":"20260305082131-cgo2jfu","Type":"NodeHeading","HeadingLevel":4,"Properties":{"id":"20260305082131-cgo2jfu","updated":"20260305082131"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"#### "},{"Type":"NodeText","Data":"8.2 三种循环的区别"}]},{"ID":"20260305082131-0gw6lj1","Type":"NodeParagraph","Properties":{"id":"20260305082131-0gw6lj1","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"前面我们讲解了三种循环语句的格式和执行流程，下面我们来讲解这三种循环语句的区别。"}]},{"ID":"20260305082131-je7a0q7","Type":"NodeParagraph","Properties":{"id":"20260305082131-je7a0q7","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"而关于这三种循环语句的区别，我们先到IDEA中去讲解，然后再回来总结："}]},{"ID":"20260305082131-eoop2vb","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"amF2YQ==","CodeBlockCloseFence":"YGBg","Properties":{"id":"20260305082131-eoop2vb","updated":"20260305082131"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"amF2YQ=="},{"Type":"NodeCodeBlockCode","Data":"/*\n    三种循环的区别\n */\npublic class LoopTest {\n    public static void main(String[] args) {\n//        //for循环\n//        for (int i = 3; i \u003c 3; i++) {\n//            System.out.println(\"我爱Java\");\n//        }\n//        System.out.println(\"--------\");\n//\n//        //while循环\n//        int j = 3;\n//        while (j \u003c 3) {\n//            System.out.println(\"我爱Java\");\n//            j++;\n//        }\n//        System.out.println(\"--------\");\n//\n//        //do...while循环\n//        int k = 3;\n//        do {\n//            System.out.println(\"我爱Java\");\n//            k++;\n//        } while (k \u003c 3);\n\n//        //for循环\n//        for (int i = 1; i \u003c 3; i++) {\n//            System.out.println(\"我爱Java\");\n//        }\n        System.out.println(i);\n//        System.out.println(\"--------\");\n//\n//        //while循环\n//        int j = 1;\n//        while (j \u003c 3) {\n//            System.out.println(\"我爱Java\");\n//            j++;\n//        }\n//        System.out.println(j);\n//        System.out.println(\"--------\");\n\n        //死循环\n//        for (;;) {\n//            System.out.println(\"for...\");\n//        }\n\n//        while (true) {\n//            System.out.println(\"while...\");\n//        }\n\n        do {\n            System.out.println(\"do...while...\");\n        } while (true);\n\n    }\n}\n123456789101112131415161718192021222324252627282930313233343536373839404142434445464748495051525354555657\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3}]},{"ID":"20260305082131-t6w70q1","Type":"NodeParagraph","Properties":{"id":"20260305082131-t6w70q1","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"讲解完毕后，回到资料，我们总结一下："}]},{"ID":"20260305082131-ekzb62d","Type":"NodeParagraph","Properties":{"id":"20260305082131-ekzb62d","updated":"20260305082131"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"三种循环语句的区别："}]},{"ID":"20260305082131-4bmcpqy","Type":"NodeParagraph","Properties":{"id":"20260305082131-4bmcpqy","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"for循环和while循环 "},{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"先判断条件是否成立"},{"Type":"NodeText","Data":" ，然后决定是否执行循环体（先判断后执行）"}]},{"ID":"20260305082131-rz59xe2","Type":"NodeParagraph","Properties":{"id":"20260305082131-rz59xe2","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"do…while循环 "},{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"先执行一次循环体"},{"Type":"NodeText","Data":" ，然后判断条件是否成立，是否继续执行循环体（先执行后判断）"}]},{"ID":"20260305082131-5eyz7d7","Type":"NodeParagraph","Properties":{"id":"20260305082131-5eyz7d7","updated":"20260305082131"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"for和while的区别："}]},{"ID":"20260305082131-phof22y","Type":"NodeParagraph","Properties":{"id":"20260305082131-phof22y","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"条件控制语句所控制的自增变量，在for循环结束后，就 "},{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"不可以继续使用"},{"Type":"NodeText","Data":" 了"}]},{"ID":"20260305082131-ndzaf9p","Type":"NodeParagraph","Properties":{"id":"20260305082131-ndzaf9p","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"条件控制语句所控制的自增变量，在while循环结束后， "},{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"还可以继续使用"}]},{"ID":"20260305082131-efc1tc6","Type":"NodeParagraph","Properties":{"id":"20260305082131-efc1tc6","updated":"20260305082131"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"死循环格式："}]},{"ID":"20260305082131-3teprj8","Type":"NodeParagraph","Properties":{"id":"20260305082131-3teprj8","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"for(;; ){}"}]},{"ID":"20260305082131-fub06yr","Type":"NodeParagraph","Properties":{"id":"20260305082131-fub06yr","updated":"20260305082131"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"while(true) {}"}]},{"ID":"20260305082131-v326xuk","Type":"NodeParagraph","Properties":{"id":"20260305082131-v326xuk","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"do{}while(true);"}]},{"ID":"20260305082131-00wx9qh","Type":"NodeParagraph","Properties":{"id":"20260305082131-00wx9qh","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"由于循环语句的区别，只是大家需要理解的知识点，故这里不需要练习，我们在后面的使用中，