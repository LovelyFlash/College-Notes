用方法，把结果在控制台输出。\n */\npublic class MethodTest03 {\n    public static void main(String[] args) {\n        int max = getMax(10, 20, 30);\n        System.out.println(\"10,20,30中的较大值是：\" + max);\n    }\n\n    /*\n        使用两个明确分析该方法的参数和返回值\n        参数：int a,int b,int c\n        返回值类型：int\n     */\n    public static int getMax(int a, int b, int c) {\n        //获取三个整数较大值\n//        if (a \u003e= b) {\n//            if (a \u003e= c) {\n//                return a;\n//            } else {\n//                return c;\n//            }\n//        } else {\n//            if (b \u003e= c) {\n//                return b;\n//            } else {\n//                return c;\n//            }\n//        }\n\n        int tempMax = a \u003e b ? a : b;\n        int max = tempMax \u003e c ? tempMax : c;\n        return max;\n    }\n}\n1234567891011121314151617181920212223242526272829303132333435\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3}]},{"ID":"20260305082131-baue2qp","Type":"NodeHeading","HeadingLevel":4,"Properties":{"id":"20260305082131-baue2qp","updated":"20260305082131"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"#### "},{"Type":"NodeText","Data":"11.5 练习4(水仙花)"}]},{"ID":"20260305082131-g6a2hpa","Type":"NodeParagraph","Properties":{"id":"20260305082131-g6a2hpa","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"需求：设计一个方法用于判断一个整数是否是水仙花数，调用方法，把结果在控制台输出。"}]},{"ID":"20260305082131-qu9hmla","Type":"NodeParagraph","Properties":{"id":"20260305082131-qu9hmla","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"首先，我们来简单的分析一下："}]},{"ID":"20260305082131-ifs78p0","Type":"NodeParagraph","Properties":{"id":"20260305082131-ifs78p0","updated":"20260305082131"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"分析："}]},{"ID":"20260305082131-1utd0vz","Type":"NodeParagraph","Properties":{"id":"20260305082131-1utd0vz","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"① 方法定义"}]},{