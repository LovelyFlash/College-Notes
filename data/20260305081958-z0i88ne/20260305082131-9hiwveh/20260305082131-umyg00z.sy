istItem","Data":"-","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"MarkerOffset":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20260305082131-58pdsp7","updated":"20260305082131"},"Children":[{"ID":"20260305082131-6rakhby","Type":"NodeParagraph","Properties":{"id":"20260305082131-6rakhby","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"特征③：索引逐一增加，每次加1"}]}]}]}]}]},{"ID":"20260305082131-s00y86r","Type":"NodeParagraph","Properties":{"id":"20260305082131-s00y86r","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"知道了如何访问数组变量以及数组中的元素后，下面我们到idea中去演示一下。"}]},{"ID":"20260305082131-9v2i50i","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"amF2YQ==","CodeBlockCloseFence":"YGBg","Properties":{"id":"20260305082131-9v2i50i","updated":"20260305082131"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"amF2YQ=="},{"Type":"NodeCodeBlockCode","Data":"/*\n    数组变量访问方式\n        格式：数组名\n\n    数组内部保存的数据的访问方式\n        格式：数组名[索引]\n */\npublic class ArrayDemo {\n    public static void main(String[] args) {\n        //定义一个数组，并进行初始化\n//        int[] scores = new int[]{93,96,99};\n        int[] scores = {93,96,99};\n\n        //输出数组名\n        System.out.println(scores); //[I@776ec8df\n\n        //输出数组中的元素\n        System.out.println(scores[0]);\n        System.out.println(scores[1]);\n        System.out.println(scores[2]);\n        System.out.println(\"-----------\");\n\n        //修改数组中的元素\n        scores[0] = 100;\n        scores[1] = 98;\n        scores[2] = 95;\n        //再次输出数组中的元素\n        System.out.println(scores[0]);\n        System.out.println(scores[1]);\n        System.out.println(scores[2]);\n    }\n}\n1234567891011121314151617181920212223242526272829303132\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3}]},{"ID":"20260305082131-hlohyx7","Type":"NodeHeading","HeadingLevel":4,"Properties":{"id":"20260305082131-hlohyx7","updated":"20260305082131"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"#### "},{"Type":"NodeText","Data":"13.4 案例1(数组常见操作之遍历)"}]},{"ID":"20260305082131-qrprnhu","Type":"NodeParagraph","Properties":{"id":"20260305082131-qrprnhu","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"下面我们来学习数组常见操作，数组常见操作有很多，这里我们先讲解下面这几个："}]},{"ID":"20260305082131-7sfvw9d","Type":"NodeList","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20260305082131-7sfvw9d","updated":"20260305082131"},"Children":[{"ID":"20260305082131-u7iofvu","Type":"NodeListItem","Data":"-","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20260305082131-u7iofvu","updated":"20260305082131"},"Children":[{"ID":"20260305082131-uc6zurf","Type":"NodeParagraph","Properties":{"id":"20260305082131-uc6zurf","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"遍历"}]}]},{"ID":"20260305082131-ii7ds6e","Type":"NodeListItem","Data":"-","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20260305082131-ii7ds6e","updated":"20260305082131"},"Children":[{"ID":"20260305082131-o5emgl2","Type":"NodeParagraph","Properties":{"id":"20260305082131-o5emgl2","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"获取最大值"}]}]},{"ID":"20260305082131-ax76ubk","Type":"NodeListItem","Data":"-","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20260305082131-ax76ubk","updated":"20260305082131"},"Children":[{"ID":"20260305082131-ocygx3s","Type":"NodeParagraph","Properties":{"id":"20260305082131-ocygx3s","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"元素打乱"}]}]}]},{"ID":"20260305082131-1bwskuc","Type":"NodeParagraph","Properties":{"id":"20260305082131-1bwskuc","updated":"20260305082131"},"Children":[{"Ty