"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3}]},{"ID":"20260305082131-ltoe280","Type":"NodeParagraph","Properties":{"id":"20260305082131-ltoe280","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"好了，自动装箱和拆箱我们就先讲到这里。"}]},{"ID":"20260305082131-by27hhj","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20260305082131-by27hhj","updated":"20260305082131"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"### "},{"Type":"NodeText","Data":"21：Date和SimpleDateFormat"}]},{"ID":"20260305082131-xt072ur","Type":"NodeHeading","HeadingLevel":4,"Properties":{"id":"20260305082131-xt072ur","updated":"20260305082131"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"#### "},{"Type":"NodeText","Data":"21.1 Date(构造方法)"}]},{"ID":"20260305082131-ufkl4ya","Type":"NodeParagraph","Properties":{"id":"20260305082131-ufkl4ya","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"下面我们来学习Date类和SimpleDateFormat类，它们涉及到两个案例：手机日期和时间显示和考勤查询"}]},{"ID":"20260305082131-03it2tc","Type":"NodeParagraph","Properties":{"id":"20260305082131-03it2tc","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"先来看手机日期和时间显示案例：获取当前时间，按照指定的格式显示在窗体上。"}]},{"ID":"20260305082131-aj0vkv8","Type":"NodeParagraph","Properties":{"id":"20260305082131-aj0vkv8","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"也就是在这里我们要进行把一个Date类型的数据，按照指定的格式，变成一个字符串数据显示出来。"}]},{"ID":"20260305082131-j6gtt27","Type":"NodeParagraph","Properties":{"id":"20260305082131-j6gtt27","updated":"20260305082131"},"Children":[{"Type":"NodeImage","Children":[{"Type":"NodeBang","Data":"!"},{"Type":"NodeOpenBracket","Data":"["},{"Type":"NodeLinkText","Data":"外链图片转存失败,源站可能有防盗链机制,建议将图片保存下来直接上传"},{"Type":"NodeCloseBracket","Data":"]"},{"Type":"NodeOpenParen","Data":"("},{"Type":"NodeLinkDest","Data":"https://i-blog.csdnimg.cn/direct/21bb5c627b33437ba5bfe827b32e0df1.png"},{"Type":"NodeCloseParen","Data":")"}]}]},{"ID":"20260305082131-ggchaa1","Type":"NodeParagraph","Properties":{"id":"20260305082131-ggchaa1","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"再来看考勤查询案例，我们要通过输入的指定格式的日期字符串数据，得到Date类型的数据。"}]},{"ID":"20260305082131-xqk5vbg","Type":"NodeParagraph","Properties":{"id":"20260305082131-xqk5vbg","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"所以，我们学习Date类和SimpleDateFormat类的重点就是为了把Date类型数据和String类型数据之间进行按照指定格式进行转换。"}]},{"ID":"20260305082131-oxdyiyl","Type":"NodeParagraph","Properties":{"id":"20260305082131-oxdyiyl","updated":"20260305082131"},"Children":[{"Type":"NodeImage","Children":[{"Type":"NodeBang","Data":"!"},{"Type":"NodeOpenBracket","Data":"["},{"Type":"NodeLinkText","Data":"外链图片转存失败,源站可能有防盗链机制,建议将图片保存下来直接上传"},{"Type":"NodeCloseBracket","Data":"]"},{"Type":"NodeOpenParen","Data":"("},{"Type":"NodeLinkDest","Data":"https://i-blog.csdnimg.cn/direct/9be96c152a3241a4a038f679801716da.png"},{"Type":"NodeCloseParen","Data":")"}]}]},{"ID":"20260305082131-rqmtq9e","Type":"NodeParagraph","Properties":{"id":"20260305082131-rqmtq9e","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"首先呢，我们先来学习一下Date类，而关于Date类呢，我们先到帮助文档中去查看，然后回来总结，最后到IDEA中去演示。"}]},{"ID":"20260305082131-2plbhn5","Type":"NodeParagraph","Properties":{"id":"20260305082131-2plbhn5","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"来，打开我们准备好的帮助文档，关于通过帮助文档查看Date，大家按照老师讲解的API的使用步骤看看即可。"}]},{"ID":"20260305082131-s8c9a61","Type":"NodeParagraph","Properties":{"id":"20260305082131-s8c9a61","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"通过文档了解了Date类之后，下面我们回到资料中总结一下："}]},{"ID":"20260305082131-ajl9qx6","Type":"NodeParagraph","Properties":{"id":"20260305082131-ajl9qx6","updated":"20260305082131"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"Date："}]},{"ID":"20260305082131-b8biht2","Type":"NodeList","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20260305082131-b8biht2","updated":"20260305082131"},"Children":[{"ID":"20260305082131-ugtcufs","Type":"NodeListItem","Data":"-","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20260305082131-ugtcufs","updated":"20260305082131"},"Children":[{"ID":"20260305082131-2xsrk49","Type":"NodeParagraph","Properties":{"id":"20260305082131-2xsrk49","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"Date类表示特定的时刻，精度为毫秒"}]}]}]},{"ID":"20260305082131-2npf7mg","Type":"NodeParagraph","Properties":{"id":"20260305082131-2npf7mg","updated":"20260305082131"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"构造方法："}]},{"ID":"20260305082131-eyy2aj3","Type":"NodeList","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20260305082131-eyy2aj3","updated":"20260305082131"},"Children":[{"ID":"20260305082131-8pqq6y4","Type":"NodeListItem","Data":"-","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20260305082131-8pqq6y4","updated":"20260305082131"},"Children":[{"ID":"20260305082131-vfo5kvc","Type":"NodeParagraph","Properties":{"id":"20260305082131-vfo5kvc","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"Date()：分配 Date对象并对其进行初始化，使其表示分配时间，测量 Date到毫秒"}]}]},{"ID":"20260305082131-vwlylc4","Type":"NodeListItem","Data":"-","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20260305082131-vwlylc4","updated":"20260305082131"},"Children":[{"ID":"20260305082131-jdasca7","Type":"NodeParagraph","Properties":{"id":"20260305082131-jdasca7","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"Date(long date)：分配 Date对象并初始化它以表示自 "},{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"标准基准时间"},{"Type":"NodeText","Data":" 以来的指定毫秒数，即 "},{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"1970年1月1日00:00:00"}]}]}]},{"ID":"20260305082131-xlna696","Type":"NodeParagraph","Properties":{"id":"20260305082131-xlna696","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"知道了(的构造方法后，我们到IDEA中去使用一下："}]},{"ID":"20260305082131-a343ung","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"amF2YQ==","CodeBlockCloseFence":"YGBg","Properties":{"id":"20260305082131-a343ung","updated":"20260305082131"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"amF2YQ=="},{"Type":"NodeCodeBlockCode","Data":"import java.util.Date;\n\n/*\n    构造方法：\n        Date()：分配 Date对象并对其进行初始化，使其表示分配时间，测量 Date到毫秒\n        Date(long date)：分配 Date对象并初始化它以表示自标准基准时间以来的指定毫秒数，即1970年1月1日00:00:00\n */\npublic class DateDemo {\n    public static void main(String[] args) {\n        //Date()：分配 Date对象并对其进行初始化，使其表示分配时间，测量 Date到毫秒\n        Date d1 = new Date();\n        System.out.println(d1);\n\n        //Date(long date)：分配 Date对象并初始化它以表示自标准基准时间以来的指定毫秒数，即1970年1月1日00:00:00\n        Date d2 = new Date(1000 * 60 * 60);\n        System.out.println(d2);\n    }\n}\n123456789101112131415161718\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3}]},{"ID":"20260305082131-wdtgyfp","Type":"NodeParagraph","Properties":{"id":"20260305082131-wdtgyfp","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"而目前呢，Date类中没有我们要使用的成员方法，所以，我们也就不看它的成员方法了。"}]},{"ID":"20260305082131-xegqe6f","Type":"NodeHeading","HeadingLevel":4,"Properties":{"id":"20260305082131-xegqe6f","updated":"20260305082131"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"#### "},{"Type":"NodeText","Data":"21.2 SimpleDateFormat(Date和String的相互转换)"}]},{"ID":"20260305082131-h5rhav7","Type":"NodeParagraph","Properties":{"id":"20260305082131-h5rhav7","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"下面我们来学习SimpleDateFormat这个类。"}]},{"ID":"20260305082131-hle5ik1","Type":"NodeParagraph","Properties":{"id":"20260305082131-hle5ik1","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"打开我们准备好的帮助文档，关于通过帮助文档查看SimpleDateFormat，大家按照老师讲解的API的使用步骤看看即可。"}]},{"ID":"20260305082131-50y0v4o","Type":"NodeParagraph","Properties":{"id":"20260305082131-50y0v4o","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"通过文档了解了SimpleDateFormat类之后，下面我们回到资料中总结一下："}]},{"ID":"20260305082131-2kj0ivk","Type":"NodeParagraph","Properties":{"id":"20260305082131-2kj0ivk","updated":"20260305082131"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"SimpleDateFormat："}]},{"ID":"20260305082131-s9fm20w","Type":"NodeList","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20260305082131-s9fm20w","updated":"20260305082131"},"Children":[{"ID":"20260305082131-4m1h8nf","Type":"NodeListItem","Data":"-","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20260305082131-4m1h8nf","updated":"20260305082131"},"Children":[{"ID":"20260305082131-vx35g2a","Type":"NodeParagraph","Properties":{"id":"20260305082131-vx35g2a","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"SimpleDateFormat 是一个用于以区域设置敏感的方式格式化和解析日期的具体类。我们重点学习日期格式化和解析"}]}]},{"ID":"20260305082131-sqjilc7","Type":"NodeListItem","Data":"-","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20260305082131-sqjilc7","updated":"20260305082131"},"Children":[{"ID":"20260305082131-4x1m0d2","Type":"NodeParagraph","Properties":{"id":"20260305082131-4x1m0d2","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"日期和时间格式由日期和时间模式字符串指定，在日期和时间模式字符串中，从‘A’到‘Z’以及从‘a’到‘z’引号的字母被解释为表示日期或时间字符串的组成部分的模式字母"}]}]}]},{"ID":"20260305082131-1j0awae","Type":"NodeParagraph","Properties":{"id":"20260305082131-1j0awae","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"常用的模式字母及对应关系如下："}]},{"ID":"20260305082131-koae2r5","Type":"NodeParagraph","Properties