ren":[{"ID":"20260305082131-cd4kzs5","Type":"NodeParagraph","Properties":{"id":"20260305082131-cd4kzs5","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"例如：itheima-api-gui"},{"Type":"NodeBackslash","Children":[{"Type":"NodeBackslashContent","Data":"\\"}]},{"Type":"NodeText","Data":"images"},{"Type":"NodeBackslash","Children":[{"Type":"NodeBackslashContent","Data":"\\"}]},{"Type":"NodeText","Data":"mn.png"}]}]}]}]}]}]}]},{"ID":"20260305082131-keukkam","Type":"NodeParagraph","Properties":{"id":"20260305082131-keukkam","updated":"20260305082131"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"成员方法："}]},{"ID":"20260305082131-9e2s433","Type":"NodeList","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20260305082131-9e2s433","updated":"20260305082131"},"Children":[{"ID":"20260305082131-8zz8qrn","Type":"NodeListItem","Data":"-","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20260305082131-8zz8qrn","updated":"20260305082131"},"Children":[{"ID":"20260305082131-xdve3bv","Type":"NodeParagraph","Properties":{"id":"20260305082131-xdve3bv","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"void setBounds(int x, int y, int width, int height)：设置位置和大小"}]}]}]},{"ID":"20260305082131-y3k4b9n","Type":"NodeParagraph","Properties":{"id":"20260305082131-y3k4b9n","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"知道了JLabel的构造方法和成员方法后，我们到IDEA中去使用一下："}]},{"ID":"20260305082131-6zc5kya","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"amF2YQ==","CodeBlockCloseFence":"YGBg","Properties":{"id":"20260305082131-6zc5kya","updated":"20260305082131"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"amF2YQ=="},{"Type":"NodeCodeBlockCode","Data":"import javax.swing.*;\n\n/*\n    构造方法\n        JLabel(String text)：使用指定的文本创建 JLabel实例\n        JLabel(Icon image)：使用指定的图像创建 JLabel实例\n            ImageIcon(String filename)：从指定的文件创建ImageIcon\n    成员方法\n        void setBounds(int x, int y, int width, int height)：设置位置和大小\n */\npublic class JLabelDemo {\n    public static void main(String[] args) {\n        //创建窗体对象\n        JFrame jf = new JFrame();\n\n        jf.setTitle(\"显示文本和图像\");\n        jf.setSize(400, 300);\n        jf.setDefaultCloseOperation(3);\n        jf.setLocationRelativeTo(null);\n        jf.setAlwaysOnTop(true);\n        jf.setLayout(null);\n\n        //JLabel(String text)：使用指定的文本创建 JLabel实例\n        JLabel jLabel = new JLabel(\"好好学习\");\n        jLabel.setBounds(0,0,100,20);\n\n        //JLabel(Icon image)：使用指定的图像创建 JLabel实例\n        //ImageIcon(String filename)：从指定的文件创建ImageIcon\n        //D:\\IdeaProjects\\javase_code\\itheima-api-gui\\images\\mn.png\n//        ImageIcon imageIcon = new ImageIcon(\"D:\\\\IdeaProjects\\\\javase_code\\\\itheima-api-gui\\\\images\\\\mn.png\");\n//        JLabel jLabel2 = new JLabel(imageIcon);\n//        JLabel jLabel2 = new JLabel(new ImageIcon(\"D:\\\\IdeaProjects\\\\javase_code\\\\itheima-api-gui\\\\images\\\\mn.png\"));\n        JLabel jLabel2 = new JLabel(new ImageIcon(\"itheima-api-gui\\\\images\\\\mn.png\"));\n        jLabel2.setBounds(50,50,100,143);\n\n        jf.add(jLabel);\n        jf.add(jLabel2);\n\n        //设置窗体可见\n        jf.setVisible(true);\n    }\n}\n123456789101112131415161718192021222324252627282930313233343536373839404142\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3}]},{"ID":"20260305082131-lybm947","Type":"NodeParagraph","Properties":{"id":"20260305082131-lybm947","updated":"20260305082131"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"注意："},{"Type":"NodeText","Data":" 在实际开发中，大家不用担心每个组件的位置和大小。因为这些都是前端人员设计好的。"}]},{"ID":"20260305082131-l2skjou","Type":"NodeHeading","HeadingLevel":4,"Properties":{"id":"20260305082131-l2skjou","updated":"20260305082131"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"#### "},{"Type":"NodeText","Data":"18.3 案例"}]},{"ID":"20260305082131-vyc54ii","Type":"NodeParagraph","Properties":{"id":"20260305082131-vyc54ii","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"下面呢，我们通过几个案例，来使用一下GUI中的常用组件。目前呢，我们仅仅是把界面做出来，下一次课呢，我们就要把最终的功能给实现了。首先，我们来看第一个案例。"}]},{"ID":"20260305082131-k67n3r1","Type":"NodeHeading","HeadingLevel":5,"Properties":{"id":"20260305082131-k67n3r1","updated":"20260305082131"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"##### "},{"Type":"NodeText","Data":"18.3.1 案例1(用户登录)"}]},{"ID":"20260305082131-bhy64br","Type":"NodeParagraph","Properties":{"id":"20260305082131-bhy64br","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"需求：如图所示，做出界面"}]},{"ID":"20260305082131-j7w46eh","Type":"NodeParagraph","Properties":{"id":"20260305082131-j7w46eh","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"提示：给出的数据就是按照组件位置和大小给出的"}]},{"ID":"20260305082131-uszf23f","Type":"NodeParagraph","Properties":{"id":"20260305082131-uszf23f","updated":"20260305082131"},"Children":[{"Type":"NodeImage","Children":[{"Type":"NodeBang","Data":"!"},{"Type":"NodeOpenBracket","Data":"["},{"Type":"NodeLinkText","Data":"外链图片转存失败,源站可能有防盗链机制,建议将图片保存下来直接上传"},{"Type":"NodeCloseBracket","Data":"]"},{"Type":"NodeOpenParen","Data":"("},{"Type":"NodeLinkDest","Data":"https://i-blog.csdnimg.cn/direct/df90a1ee288b4b14a8f00ce699bcb355.png"},{"Type":"NodeCloseParen","Data":")"}]}]},{"ID":"20260305082131-zqajy3q","Type":"NodeParagraph","Properties":{"id":"20260305082131-zqajy3q","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"首先，我们来简单的分析一下："}]},{"ID":"20260305082131-vsqtvfu","Type":"NodeParagraph","Properties":{"id":"20260305082131-vsqtvfu","updated":"20260305082131"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"分析："}]},{"ID":"202603050821