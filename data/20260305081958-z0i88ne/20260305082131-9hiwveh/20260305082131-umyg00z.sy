":"20260305082131-otchdrd","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"当然了，还有很多其他的成员方法，只不过，目前我们暂时用不上，后面用的时候再讲。"}]},{"ID":"20260305082131-e16hft1","Type":"NodeParagraph","Properties":{"id":"20260305082131-e16hft1","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"下面，我们就来学习一下字符串类String，最后完成用户登录案例和聊天室案例。"}]},{"ID":"20260305082131-fjbfz4i","Type":"NodeParagraph","Properties":{"id":"20260305082131-fjbfz4i","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"而关于String类呢，我们先到帮助文档中去查看，然后回来总结，最后到IDEA中去演示。"}]},{"ID":"20260305082131-wgsf2j4","Type":"NodeParagraph","Properties":{"id":"20260305082131-wgsf2j4","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"来，打开我们准备好的帮助文档，关于通过帮助文档查看String，大家按照老师讲解的API的使用步骤看看即可。"}]},{"ID":"20260305082131-e5era1o","Type":"NodeParagraph","Properties":{"id":"20260305082131-e5era1o","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"通过文档了解了String类之后，下面我们回到资料中总结一下："}]},{"ID":"20260305082131-1bzjpgp","Type":"NodeParagraph","Properties":{"id":"20260305082131-1bzjpgp","updated":"20260305082131"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"String："}]},{"ID":"20260305082131-8xt29h9","Type":"NodeList","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20260305082131-8xt29h9","updated":"20260305082131"},"Children":[{"ID":"20260305082131-91fy54k","Type":"NodeListItem","Data":"-","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20260305082131-91fy54k","updated":"20260305082131"},"Children":[{"ID":"20260305082131-rpy8hdu","Type":"NodeParagraph","Properties":{"id":"20260305082131-rpy8hdu","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"String类表示字符串。 Java程序中的所有字符串文字（例如\"abc\" ）都实现为此类的实例"}]}]}]},{"ID":"20260305082131-bk7zr7f","Type":"NodeParagraph","Properties":{"id":"20260305082131-bk7zr7f","updated":"20260305082131"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"构造方法："}]},{"ID":"20260305082131-cmhmt0v","Type":"NodeList","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20260305082131-cmhmt0v","updated":"20260305082131"},"Children":[{"ID":"20260305082131-zyg4qu4","Type":"NodeListItem","Data":"-","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20260305082131-zyg4qu4","updated":"20260305082131"},"Children":[{"ID":"20260305082131-h1cbx7q","Type":"NodeParagraph","Properties":{"id":"20260305082131-h1cbx7q","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"String()：初始化新创建的 String对象，使其表示空字符序列"}]}]},{"ID":"20260305082131-lml2a83","Type":"NodeListItem","Data":"-","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20260305082131-lml2a83","updated":"20260305082131"},"Children":[{"ID":"20260305082131-bsj9t1e","Type":"NodeParagraph","Properties":{"id":"20260305082131-bsj9t1e","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"String(String original)：初始化新创建的String对象，使其表示与参数相同的字符序列"}]}]}]},{"ID":"20260305082131-sg82kyj","Type":"NodeParagraph","Properties":{"id":"20260305082131-sg82kyj","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"知道了String的构造方法后，我们到IDEA中去使用一下："}]},{"ID":"20260305082131-0ajni08","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"amF2YQ==","CodeBlockCloseFence":"YGBg","Properties":{"id":"20260305082131-0ajni08","updated":"20260305082131"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"amF2YQ=="},{"Type":"NodeCodeBlockCode","Data":"/*\n    String类表示字符串。 Java程序中的所有字符串文字（例如\"abc\" ）都实现为此类的实例\n\n    构造方法：\n        String()：初始化新创建的 String对象，使其表示空字符序列\n        String(String original)：初始化新创建的String对象，使其表示与参数相同的字符序列\n */\npublic class StringDemo01 {\n    public static void main(String[] args) {\n        //String()：初始化新创建的 String对象，使其表示空字符序列\n        String s1 = new String();\n        System.out.println(s1);\n        //int length() 返回此字符串的长度\n        System.out.println(s1.length());\n        System.out.println(\"------------\");\n\n        //String(String original)：初始化新创建的String对象，使其表示与参数相同的字符序列\n        String s2 = new String(\"itheima\");\n        System.out.println(s2);\n        System.out.println(s2.length());\n        System.out.println(\"------------\");\n\n        //Java程序中的所有字符串文字（例如\"abc\" ）都实现为此类的实例\n        String s3 = \"itheima\";\n        System.out.println(s3);\n        System.out.println(s3.length());\n    }\n}\n12345678910111213141516171819202122232425262728\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3}]},{"ID":"20260305082131-oc1rlrl","Type":"NodeHeading","HeadingLevel":4,"Properties":{"id":"20260305082131-oc1rlrl","updated":"20260305082131"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"#### "},{"Type":"NodeText","Data":"19.2 String(成员方法)"}]},{"ID":"20260305082131-65qbbx8","Type":"NodeParagraph","Properties":{"id":"20260305082131-65qbbx8","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"下面我们来学习String类中常用的成员方法："}]},{"ID":"20260305082131-0euvwta","Type":"NodeList","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20260305082131-0euvwta","updated":"20260305082131"},"Children":[{"ID":"20260305082131-wq7txg3","Type":"NodeListItem","Data":"-","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20260305082131-wq7txg3","updated":"20260305082131"},"Children":[{"ID":"20260305082131-swyja6r","Type":"NodeParagraph","Properties":{"id":"20260305082131-swyja6r","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"int length()：返回此字符串的长度"}]}]},{"ID":"20260305082131-ho7czf6","Type":"NodeListItem","Data":"-","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20260305082131-ho7czf6","updated":"20260305082131"},"Children":[{"ID":"20260305082131-dmutrfb","Type":"NodeParagraph","Properties":{"id":"20260305082131-dmutrfb","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"boolean equals(Object anObject)：将此字符串与指定的对象进行比较"}]}]},{"ID":"20260305082131-3tlg6dg","Type":"NodeListItem","Data":"-","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20260305082131-3tlg6dg","updated":"20260305082131"},"Children":[{"ID":"20260305082131-kvc6aes","Type":"NodeParagraph","Properties":{"id":"20260305082131-kvc6aes","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"boolean equalsIgnoreCase(String anotherString)：将此 String与另一个 String比较，忽略了大小写"}]}]},{"ID":"20260305082131-07ziall","Type":"NodeListItem","Data":"-","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20260305082131-07ziall","updated":"20260305082131"},"Children":[{"ID":"20260305082131-jv1jezm","Type":"NodeParagraph","Properties":{"id":"20260305082131-jv1jezm","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"String trim()：返回一个字符串，其值为此字符串，删除了所有前导和尾随空格"}]}]}]},{"ID":"20260305082131-nzlyx7b","Type":"NodeParagraph","Properties":{"id":"20260305082131-nzlyx7b","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"而关于这几个成员方法呢，我们到IDEA中一边使用，一边讲解。"}]},{"ID":"20260305082131-ouj6toy","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"amF2YQ==","CodeBlockCloseFence":"YGBg","Properties":{"id":"20260305082131-ouj6toy","updated":"20260305082131"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"amF2YQ=="},{"Type":"NodeCodeBlockCode","Data":"/*\n    int length()：返回此字符串的长度\n    boolean equals(Object anObject)：将此字符串与指定的对象进行比较\n    boolean equalsIgnoreCase(String anotherString)：将此 String与另一个 String比较，忽略了大小写\n    String trim()：返回一个字符串，其值为此字符串，删除了所有前导和尾随空格\n */\npublic class StringDemo02 {\n    public static void main(String[] args) {\n        String s1 = \"itheima\";\n        String s2 = \"itheima\";\n        String s3 = \"Itheima\";\n\n        //boolean equals(Object anObject)：将此字符串与指定的对象进行比较\n        System.out.println(s1.equals(s2));\n        System.out.println(s1.equals(s3));\n\n        //boolean equalsIgnoreCase(String anotherString)：将此 String与另一个 String比较，忽略了大小写\n        System.out.println(s1.equalsIgnoreCase(s2));\n        System.out.println(s1.equalsIgnoreCase(s3));\n        System.out.println(\"-------------------\");\n\n        String s4 = \" itheima \";\n        //String trim()：返回一个字符串，其值为此字符串，删除了所有前导和尾随空格\n        System.out.println(s4);\n        System.out.println(s4.trim());\n\n        String s5 = \"it heima\";\n        System.out.println(s5.trim());\n    }\n}\n123456789101112131415161718192021222324252627282930\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3}]},{"ID":"20260305082131-6w4d5xv","Type":"NodeHeading","HeadingLevel":4,"Properties":{"id":"20260305082131-6w4d5xv","updated":"20260305082131"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"#### "},{"Type":"NodeText","Data":"19.3 GUI案例1(用户登录实现)"}]},{"ID":"20260305082131-ojuexjp","Type":"NodeParagraph","Properties":{"id":"20260305082131-ojuexjp","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"需求：根据下列要求，完成用户登录的逻辑，并给出相应的提示"}]},{"ID":"20260305082131-ctd08wy","Type":"NodeParagraph","Properties":{"id":"20260305082131-ctd08wy","updated":"20260305082131"},"Children":[{"Type":"NodeImage","Children":[{"Type":"NodeBang","Data":"!"},{"Type":"NodeOpenBracket","Data":"["},{"Type":"NodeLinkText","Data":"外链图片转存失败,源站可能有防盗链机制,建议将图片保存下来直接上传"},{"Type":"NodeCloseBracket","Data":"]"},{"Type":"NodeOpenParen","Data":"("},{"Type":"NodeLinkDest","Data":"https://i-blog.csdnimg.cn/direct/a2b2a7dab565401cbda464d1f1d8f9bf.png"},{"Type":"NodeCloseParen","Data":")"}]}]},{"ID":"20260305082131-wkz9ei4","Type":"NodeParagraph","Properties":{"id":"20260305082131-wkz9ei4","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"要求："}]},{"ID":"20260305082131-1ld0e4o","Type":"NodeParagraph","Properties":{"id":"20260305082131-1ld0e4o","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"① 已知的用户名和密码"}]},{"ID":"20260305082131-7wb8x3y","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"amF2YQ==","CodeBlockCloseFence":"YGBg","Properties":{"id":"20260305082131-7wb8x3y","updated":"20260305082131"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"amF2YQ=="},{"Type":"NodeCodeBlockCode","Data":"用户名：itheima\n\n密码：123456\n123\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3}]},{"ID":"20260305082131-ciq1qcp","Type":"NodeParagraph","Properties":{"id":"20260305082131-ciq1qcp","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"② 用户名和密码的长度都是6-12位"}]},{"ID":"20260305082131-8u79eyy","Type":"NodeParagraph","Properties":{"id":"20260305082131-8u79eyy","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"③ 点击登录按钮"}]},{"ID":"20260305082131-3491zxv","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"amF2YQ==","CodeBlockCloseFence":"YGBg","Properties":{"id":"20260305082131-3491zxv","updated":"20260305082131"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"amF2YQ=="},{"Type":"NodeCodeBlockCode","Data":"先判断输入的用户名和密码是否符合要求\n\n再判断用户登录是否成功\n123\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3}]},{"ID":"20260305082131-wjwlp7s","Type":"NodeParagraph","Properties":{"id":"20260305082131-wjwlp7s","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"知道了用户登录案例的需求和要求后，下面我们到IDEA中去实现一下："}]},{"ID":"20260305082131-r4pp9mr","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"amF2YQ==","CodeBlockCloseFence":"YGBg","Properties":{"id":"20260305082131-r4pp9mr","updated":"20260305082131"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"amF2YQ=="},{"Type":"NodeCodeBlockCode","Data":"import javax.swing.*;\nimport java.awt.event.ActionEvent;\nimport java.awt.event.ActionListener;\n\n/*\n    1:已知的用户名和密码\n        用户名：itheima\n       密码：123456\n    2:用户名和密码的长度都是6-12位\n    3:点击登录按钮\n       先判断输入的用户名和密码是否符合要求\n       再判断用户登录是否成功\n */\npublic class UserLogin {\n    public static void main(String[] args) {\n        //创建窗体对象\n        JFrame jf = new JFrame();\n\n        jf.setTitle(\"用户登录\");\n        jf.setSize(400, 300);\n        jf.setDefaultCloseOperation(3);\n        jf.setLocationRelativeTo(null);\n        jf.setAlwaysOnTop(true);\n        jf.setLayout(null);\n\n        //显示用户名文本\n        JLabel usernameLable = new JLabel(\"用户名\");\n        usernameLable.setBounds(50, 50, 50, 20);\n        jf.add(usernameLable);\n\n        //用户名输入框\n        JTextField usernameField = new JTextField();\n        usernameField.setBounds(150, 50, 180, 20);\n        jf.add(usernameField);\n\n        //显示密码文本\n        JLabel passwordLable = new JLabel(\"密码\");\n        passwordLable.setBounds(50, 100, 50, 20);\n        jf.add(passwordLable);\n\n        //密码输入框\n        JPasswordField passwordField = new JPasswordField();\n        passwordField.setBounds(150, 100, 180, 20);\n        jf.add(passwordField);\n\n        //登录按钮\n        JButton loginButton = new JButton(\"登录\");\n        loginButton.setBounds(50, 200, 280, 20);\n        jf.add(loginButton);\n\n        //已知的用户名和密码\n        String name = \"itheima\";\n        String pwd = \"123456\";\n\n        loginButton.addActionListener(new ActionListener() {\n            @Override\n            public void actionPerformed(ActionEvent e) {\n                //获取用户输入的用户名和密码\n                String username = usernameField.getText();\n                String password = passwordField.getText();\n\n                //先判断输入的用户名和密码是否符合要求\n                //用户名和密码的长度都是6-12位\n                if(username.length()\u003c6 || username.length()\u003e12) {\n//                    System.out.println(\"用户名的长度是6-12位，请重新输入\");\n                    //静态的成员方法和成员变量是可以通过类名访问的\n                    JOptionPane.showMessageDialog(jf,\"用户名的长度是6-12位，请重新输入\");\n                    usernameField.setText(\"\");\n                    return;\n                }\n\n                //再判断用户登录是否成功\n                if(username.equals(name) \u0026\u0026 password.equals(pwd)) {\n//                    System.out.println(\"登录成功\");\n                    JOptionPane.showMessageDialog(jf,\"登录成功\");\n                    usernameField.setText(\"\");\n                    passwordField.setText(\"\");\n                } else {\n//                    System.out.println(\"用户名或者密码有误\");\n                    JOptionPane.showMessageDialog(jf,\"用户名或者密码有误\");\n                }\n            }\n        });\n\n        jf.setVisible(true);\n    }\n}\n123456789101112131415161718192021222324252627282930313233343536373839404142434445464748495051525354555657585960616263646566676869707172737475767778798081828384858687\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3}]},{"ID":"20260305082131-kmpn4kb","Type":"NodeHeading","HeadingLevel":4,"Properties":{"id":"20260305082131-kmpn4kb","updated":"20260305082131"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"#### "},{"Type":"NodeText","Data":"19.4 GUI案例2(聊天室实现)"}]},{"ID":"20260305082131-e1biijj","Type":"NodeParagraph","Properties":{"id":"20260305082131-e1biijj","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"需求：根据下列要求，完成聊天室的逻辑"}]},{"ID":"20260305082131-k9a0mdx","Type":"NodeParagraph","Properties":{"id":"20260305082131-k9a0mdx","updated":"20260305082131"},"Children":[{"Type":"NodeImage","Children":[{"Type":"NodeBang","Data":"!"},{"Type":"NodeOpenBracket","Data":"["},{"Type":"NodeLinkText","Data":"外链图片转存失败,源站可能有防盗链机制,建议将图片保存下来直接上传"},{"Type":"NodeCloseBracket","Data":"]"},{"Type":"NodeOpenParen","Data":"("},{"Type":"NodeLinkDest","Data":"https://i-blog.csdnimg.cn/direct/a0e4cb66fc034df9b8dd632b3e147b19.png"},{"Type":"NodeCloseParen","Data":")"}]}]},{"ID":"20260305082131-wfcxck5","Type":"NodeParagraph","Properties":{"id":"20260305082131-wfcxck5","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"要求："}]},{"ID":"20260305082131-c37nc9o","Type":"NodeParagraph","Properties":{"id":"20260305082131-c37nc9o","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"① 把文本框的内容发送到文本域中"}]},{"ID":"20260305082131-7dmkrmi","Type":"NodeParagraph","Properties":{"id":"20260305082131-7dmkrmi","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"② 每次发送的文本内容不带前后空格"}]},{"ID":"20260305082131-zoyauu7","Type":"NodeParagraph","Properties":{"id":"20260305082131-zoyauu7","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"③ 多次发送的内容在文本域以追加的方式呈现"}]},{"ID":"20260305082131-a3u6oqc","Type":"NodeParagraph","Properties":{"id":"20260305082131-a3u6oqc","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"④ 清空聊天就是把文本域的内容设置为空"}]},{"ID":"20260305082131-7jymdo5","Type":"NodeParagraph","Properties":{"id":"20260305082131-7jymdo5","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"知道了聊天室案例的需求和要求后，下面我们到IDEA中去实现一下："}]},{"ID":"20260305082131-ro2bz0c","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"amF2YQ==","CodeBlockCloseFence":"YGBg","Properties":{"id":"20260305082131-ro2bz0c","updated":"20260305082131"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"amF2YQ=="},{"Type":"NodeCodeBlockCode","Data":"import javax.swing.*;\nimport java.awt.event.ActionEvent;\nimport java.awt.event.ActionListener;\n\n/*\n    1:把文本框的内容发送到文本域中\n    2:每次发送的文本内容不带前后空格\n    3:多次发送的内容在文本域以追加的方式呈现\n    4:清空聊天就是把文本域的内容设置为空\n */\npublic class ChatRoom {\n    public static void main(String[] args) {\n        //创建窗体对象\n        JFrame jf = new JFrame();\n\n        jf.setTitle(\"聊天室\");\n        jf.setSize(400, 300);\n        jf.setDefaultCloseOperation(3);\n        jf.setLocationRelativeTo(null);\n        jf.setAlwaysOnTop(true);\n        jf.setLayout(null);\n\n        //显示聊天信息的文本域\n        JTextArea messageArea = new JTextArea();\n        messageArea.setBounds(10, 10, 360, 200);\n        jf.add(messageArea);\n\n        //输入聊天信息的文本框\n        JTextField messageField = new JTextField();\n        messageField.setBounds(10, 230, 180, 20);\n        jf.add(messageField);\n\n        //发送按钮\n        JButton sendButton = new JButton(\"发送\");\n        sendButton.setBounds(200, 230, 70, 20);\n        jf.add(sendButton);\n\n        //清空聊天按钮\n        JButton clearButton = new JButton(\"清空聊天\");\n        clearButton.setBounds(280, 230, 100, 20);\n        jf.add(clearButton);\n\n        sendButton.addActionListener(new ActionListener() {\n            @Override\n            public void actionPerformed(ActionEvent e) {\n                //获取文本框的内容\n//                String message = messageField.getText();\n//                messageField.setText(\"\");\n\n                //每次发送的文本内容不带前后空格\n//                String message = messageField.getText();\n//                message = message.trim();\n                String message = messageField.getText().trim(); //链式调用\n                messageField.setText(\"\");\n\n                //把文本框的内容发送到文本域中\n//                messageArea.setText(message);\n                //多次发送的内容在文本域以追加的方式呈现\n                messageArea.append(message+\"\\n\");\n            }\n        });\n\n        clearButton.addActionListener(new ActionListener() {\n            @Override\n            public void actionPerformed(ActionEvent e) {\n                //清空聊天就是把文本域的内容设置为空\n                messageArea.setText(\"\");\n            }\n        });\n\n        jf.setVisible(true);\n    }\n}\n1234567891011121314151617181920212223242526272829303132333435363738394041424344454647484950515253545556575859606162636465666768697071727374\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3}]},{"ID":"20260305082131-10u1t3p","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20260305082131-10u1t3p","updated":"20260305082131"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"### "},{"Type":"NodeText","Data":"20：Integer"}]},{"ID":"20260305082131-g0yc8gj","Type":"NodeHeading","HeadingLevel":4,"Properties":{"id":"20260305082131-g0yc8gj","updated":"20260305082131"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"#### "},{"Type":"NodeText","Data":"20.1 Integer(构造方法)"}]},{"ID":"20260305082131-7sn5x55","Type":"NodeParagraph","Properties":{"id":"20260305082131-7sn5x55","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"下面我们来学习基本类型包装类，它涉及到1个案例：猜数字。"}]},{"ID":"20260305082131-68og85c","Type":"NodeParagraph","Properties":{"id":"20260305082131-68og85c","updated":"20260305082131"},"Children":[{"Type":"NodeImage","Children":[{"Type":"NodeBang","Data":"!"},{"Type":"NodeOpenBracket","Data":"["},{"Type":"NodeLinkText","Data":"外链图片转存失败,源站可能有防盗链机制,建议将图片保存下来直接上传"},{"Type":"NodeCloseBracket","Data":"]"},{"Type":"NodeOpenParen","Data":"("},{"Type":"NodeLinkDest","Data":"https://i-blog.csdnimg.cn/direct/a9b76f1911cf4e5b93fdc4afc0c78bc7.png"},{"Type":"NodeCloseParen","Data":")"}]}]},{"ID":"20260305082131-xwsvi8v","Type":"NodeParagraph","Properties":{"id":"20260305082131-xwsvi8v","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"来，我们一起看一下，在这个输入框里，我们要输入一个猜的数据，然后点击我猜这个按钮，和已经产生的数据进行比对，给出相应的提示即可。"}]},{"ID":"20260305082131-sj3pvix","Type":"NodeParagraph","Properties":{"id":"20260305082131-sj3pvix","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"而且呢，猜数字案例的基本逻辑，我们前面是讲解过的，只不过当时使用的是键盘录入数据，而这里我们采用的是在输入框里输入数据而已。"}]},{"ID":"20260305082131-2reb82b","Type":"NodeParagraph","Properties":{"id":"20260305082131-2reb82b","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"那我们为什么要学习基本类型包装类呢？"}]},{"ID":"20260305082131-cy5hrno","Type":"NodeParagraph","Properties":{"id":"20260305082131-cy5hrno","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"因为，在输入框里输入的数据，我们得到的是一个字符串数据，而实际比较的时候我们需要的是一个int类型的数据，所以，我们得想办法把字符串数据转换为int类型的数据。"}]},{"ID":"20260305082131-650b680","Type":"NodeParagraph","Properties":{"id":"20260305082131-650b680","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"为了实现这个效果，Java就提供了基本类型包装类供我们使用。所以，我们说，将基本数据类型封装成对象的好处就是可以通过对象调用方法操作数据。"}]},{"ID":"20260305082131-3buu5gz","Type":"NodeParagraph","Properties":{"id":"20260305082131-3buu5gz","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"而我们常用的操作之一呢：就是用于基本数据类型与字符串之间的转换。"}]},{"ID":"20260305082131-9pgunvs","Type":"NodeParagraph","Properties":{"id":"20260305082131-9pgunvs","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"在这里呢，我们一起来看一下，八种基本数据类型和其对应的包装类类型"}]},{"ID":"20260305082131-tvabs8m","Type":"NodeParagraph","Properties":{"id":"20260305082131-tvabs8m","updated":"20260305082131"},"Children":[{"Type":"NodeImage","Children":[{"Type":"NodeBang","Data":"!"},{"Type":"NodeOpenBracket","Data":"["},{"Type":"NodeLinkText","Data":"外链图片转存失败,源站可能有防盗链机制,建议将图片保存下来直接上传"},{"Type":"NodeCloseBracket","Data":"]"},{"Type":"NodeOpenParen","Data":"("},{"Type":"NodeLinkDest","Data":"https://i-blog.csdnimg.cn/direct/771931894600436cb837049cf6813da6.png"},{"Type":"NodeCloseParen","Data":")"}]}]},{"ID":"20260305082131-jk8ifbn","Type":"NodeParagraph","Properties":{"id":"20260305082131-jk8ifbn","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"从名字上看，包装类类型就是把基本类型的第一个单词改为大写即可。"}]},{"ID":"20260305082131-1yhyveo","Type":"NodeParagraph","Properties":{"id":"20260305082131-1yhyveo","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"当然，这里也有两个比较特殊的，一个是int类型的包装类，一个是字符类型的包装类，它们的包装类名称是这个样子的，大家了解一下即可。"}]},{"ID":"20260305082131-ydteja7","Type":"NodeParagraph","Properties":{"id":"20260305082131-ydteja7","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"下面呢，我们以Integer举例来讲解字符串和int类型之间的相互转换，其他基本类型和字符串的转换方式类似，在使用的时候，大家参照Integer的使用即可。"}]},{"ID":"20260305082131-i8vpqlr","Type":"NodeParagraph","Properties":{"id":"20260305082131-i8vpqlr","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"而关于Integer类的学习呢，我们先到帮助文档中去查看，然后回来总结，最后到IDEA中去演示。"}]},{"ID":"20260305082131-yc9ayp0","Type":"NodeParagraph","Properties":{"id":"20260305082131-yc9ayp0","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"来，打开我们准备好的帮助文档，关于通过帮助文档查看Integer，大家按照老师讲解的API的使用步骤看看即可。"}]},{"ID":"20260305082131-dgyupkm","Type":"NodeParagraph","Properties":{"id":"20260305082131-dgyupkm","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"通过文档了解了Integer类之后，下面我们回到资料中总结一下："}]},{"ID":"20260305082131-qgyu956","Type":"NodeParagraph","Properties":{"id":"20260305082131-qgyu956","updated":"20260305082131"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"Integer："}]},{"ID":"20260305082131-19ekhfs","Type":"NodeList","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20260305082131-19ekhfs","updated":"20260305082131"},"Children":[{"ID":"20260305082131-fbg2q0d","Type":"NodeListItem","Data":"-","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20260305082131-fbg2q0d","updated":"20260305082131"},"Children":[{"ID":"20260305082131-1k4umcg","Type":"NodeParagraph","Properties":{"id":"20260305082131-1k4umcg","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"Integer类在对象中包装基本类型int的值"}]}]}]},{"ID":"20260305082131-17qu01r","Type":"NodeParagraph","Properties":{"id":"20260305082131-17qu01r","updated":"20260305082131"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"构造方法："}]},{"ID":"20260305082131-f5p8q5q","Type":"NodeList","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20260305082131-f5p8q5q","updated":"20260305082131"},"Children":[{"ID":"20260305082131-3atxwz1","Type":"NodeListItem","Data":"-","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20260305082131-3atxwz1","updated":"20260305082131"},"Children":[{"ID":"20260305082131-ffdfod0","Type":"NodeParagraph","Properties":{"id":"20260305082131-ffdfod0","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"Integer(int value)：根据 int 值创建 Integer 对象(过时)"}]}]},{"ID":"20260305082131-4rs4rz7","Type":"NodeListItem","Data":"-","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20260305082131-4rs4rz7","updated":"20260305082131"},"Children":[{"ID":"20260305082131-4i35i3e","Type":"NodeParagraph","Properties":{"id":"20260305082131-4i35i3e","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"Integer(String s)：根据 String 值创建 Integer 对象(过时)"}]}]}]},{"ID":"20260305082131-zslrsxv","Type":"NodeParagraph","Properties":{"id":"20260305082131-zslrsxv","updated":"20260305082131"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"成员方法："}]},{"ID":"20260305082131-uupyh22","Type":"NodeList","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20260305082131-uupyh22","updated":"20260305082131"},"Children":[{"ID":"20260305082131-je4k4xz","Type":"NodeListItem","Data":"-","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20260305082131-je4k4xz","updated":"20260305082131"},"Children":[{"ID":"20260305082131-ss65qo9","Type":"NodeParagraph","Properties":{"id":"20260305082131-ss65qo9","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"static Integer valueOf(int i)：返回表示指定的 int 值的 Integer 实例"}]}]},{"ID":"20260305082131-gfwbwo4","Type":"NodeListItem","Data":"-","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20260305082131-gfwbwo4","updated":"20260305082131"},"Children":[{"ID":"20260305082131-icc2yul","Type":"NodeParagraph","Properties":{"id":"20260305082131-icc2yul","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"static Integer valueOf(String s)：返回一个保存指定值的 Integer 对象 String"}]}]}]},{"ID":"20260305082131-ph135wr","Type":"NodeParagraph","Properties":{"id":"20260305082131-ph135wr","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"知道了Integer的构造方法后，我们到IDEA中去使用一下："}]},{"ID":"20260305082131-t1xicnd","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"amF2YQ==","CodeBlockCloseFence":"YGBg","Properties":{"id":"20260305082131-t1xicnd","updated":"20260305082131"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"amF2YQ=="},{"Type":"NodeCodeBlockCode","Data":"/*\n    构造方法\n        Integer(int value)：根据 int 值创建 Integer 对象(过时)\n        Integer(String s)：根据 String 值创建 Integer 对象(过时)\n\n    成员方法\n        static Integer valueOf(int i)：返回表示指定的 int 值的 Integer 实例\n        static Integer valueOf(String s)：返回一个保存指定值的 Integer 对象 String\n */\npublic class IntegerDemo01 {\n    public static void main(String[] args) {\n//        //Integer(int value)：根据 int 值创建 Integer 对象(过时)\n//        Integer i1 = new Integer(100);\n//        System.out.println(i1);\n//\n//        //Integer(String s)：根据 String 值创建 Integer 对象(过时)\n//        Integer i2 = new Integer(\"100\");\n//        System.out.println(i2);\n\n//        static Integer valueOf(int i)：返回表示指定的 int 值的 Integer 实例\n//        static Integer valueOf(String s)：返回一个保存指定值的 Integer 对象 String\n        Integer i1 = Integer.valueOf(100);\n        Integer i2 = Integer.valueOf(\"100\");\n        System.out.println(i1);\n        System.out.println(i2);\n    }\n}\n123456789101112131415161718192021222324252627\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3}]},{"ID":"20260305082131-0xpbfjp","Type":"NodeHeading","HeadingLevel":4,"Properties":{"id":"20260305082131-0xpbfjp","updated":"20260305082131"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"#### "},{"Type":"NodeText","Data":"20.2 Integer(int和String的相互转换)"}]},{"ID":"20260305082131-jz51x7t","Type":"NodeParagraph","Properties":{"id":"20260305082131-jz51x7t","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"下面我们来学习int类型数据和String类型数据的相互转换，关于它们之间的相互转换，我们先到IDEA中去讲解，然后回来总结。"}]},{"ID":"20260305082131-p2qmx3z","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"amF2YQ==","CodeBlockCloseFence":"YGBg","Properties":{"id":"20260305082131-p2qmx3z","updated":"20260305082131"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"amF2YQ=="},{"Type":"NodeCodeBlockCode","Data":"/*\n    int和String的相互转换\n */\npublic class IntegerDemo02 {\n    public static void main(String[] args) {\n        //int --- String\n        int number = 100;\n        //方式1\n        String s1 = number + \"\";\n        System.out.println(s1);\n        //方式2\n        //static String valueOf(int i)\n        String s2 = String.valueOf(number);\n        System.out.println(s2);\n        System.out.println(\"---------------\");\n\n        //String --- int\n        String s = \"100\";\n        //方式1：String --- Integer --- int\n        Integer i = Integer.valueOf(s);\n        //int intValue() 返回此值 Integer为 int\n        int x = i.intValue();\n        System.out.println(x);\n        //方式2\n        //static int parseInt(String s)\n        int y = Integer.parseInt(s);\n        System.out.println(y);\n    }\n}\n1234567891011121314151617181920212223242526272829\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3}]},{"ID":"20260305082131-mk4hq2d","Type":"NodeParagraph","Properties":{"id":"20260305082131-mk4hq2d","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"讲解完毕int类型和String类型的相互转换后，回到资料总结一下："}]},{"ID":"20260305082131-qac4gog","Type":"NodeList","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20260305082131-qac4gog","updated":"20260305082131"},"Children":[{"ID":"20260305082131-3ekstws","Type":"NodeListItem","Data":"-","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20260305082131-3ekstws","updated":"20260305082131"},"Children":[{"ID":"20260305082131-u2vbcxd","Type":"NodeParagraph","Properties":{"id":"20260305082131-u2vbcxd","updated":"20260305082131"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"int 转换为 String"}]},{"ID":"20260305082131-cfuczab","Type":"NodeList","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"MarkerOffset":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20260305082131-cfuczab","updated":"20260305082131"},"Children":[{"ID":"20260305082131-knq9og1","Type":"NodeListItem","Data":"-","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"MarkerOffset":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20260305082131-knq9og1","updated":"20260305082131"},"Children":[{"ID":"20260305082131-mkxn4aa","Type":"NodeParagraph","Properties":{"id":"20260305082131-mkxn4aa","updated":"20260305082131"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"static String valueOf(int i)："},{"Type":"NodeText","Data":" 返回 int 参数的字符串表示形式。该方法是 String 类中的方法"}]}]}]}]},{"ID":"20260305082131-68499ul","Type":"NodeListItem","Data":"-","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20260305082131-68499ul","updated":"20260305082131"},"Children":[{"ID":"20260305082131-ejv8vk9","Type":"NodeParagraph","Properties":{"id":"20260305082131-ejv8vk9","updated":"20260305082131"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"String 转换为 int"}]},{"ID":"20260305082131-2x77awp","Type":"NodeList","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"MarkerOffset":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20260305082131-2x77awp","updated":"20260305082131"},"Children":[{"ID":"20260305082131-lhan1kc","Type":"NodeListItem","Data":"-","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"MarkerOffset":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20260305082131-lhan1kc","updated":"20260305082131"},"Children":[{"ID":"20260305082131-4i2hfyu","Type":"NodeParagraph","Properties":{"id":"20260305082131-4i2hfyu","updated":"20260305082131"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"static int parseInt(String s)："},{"Type":"NodeText","Data":" 将字符串解析为 int 类型。该方法是 Integer 类中的方法"}]}]}]}]}]},{"ID":"20260305082131-no1difb","Type":"NodeParagraph","Properties":{"id":"20260305082131-no1difb","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"好了，int类型数据和String类型数据的相互转换我们就先讲到这里。"}]},{"ID":"20260305082131-xzd6lpz","Type":"NodeHeading","HeadingLevel":4,"Properties":{"id":"20260305082131-xzd6lpz","updated":"20260305082131"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"#### "},{"Type":"NodeText","Data":"20.3 GUI案例3(猜数字实现)"}]},{"ID":"20260305082131-edpgh60","Type":"NodeParagraph","Properties":{"id":"20260305082131-edpgh60","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"需求：根据下列要求，完成猜数字的逻辑"}]},{"ID":"20260305082131-17bfig2","Type":"NodeParagraph","Properties":{"id":"20260305082131-17bfig2","updated":"20260305082131"},"Children":[{"Type":"NodeImage","Children":[{"Type":"NodeBang","Data":"!"},{"Type":"NodeOpenBracket","Data":"["},{"Type":"NodeLinkText","Data":"外链图片转存失败,源站可能有防盗链机制,建议将图片保存下来直接上传"},{"Type":"NodeCloseBracket","Data":"]"},{"Type":"NodeOpenParen","Data":"("},{"Type":"NodeLinkDest","Data":"https://i-blog.csdnimg.cn/direct/c087ace72b5c4e0191bcd859f19275df.png"},{"Type":"NodeCloseParen","Data":")"}]}]},{"ID":"20260305082131-4xpmezq","Type":"NodeParagraph","Properties":{"id":"20260305082131-4xpmezq","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"要求："}]},{"ID":"20260305082131-ar2q7ka","Type":"NodeParagraph","Properties":{"id":"20260305082131-ar2q7ka","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"① 系统产生一个1-100之间的随机数"}]},{"ID":"20260305082131-ppqw7o7","Type":"NodeParagraph","Properties":{"id":"20260305082131-ppqw7o7","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"② 猜的内容不能为空"}]},{"ID":"20260305082131-bzdk2jn","Type":"NodeParagraph","Properties":{"id":"20260305082131-bzdk2jn","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"③ 每次根据猜的数字给出相应的提示"}]},{"ID":"20260305082131-zl5fups","Type":"NodeParagraph","Properties":{"id":"20260305082131-zl5fups","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"知道了猜数字案例的需求和要求后，下面我们到IDEA中去实现一下："}]},{"ID":"20260305082131-pk3nmzj","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"amF2YQ==","CodeBlockCloseFence":"YGBg","Properties":{"id":"20260305082131-pk3nmzj","updated":"20260305082131"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"amF2YQ=="},{"Type":"NodeCodeBlockCode","Data":"import javax.swing.*;\nimport java.awt.event.ActionEvent;\nimport java.awt.event.ActionListener;\nimport java.util.Random;\n\n/*\n    1:系统产生一个1-100之间的随机数\n    2:猜的内容不能为空\n    3:每次根据猜的数字给出相应的提示\n*/\npublic class GuessNumber {\n    public static void main(String[] args) {\n        //创建窗体对象\n        JFrame jf = new JFrame();\n\n        jf.setTitle(\"猜数字\");\n        jf.setSize(400, 300);\n        jf.setDefaultCloseOperation(3);\n        jf.setLocationRelativeTo(null);\n        jf.setAlwaysOnTop(true);\n        jf.setLayout(null);\n\n        //系统产生一个1-100之间的随机数\n        Random r = new Random();\n        int number = r.nextInt(100) + 1;\n\n        //提示信息\n        JLabel messageLable = new JLabel(\"系统产生了一个1-100之间的数据，请猜一猜\");\n        messageLable.setBounds(70, 50, 350, 20);\n        jf.add(messageLable);\n\n        //输入要猜的数字\n        JTextField numberField = new JTextField();\n        numberField.setBounds(120, 100, 150, 20);\n        jf.add(numberField);\n\n        //猜数字的按钮\n        JButton guessButton = new JButton(\"我猜\");\n        guessButton.setBounds(150, 150, 100, 20);\n        jf.add(guessButton);\n\n        guessButton.addActionListener(new ActionListener() {\n            @Override\n            public void actionPerformed(ActionEvent e) {\n                //猜的内容不能为空\n                String stringNumber = numberField.getText().trim();\n                if(stringNumber.equals(\"\")) {\n                    JOptionPane.showMessageDialog(jf,\"猜的数字不能为空\");\n                    return;\n                }\n\n                //每次根据猜的数字给出相应的提示\n                int guessNumber = Integer.parseInt(stringNumber);\n\n                if(guessNumber \u003e number) {\n                    JOptionPane.showMessageDialog(jf,\"你猜的数字\"+guessNumber+\"大了\");\n                    numberField.setText(\"\");\n                } else if(guessNumber \u003c number) {\n                    JOptionPane.showMessageDialog(jf,\"你猜的数字\"+guessNumber+\"小了\");\n                    numberField.setText(\"\");\n                } else  {\n                    JOptionPane.showMessageDialog(jf,\"恭喜你猜中了\");\n                }\n            }\n        });\n\n        jf.setVisible(true);\n    }\n}\n123456789101112131415161718192021222324252627282930313233343536373839404142434445464748495051525354555657585960616263646566676869\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3}]},{"ID":"20260305082131-g2sbklf","Type":"NodeHeading","HeadingLevel":4,"Properties":{"id":"20260305082131-g2sbklf","updated":"20260305082131"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"#### "},{"Type":"NodeText","Data":"20.4 Integer(自动装箱和拆箱)"}]},{"ID":"20260305082131-284pgk7","Type":"NodeParagraph","Properties":{"id":"20260305082131-284pgk7","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"下面我们来学习自动装箱和拆箱。"}]},{"ID":"20260305082131-2xhkfyw","Type":"NodeParagraph","Properties":{"id":"20260305082131-2xhkfyw","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"首先，我们来说一下什么是装箱和拆箱："}]},{"ID":"20260305082131-zbdzjff","Type":"NodeList","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20260305082131-zbdzjff","updated":"20260305082131"},"Children":[{"ID":"20260305082131-b0jweuw","Type":"NodeListItem","Data":"-","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20260305082131-b0jweuw","updated":"20260305082131"},"Children":[{"ID":"20260305082131-1lt0tft","Type":"NodeParagraph","Properties":{"id":"20260305082131-1lt0tft","updated":"20260305082131"},"Children":[{"Type":"NodeBackslash","Children":[{"Type":"NodeBackslashContent","Data":"*"}]},{"Type":"NodeBackslash","Children":[{"Type":"NodeBackslashContent","Data":"*"}]},{"Type":"NodeText","Data":"装箱："},{"Type":"NodeBackslash","Children":[{"Type":"NodeBackslashContent","Data":"*"}]},{"Type":"NodeBackslash","Children":[{"Type":"NodeBackslashContent","Data":"*"}]},{"Type":"NodeText","Data":"把基本数据类型转换为对应的包装类类型"}]}]},{