  jf.add(passwordLable);\n\n        //密码输入框\n//        JTextField passwordField = new JTextField();\n//        passwordField.setBounds(150,100,180,20);\n//        jf.add(passwordField);\n\n        JPasswordField passwordField = new JPasswordField();\n        passwordField.setBounds(150,100,180,20);\n        jf.add(passwordField);\n\n        //登录按钮\n        JButton loginButton = new JButton(\"登录\");\n        loginButton.setBounds(50,200,280,20);\n        jf.add(loginButton);\n\n        jf.setVisible(true);\n    }\n}\n12345678910111213141516171819202122232425262728293031323334353637383940414243444546474849\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3}]},{"ID":"20260305082131-65quq3j","Type":"NodeParagraph","Properties":{"id":"20260305082131-65quq3j","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"在讲解的过程中，引入了一个新的组件JPasswordField，用来表示密码框。"}]},{"ID":"20260305082131-dqyxoeq","Type":"NodeHeading","HeadingLevel":5,"Properties":{"id":"20260305082131-dqyxoeq","updated":"20260305082131"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"##### "},{"Type":"NodeText","Data":"18.3.2 案例2(聊天室)"}]},{"ID":"20260305082131-8se9ohz","Type":"NodeParagraph","Properties":{"id":"20260305082131-8se9ohz","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"需求：如图所示，做出界面"}]},{"ID":"20260305082131-0j3te68","Type":"NodeParagraph","Properties":{"id":"20260305082131-0j3te68","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"提示：给出的数据就是按照组件位置和大小给出的"}]},{"ID":"20260305082131-v2cw293","Type":"NodeParagraph","Properties":{"id":"20260305082131-v2cw293","updated":"20260305082131"},"Children":[{"Type":"NodeImage","Children":[{"Type":"NodeBang","Data":"!"},{"Type":"NodeOpenBracket","Data":"["},{"Type":"NodeLinkText","Data":"外链图片转存失败,源站可能有防盗链机制,建议将图片保存下来直接上传"},{"Type":"NodeCloseBracket","Data":"]"},{"Type":"NodeOpenParen","Data":"("},{"Type":"NodeLinkDest","Data":"https://i-blog.csdnimg.cn/direct/aafbaa2ec0a84759b2ddc815c9323