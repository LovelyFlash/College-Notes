4=","Num":2},"Properties":{"id":"20260305082131-7ximr82","updated":"20260305082131"},"Children":[{"ID":"20260305082131-a97njjy","Type":"NodeParagraph","Properties":{"id":"20260305082131-a97njjy","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"while循环"}]}]},{"ID":"20260305082131-il112cm","Type":"NodeListItem","Data":"3.","ListData":{"Typ":1,"Tight":true,"Start":3,"Delimiter":46,"Padding":3,"Marker":"My4=","Num":3},"Properties":{"id":"20260305082131-il112cm","updated":"20260305082131"},"Children":[{"ID":"20260305082131-7cfgetw","Type":"NodeParagraph","Properties":{"id":"20260305082131-7cfgetw","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"do…while循环"}]}]}]},{"ID":"20260305082131-9n8frd5","Type":"NodeParagraph","Properties":{"id":"20260305082131-9n8frd5","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"这三种循环可以做相同的事情，当然它们也有小的区别，至于它们的应用及区别，我们后面会详细讲解。这里我们来学习for循环"}]},{"ID":"20260305082131-fpxoc7q","Type":"NodeHeading","HeadingLevel":4,"Properties":{"id":"20260305082131-fpxoc7q","updated":"20260305082131"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"#### "},{"Type":"NodeText","Data":"6.1 for循环结构"}]},{"ID":"20260305082131-ea166d4","Type":"NodeParagraph","Properties":{"id":"20260305082131-ea166d4","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"而在讲解for循环格式之前，我们先来看一下前面我们讲过的一个内容：这段代码的作用，是用来展示手机信息1000次。"}]},{"ID":"20260305082131-xpedefn","Type":"NodeParagraph","Properties":{"id":"20260305082131-xpedefn","updated":"20260305082131"},"Children":[{"Type":"NodeImage","Children":[{"Type":"NodeBang","Data":"!"},{"Type":"NodeOpenBracket","Data":"["},{"Type":"NodeLinkText","Data":"外链图片转存失败,源站可能有防盗链机制,建议将图片保存下来直接上传"},{"Type":"NodeCloseBracket","Data":"]"},{"Type":"NodeOpenParen","Data":"("},{"Type":"NodeLinkDest","Data":"https://i-blog.csdnimg.cn/direct/5fca53f4c96f4cea8a29f85d67ff950b.png"},{"Type":"NodeCloseParen","Data":")"}]}]},{"ID":"20260305082131-qy8wmbk","Type":"NodeParagraph","Properties":{"id":"