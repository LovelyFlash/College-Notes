 \u0026gt; src \u0026gt; main \u0026gt; resources \u0026gt; base \u0026gt; profile"},{"Type":"NodeText","Data":" ”，在main"},{"Type":"NodeBackslash","Children":[{"Type":"NodeBackslashContent","Data":"_"}]},{"Type":"NodeText","Data":"pages.json文件中的“src”下配置第二个页面的路由“pages/Second”。示例如下："}]},{"ID":"20260305082131-x7o8xf9","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"dHlwZXNjcmlwdA==","CodeBlockCloseFence":"YGBg","Properties":{"id":"20260305082131-x7o8xf9","updated":"20260305082131"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"dHlwZXNjcmlwdA=="},{"Type":"NodeCodeBlockCode","Data":"//main_pages.json文件内容\n\n{\n\n  \"src\": [\n\n    \"pages/Index\",\n\n    \"pages/Second\"\n\n  ]\n\n}\nTypeScript\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3}]},{"ID":"20260305082131-2nog97u","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20260305082131-2nog97u","updated":"20260305082131"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"### "},{"Type":"NodeText","Data":"4.ArkUI组件"}]},{"ID":"20260305082131-7zue9wr","Type":"NodeParagraph","Properties":{"id":"20260305082131-7zue9wr","updated":"20260305082131"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"组件："},{"Type":"NodeText","Data":" UI构建与显示的最小单位，如列表、网格、按钮、单选框、进度条、文本等。开发者通过多种组件的组合，构建出满足自身应用诉求的完整界面。"}]},{"ID":"20260305082131-npppzbf","Type":"NodeHeading","HeadingLevel":4,"Properties":{"id":"20260305082131-npppzbf","updated":"20260305082131"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"#### "},{"Type":"NodeText","Data":"4.1组件基础语法"}]},{"ID":"20260305082131-yu7j21l","Type":"NodeHeading","HeadingLevel":5,"Properties":{"id":"20260305082131-yu7j21l","updated":"20260305082131"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"##### "},{"Type":"NodeText","Data":"创建组件"}]},{"ID":"20260305082131-vakp1a3","Type":"NodeParagraph","Properties":{"id":"20260305082131-vakp1a3","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"根据组件构造方法的不同，创建组件包含有参数和无参数两种方式"}]},{"ID":"20260305082131-iuke9rj","Type":"NodeParagraph","Properties":{"id":"20260305082131-iuke9rj","updated":"20260305082131"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"无参数"}]},{"ID":"20260305082131-5zt3di0","Type":"NodeParagraph","Properties":{"id":"20260305082131-5zt3di0","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"如果组件的接口定义没有包含必选构造参数，则组件后面的“()”不需要配置任何内容。"}]},{"ID":"20260305082131-fp1vk7w","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockCloseFence":"YGBg","Properties":{"id":"20260305082131-fp1vk7w","updated":"20260305082131"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3},{"Type":"NodeCodeBlockFenceInfoMarker"},{"Type":"NodeCodeBlockCode","Data":"Column() {\n\n  Text('item 1')\n\n  Divider()\n\n  Text('item 2')\n\n}\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3}]},{"ID":"20260305082131-myn0t9j","Type":"NodeParagraph","Properties":{"id":"20260305082131-myn0t9j","updated":"20260305082131"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"有参数"}]},{"ID":"20260305082131-3wlqh62","Type":"NodeParagraph","Properties":{"id":"20260305082131-3wlqh62","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"如果组件的接口定义包含构造参数，则在组件后面的“()”需要配置相应参数。"}]},{"ID":"20260305082131-rfqohos","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"dHlwZXNjcmlwdA==","CodeBlockCloseFence":"YGBg","Properties":{"id":"20260305082131-rfqohos","updated":"20260305082131"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"dHlwZXNjcmlwdA=="},{"Type":"NodeCodeBlockCode","Data":"//Image组件的必选参数src。\n\nImage('https://xyz/test.jpg')\n\n​\n\n​\n\n// Text组件string类型参数\n\nText('test')\n\n// Text组件Resource引用类型参数，$r形式引入应用资源，可应用于多语言场景\n\nText($r('app.string.title_value'))\n\n// 无参数形式\n\nText()\n\n​\n\n//变量或表达式也可以用于参数赋值，其中表达式返回的结果类型必须满足参数类型要求。\n\nImage(this.imagePath)\n\nImage('https://' + this.imageUrl)\n\nText(\\`count: ${this.count}\\`)\nTypeScript\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3}]},{"ID":"20260305082131-dfgpkuf","Type":"NodeHeading","HeadingLevel":5,"Properties":{"id":"20260305082131-dfgpkuf","updated":"20260305082131"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"##### "},{"Type":"NodeText","Data":"配置属性"}]},{"ID":"20260305082131-vyx184r","Type":"NodeParagraph","Properties":{"id":"20260305082131-vyx184r","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"属性方法以“.”链式调用的方式配置系统组件的样式和其他属性，建议每个属性方法单独写一行。"}]},{"ID":"20260305082131-7myp8l1","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockCloseFence":"YGBg","Properties":{"id":"20260305082131-7myp8l1","updated":"20260305082131"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3},{"Type":"NodeCodeBlockFenceInfoMarker"},{"Type":"NodeCodeBlockCode","Data":"​\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3}]},{"ID":"20260305082131-xbd7e5z","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"dHlwZXNjcmlwdA==","CodeBlockCloseFence":"YGBg","Properties":{"id":"20260305082131-xbd7e5z","updated":"20260305082131"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"dHlwZXNjcmlwdA=="},{"Type":"NodeCodeBlockCode","Data":"//配置组件的一个属性。\n\nText('test')\n\n  .fontSize(12)\n\n​\n\n//配置组件的多个属性。\n\nImage('test.jpg')\n\n  .alt('error.jpg')    \n\n  .width(100)    \n\n  .height(100)\n\n​\n\n//除了直接传递常量参数外，还可以传递变量或表达式\n\nText('hello')\n\n  .fontSize(this.size)\n\nImage('test.jpg')\n\n  .width(this.count % 2 === 0 ? 100 : 200)    \n\n  .height(this.offset + 100)\nTypeScript\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3}]},{"ID":"20260305082131-4dql8w6","Type":"NodeHeading","HeadingLevel":5,"Properties":{"id":"20260305082131-4dql8w6","updated":"20260305082131"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"##### "},{"Type":"NodeText","Data":"配置事件"}]},{"ID":"20260305082131-u4nzne4","Type":"NodeParagraph","Properties":{"id":"20260305082131-u4nzne4","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"事件方法以“.”链式调用的方式配置系统组件支持的事件，建议每个事件方法单独写一行。"}]},{"ID":"20260305082131-apoptp3","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"dHlwZXNjcmlwdA==","CodeBlockCloseFence":"YGBg","Properties":{"id":"20260305082131-apoptp3","updated":"20260305082131"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"dHlwZXNjcmlwdA=="},{"Type":"NodeCodeBlockCode","Data":"@Entry\n\n@Component\n\nstruct NewPage {\n\n  @State myText:string = ''\n\n  build() {\n\n    Column() {\n\n      Text(this.myText)\n\n       //使用箭头函数配置组件的事件方法。\n\n      Button('Click me')\n\n        .onClick(() =\u003e {\n\n          this.myText = 'ArkUI';\n\n        })\n\n​\n\n    }\n\n    .width('100%')\n\n    .height('100%')\n\n​\n\n​\n\n  }\n\n}\nTypeScript\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3}]},{"ID":"20260305082131-47a5peh","Type":"NodeParagraph","Properties":{"id":"20260305082131-47a5peh","updated":"20260305082131"},"Children":[{"Type":"NodeImage","Children":[{"Type":"NodeBang","Data":"!"},{"Type":"NodeOpenBracket","Data":"["},{"Type":"NodeLinkText","Data":"image-20240719183828054"},{"Type":"NodeCloseBracket","Data":"]"},{"Type":"NodeOpenParen","Data":"("},{"Type":"NodeLinkDest","Data":"https://i-blog.csdnimg.cn/blog_migrate/6c2e28ce26b64e073cb49c09e966e366.png"},{"Type":"NodeCloseParen","Data":")"}]}]},{"ID":"20260305082131-20p4xjg","Type":"NodeHeading","HeadingLevel":5,"Properties":{"id":"20260305082131-20p4xjg","updated":"20260305082131"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"##### "},{"Type":"NodeText","Data":"配置子组件"}]},{"ID":"20260305082131-9f03tbv","Type":"NodeParagraph","Properties":{"id":"20260305082131-9f03tbv","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"如果组件支持子组件配置，则需在尾随花括号\"{...}\"中为组件添加子组件的UI描述。"}]},{"ID":"20260305082131-e64881p","Type":"NodeBlockquote","Properties":{"id":"20260305082131-e64881p","updated":"20260305082131"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e "},{"ID":"20260305082131-c0nh8mp","Type":"NodeList","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20260305082131-c0nh8mp","updated":"20260305082131"},"Children":[{"ID":"20260305082131-cq326qo","Type":"NodeListItem","Data":"-","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20260305082131-cq326qo","updated":"20260305082131"},"Children":[{"ID":"20260305082131-foz2gol","Type":"NodeParagraph","Properties":{"id":"20260305082131-foz2gol","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"Column、Row、Stack、Grid、List等组件都是容器组件。容器组件都支持添加子组件。"}]}]},{"ID":"20260305082131-jog6nem","Type":"NodeListItem","Data":"-","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20260305082131-jog6nem","updated":"20260305082131"},"Children":[{"ID":"20260305082131-oiat2ld","Type":"NodeParagraph","Properties":{"id":"20260305082131-oiat2ld","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"部分基础组件也支持添加子组件"}]}]}]}]},{"ID":"20260305082131-hjnosn7","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"dHlwZXNjcmlwdA==","CodeBlockCloseFence":"YGBg","Properties":{"id":"20260305082131-hjnosn7","updated":"20260305082131"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"dHlwZXNjcmlwdA=="},{"Type":"NodeCodeBlockCode","Data":"Column() {\n\n  Text('Hello')\n\n    .fontSize(100)\n\n  Divider()\n\n  Text(this.myText)\n\n    .fontSize(100)\n\n    .fontColor(Color.Red)\n\n}\nTypeScript\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3}]},{"ID":"20260305082131-4plnq8q","Type":"NodeHeading","HeadingLevel":5,"Properties":{"id":"20260305082131-4plnq8q","updated":"20260305082131"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"##### "},{"Type":"NodeText","Data":"单位"}]},{"ID":"20260305082131-zazpe6v","Type":"NodeParagraph","Properties":{"id":"20260305082131-zazpe6v","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"继承web单位px、calc()、百分比%"}]},{"ID":"20260305082131-000efxy","Type":"NodeParagraph","Properties":{"id":"20260305082131-000efxy","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"新增："}]},{"ID":"20260305082131-8181t25","Type":"NodeParagraph","Properties":{"id":"20260305082131-8181t25","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"vp：虚拟像素，相对于不同的设备会自动转换，保证不同设备视角一直。ArkUI组件如果不写单位，则默认单位都是vp。"}]},{"ID":"20260305082131-s73l9r7","Type":"NodeParagraph","Properties":{"id":"20260305082131-s73l9r7","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"fp: 字体像素，与vp类似适用屏幕密度变化，随系统字体大小设置变化。"}]},{"ID":"20260305082131-419tfec","Type":"NodeParagraph","Properties":{"id":"20260305082131-419tfec","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"lpx: 视窗逻辑像素单位,lpx单位为实际屏幕宽度与逻辑宽度（通过 "},{"Type":"NodeTextMark","TextMarkType":"a","TextMarkAHref":"https://developer.huawei.com/consumer/cn/doc/harmonyos-guides-V5/module-configuration-file-V5#ZH-CN_TOPIC_0000001884756258__pages标签","TextMarkATitle":"designWidth","TextMarkTextContent":"designWidth"},{"Type":"NodeText","Data":" 配置）的比值，designWidth默认值为720。当designWidth为720时，在实际宽度为1440物理像素的屏幕上，1lpx为2px大小。"}]},{"ID":"20260305082131-ovq7rtu","Type":"NodeHeading","HeadingLevel":5,"Properties":{"id":"20260305082131-ovq7rtu","updated":"20260305082131"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"##### "},{"Type":"NodeText","Data":"像素单位转换"}]},{"ID":"20260305082131-3zom1tr","Type":"NodeParagraph","Properties":{"id":"20260305082131-3zom1tr","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"语法: 单位A 2单位B(value: number): number"}]},{"ID":"20260305082131-fhlzs0i","Type":"NodeParagraph","Properties":{"id":"20260305082131-fhlzs0i","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"将以A为单位的数值转换为以B为单位的数值。"}]},{"ID":"20260305082131-6wc4zf0","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"dHlwZXNjcmlwdA==","CodeBlockCloseFence":"YGBg","Properties":{"id":"20260305082131-6wc4zf0","updated":"20260305082131"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"dHlwZXNjcmlwdA=="},{"Type":"NodeCodeBlockCode","Data":"Text(\"单位转换\")\n\n         .width(vp2px(220)) //将vp单位的数值转换为以px为单位的数值。\n\n          .width(px2vp(220)) //将px单位的数值转换为以vp为单位的数值。\n\n        .width(fp2px(220)) //将fp单位的数值转换为以px为单位的数值。\n\n        .width(px2fp(220)) // 将px单位的数值转换为以fp为单位的数值。\n\n        .width(lpx2px(220)) // 将lpx单位的数值转换为以px为单位的数值。\n\n        .width(px2lpx(220)) // 将px单位的数值转换为以lpx为单位的数值。\nTypeScript\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3}]},{"ID":"20260305082131-b9skgdo","Type":"NodeHeading","HeadingLevel":5,"Properties":{"id":"20260305082131-b9skgdo","updated":"20260305082131"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"##### "},{"Type":"NodeText","Data":"枚举说明"}]},{"ID":"20260305082131-a9f623j","Type":"NodeParagraph","Properties":{"id":"20260305082131-a9f623j","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"ArkTS把一些属性值设为了一个个枚举。就拿backgroundColor这个通用属性举例。"}]},{"ID":"20260305082131-ssu6m6p","Type":"NodeParagraph","Properties":{"id":"20260305082131-ssu6m6p","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"比如HarmonyOS SDK API封装了一个Color枚举类型"}]},{"ID":"20260305082131-2rivumk","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"dHlwZXNjcmlwdA==","CodeBlockCloseFence":"YGBg","Properties":{"id":"20260305082131-2rivumk","updated":"20260305082131"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"dHlwZXNjcmlwdA=="},{"Type":"NodeCodeBlockCode","Data":"enum Color{\n\n    Black = '#000000',\n\n    Blue = '#0000ff',\n\n    Brown = '#a52a2a',\n\n    Gray = '#808080',\n\n    ......\n\n}\nTypeScript\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3}]},{"ID":"20260305082131-x613iy1","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"dHlwZXNjcmlwdA==","CodeBlockCloseFence":"YGBg","Properties":{"id":"20260305082131-x613iy1","updated":"20260305082131"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"dHlwZXNjcmlwdA=="},{"Type":"NodeCodeBlockCode","Data":"Text(\"单位转换\")\n\n    .backgroundColor(Color.Blue) //枚举类型Color访问其中一个Blue成员。\n\n    //等价于下面\n\n    .backgroundColor('#0000ff')  \nTypeScript\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBloc