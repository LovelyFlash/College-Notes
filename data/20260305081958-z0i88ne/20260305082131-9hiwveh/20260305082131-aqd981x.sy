enBracket","Data":"["},{"Type":"NodeCloseBracket","Data":"]"},{"Type":"NodeOpenParen","Data":"("},{"Type":"NodeLinkDest","Data":"https://i-blog.csdnimg.cn/blog_migrate/a6226e04f0e364fee640713f7746ae5f.png"},{"Type":"NodeCloseParen","Data":")"}]}]},{"ID":"20260305082131-lk8ko82","Type":"NodeParagraph","Properties":{"id":"20260305082131-lk8ko82","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"$rawfile('filename')"}]},{"ID":"20260305082131-vbl4zde","Type":"NodeParagraph","Properties":{"id":"20260305082131-vbl4zde","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"filename：工程中resources/rawfile目录下的文件名称。"}]},{"ID":"20260305082131-15h2ovp","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"dHlwZXNjcmlwdA==","CodeBlockCloseFence":"YGBg","Properties":{"id":"20260305082131-15h2ovp","updated":"20260305082131"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"dHlwZXNjcmlwdA=="},{"Type":"NodeCodeBlockCode","Data":"Image($rawfile('picture'))TypeScript\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3}]},{"ID":"20260305082131-j7qi07y","Type":"NodeHeading","HeadingLevel":4,"Properties":{"id":"20260305082131-j7qi07y","updated":"20260305082131"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"#### "},{"Type":"NodeText","Data":"4.2通用属性"}]},{"ID":"20260305082131-1sqq6hc","Type":"NodeParagraph","Properties":{"id":"20260305082131-1sqq6hc","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"ArkUI组件通用信息分为通用事件和通用属性，所有组件都能使用他们。"}]},{"ID":"20260305082131-12b4kex","Type":"NodeHeading","HeadingLevel":5,"Properties":{"id":"20260305082131-12b4kex","updated":"20260305082131"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"##### "},{"Type":"NodeText","Data":"尺寸设置"}]},{"ID":"20260305082131-pcsynwn","Type":"NodeParagraph","Properties":{"id":"20260305082131-pcsynwn","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"语法："}]},{"ID":"20260305082131-xgk90h5","Type":"NodeHeading","HeadingLevel":6,"Properties":{"id":"20260305082131-xgk90h5","updated":"20260305082131"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"###### "},{"Type":"NodeText","Data":"width(value: Length)"}]},{"ID":"20260305082131-u32jgfb","Type":"NodeHeading","HeadingLevel":6,"Properties":{"id":"20260305082131-u32jgfb","updated":"20260305082131"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"###### "},{"Type":"NodeText","Data":"height(value: Length)"}]},{"ID":"20260305082131-ekn6t3a","Type":"NodeHeading","HeadingLevel":6,"Properties":{"id":"20260305082131-ekn6t3a","updated":"20260305082131"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"###### "},{"Type":"NodeText","Data":"size(value: SizeOptions)"}]},{"ID":"20260305082131-ai81rmw","Type":"NodeParagraph","Properties":{"id":"20260305082131-ai81rmw","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"设置高宽尺寸。"}]},{"ID":"20260305082131-qp0n6ee","Type":"NodeParagraph","Properties":{"id":"20260305082131-qp0n6ee","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"参数类型SizeOptions是个包含宽、高的对象"}]},{"ID":"20260305082131-60xvd3j","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"dHlwZXNjcmlwdA==","CodeBlockCloseFence":"YGBg","Properties":{"id":"20260305082131-60xvd3j","updated":"20260305082131"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"dHlwZXNjcmlwdA=="},{"Type":"NodeCodeBlockCode","Data":"//值为一个包含宽、高的对象\n\n.size({ width: '100%', height: '100%' })\n\n.size({ width: 'calc(90%)', height: 'calc(50vp + 10%)' })\nTypeScript\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3}]},{"ID":"20260305082131-7jxp3g6","Type":"NodeHeading","HeadingLevel":6,"Properties":{"id":"20260305082131-7jxp3g6","updated":"20260305082131"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"###### "},{"Type":"NodeText","Data":"padding(value: Padding | Length | LocalizedPadding)"}]},{"ID":"20260305082131-lr0bh9m","Type":"NodeParagraph","Properties":{"id":"20260305082131-lr0bh9m","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"内边距"}]},{"ID":"20260305082131-iazvxe9","Type":"NodeParagraph","Properties":{"id":"20260305082131-iazvxe9","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"参数类型Padding是个包含top、left、bottom、right的对象；Length就是长度； LocalizedPadding是个枚举类型"}]},{"ID":"20260305082131-7om75gj","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"dHlwZXNjcmlwdA==","CodeBlockCloseFence":"YGBg","Properties":{"id":"20260305082131-7om75gj","updated":"20260305082131"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"dHlwZXNjcmlwdA=="},{"Type":"NodeCodeBlockCode","Data":"//参数类型为Padding \n\n.padding({\n\n        top: 5,\n\n        left: 10,\n\n        bottom: 15,\n\n        right: 20\n\n})\n\n​\n\n//参数类型为Length\n\n.padding(20) //意思是上左下右内边距都是20\n\n//参数类型为LocalizedMargin\n\n.padding({\n\n          top: LengthMetrics.vp(40),\n\n          bottom: LengthMetrics.vp(20),\n\n          start: LengthMetrics.vp(30),\n\n          end: LengthMetrics.vp(10)\n\n })\nTypeScript\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3}]},{"ID":"20260305082131-z5q1ngp","Type":"NodeHeading","HeadingLevel":6,"Properties":{"id":"20260305082131-z5q1ngp","updated":"20260305082131"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"###### "},{"Type":"NodeText","Data":"margin(value: margin | Length | LocalizedMargin)"}]},{"ID":"20260305082131-9vy4evm","Type":"NodeParagraph","Properties":{"id":"20260305082131-9vy4evm","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"外边距"}]},{"ID":"20260305082131-b8irnx0","Type":"NodeParagraph","Properties":{"id":"20260305082131-b8irnx0","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"参照内边距"}]},{"ID":"20260305082131-ig6rbba","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockCloseFence":"YGBg","Properties":{"id":"20260305082131-ig6rbba","updated":"20260305082131"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3},{"Type":"NodeCodeBlockFenceInfoMarker"},{"Type":"NodeCodeBlockCode","Data":"//值为margin\n.margin({\n        top: 5,\n        left: 10,\n        bottom: 15,\n        right: 20\n})\n​\n//值为Length\n.margin(20) //意思是上左下右外边距都是20\n//值为LocalizedMargin\n.margin({\n          top: LengthMetrics.vp(40),\n          bottom: LengthMetrics.vp(20),\n          start: LengthMetrics.vp(30),\n          end: LengthMetrics.vp(10)\n })\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3}]},{"ID":"20260305082131-69sjxjx","Type":"NodeHeading","HeadingLevel":6,"Properties":{"id":"20260305082131-69sjxjx","updated":"20260305082131"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"###### "},{"Type":"NodeText","Data":"layoutWeight(value: number | string)"}]},{"ID":"20260305082131-aweu9r8","Type":"NodeParagraph","Properties":{"id":"20260305082131-aweu9r8","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"对子组件进行重新布局。仅在Row/Column/Flex布局中生效。"}]},{"ID":"20260305082131-wq6fa5k","Type":"NodeParagraph","Properties":{"id":"20260305082131-wq6fa5k","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"父容器尺寸确定时，设置了layoutWeight属性的子元素与兄弟元素占主轴尺寸按照权重进行分配，忽略元素本身尺寸设置，表示自适应占满剩余空间。默认值：0"}]},{"ID":"20260305082131-u7i6qb4","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockCloseFence":"YGBg","Properties":{"id":"20260305082131-u7i6qb4","updated":"20260305082131"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3},{"Type":"NodeCodeBlockFenceInfoMarker"},{"Type":"NodeCodeBlockCode","Data":"@Entry\n@Component\nstruct StackExample {\n  build() {\n   Column(){\n     Row() {\n       // 权重1，占主轴剩余空间1/3\n       Text('layoutWeight(1)')\n         .size({ width: '30%', height: 110 })\n         .backgroundColor(0xFFEFD5)\n         .textAlign(TextAlign.Center)\n         .layoutWeight(1)\n       // 权重2，占主轴剩余空间2/3\n       Text('layoutWeight(2)')\n         .size({ width: '30%', height: 110 })\n         .backgroundColor(0xF5DEB3)\n         .textAlign(TextAlign.Center)\n         .layoutWeight(2)\n       // 未设置layoutWeight属性，组件按照自身尺寸渲染\n       Text('no layoutWeight')\n         .size({ width: '30%', height: 110 }) //优先分配此空间\n         .backgroundColor(0xD2B48C)\n         .textAlign(TextAlign.Center)\n     }.size({ width: '90%', height: 140 })\n      .backgroundColor(0xAFEEEE)\n   }\n   .width('100%')\n   .height('100%')\n​\n  }\n}\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3}]},{"ID":"20260305082131-tqmpb5n","Type":"NodeParagraph","Properties":{"id":"20260305082131-tqmpb5n","updated":"20260305082131"},"Children":[{"Type":"NodeImage","Children":[{"Type":"NodeBang","Data":"!"},{"Type":"NodeOpenBracket","Data":"["},{"Type":"NodeLinkText","Data":"image-20240717092746443"},{"Type":"NodeCloseBracket","Data":"]"},{"Type":"NodeOpenParen","Data":"("},{"Type":"NodeLinkDest","Data":"https://i-blog.csdnimg.cn/blog_migrate/b94f67dbc749421d401a3471f14bad95.png"},{"Type":"NodeCloseParen","Data":")"}]}]},{"ID":"20260305082131-vvwdqsn","Type":"NodeHeading","HeadingLevel":6,"Properties":{"id":"20260305082131-vvwdqsn","updated":"20260305082131"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"###### "},{"Type":"NodeText","Data":"constraintSize(value: ConstraintSizeOptions)"}]},{"ID":"20260305082131-ycxg29w","Type":"NodeParagraph","Properties":{"id":"20260305082131-ycxg29w","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"设置约束尺寸，组件布局时，进行尺寸范围限制。"}]},{"ID":"20260305082131-5zhd5rh","Type":"NodeParagraph","Properties":{"id":"20260305082131-5zhd5rh","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"参数类型ConstraintSizeOptions对象内默认值："}]},{"ID":"20260305082131-k8elcxc","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockCloseFence":"YGBg","Properties":{"id":"20260305082131-k8elcxc","updated":"20260305082131"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3},{"Type":"NodeCodeBlockFenceInfoMarker"},{"Type":"NodeCodeBlockCode","Data":".constraintSize({\nminWidth: 0, //设置组件最小宽度。\nmaxWidth: Infinity, //设置组件最大宽度。\nminHeight: 0, //设置组件最小高度。\nmaxHeight: Infinity //设置组件最大高度。 \n})\n单位：vp\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3}]},{"ID":"20260305082131-2g1eb0j","Type":"NodeParagraph","Properties":{"id":"20260305082131-2g1eb0j","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"示例:"}]},{"ID":"20260305082131-09gg6xk","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockCloseFence":"YGBg","Properties":{"id":"20260305082131-09gg6xk","updated":"20260305082131"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3},{"Type":"NodeCodeBlockFenceInfoMarker"},{"Type":"NodeCodeBlockCode","Data":"@Entry\n@Component\nstruct Commontype {\n  build() {\n​\n    Text('尺寸类通用属性')\n      .height('100%')\n      .width('100%')\n      .size({ width: '100%', height: '100%' })\n      .padding({\n        top: 5,\n        left: 10,\n        bottom: 15,\n        right: 20\n      })// 可以这样写 .padding(20) 上 左 下 右内边距都是20vp\n      .margin({\n        top: 5,\n        left: 10,\n        bottom: 15,\n        right: 20\n      })// 可以这样写.margin(20) 上 左 下 右外边距都是20vp\n      .layoutWeight(20)\n      .constraintSize({\n        minWidth: 0,\n        maxWidth: Infinity,\n        minHeight: 0,\n        maxHeight: Infinity\n      }\n      )\n  }\n}\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3}]},{"ID":"20260305082131-cu6thlg","Type":"NodeHeading","HeadingLevel":5,"Properties":{"id":"20260305082131-cu6thlg","updated":"20260305082131"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"##### "},{"Type":"NodeText","Data":"Flex布局"}]},{"ID":"20260305082131-k9fdz23","Type":"NodeHeading","HeadingLevel":4,"Properties":{"id":"20260305082131-k9fdz23","updated":"20260305082131"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"#### "},{"Type":"NodeText","Data":"4.3基础组件"}]},{"ID":"20260305082131-85nhirk","Type":"NodeHeading","HeadingLevel":4,"Properties":{"id":"20260305082131-85nhirk","updated":"20260305082131"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"#### "},{"Type":"NodeText","Data":"4.4容器属性"}]},{"ID":"20260305082131-zayb1ep","Type":"NodeParagraph","Properties":{"id":"20260305082131-zayb1ep","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"实付 元"}]},{"ID":"20260305082131-pnmoh45","Type":"NodeParagraph","Properties":{"id":"20260305082131-pnmoh45","updated":"20260305082131"},"Children":[{"Type":"NodeTextMark","TextMarkType":"a","TextMarkAHref":"https://blog.csdn.net/m0_64115130/article/details/","TextMarkTextContent":"使用余额支付"}]},{"ID":"20260305082131-r8c0wri","Type":"NodeParagraph","Properties":{"id":"20260305082131-r8c0wri","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"点击重新获取"}]},{"ID":"20260305082131-s3fv1g1","Type":"NodeParagraph","Properties":{"id":"20260305082131-s3fv1g1","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"扫码支付"}]},{"ID":"20260305082131-bifz2cf","Type":"NodeParagraph","Properties":{"id":"20260305082131-bifz2cf","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"钱包余额 0"}]},{"ID":"202603050