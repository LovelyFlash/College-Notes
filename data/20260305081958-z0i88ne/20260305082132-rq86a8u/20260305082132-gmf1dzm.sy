kType":"inline-math","TextMarkInlineMathContent":"(\\lnot G),(\\lnot H), (G\\lor H),(G\\land H),(G\\to H),(G\\leftrightarrow H)"},{"Type":"NodeText","Data":" 也是合式公式；"}]}]},{"ID":"20260305082132-ykbqeyg","Type":"NodeListItem","Data":"3.","ListData":{"Typ":1,"Tight":true,"Start":3,"Delimiter":41,"Padding":3,"Marker":"My4=","Num":3},"Properties":{"id":"20260305082132-ykbqeyg","updated":"20260305082132"},"Children":[{"ID":"20260305082132-x7daeto","Type":"NodeParagraph","Properties":{"id":"20260305082132-x7daeto","updated":"20260305082132"},"Children":[{"Type":"NodeText","Data":"若 G 是合式公式，x 是个体变量，则 "},{"Type":"NodeTextMark","TextMarkType":"inline-math","TextMarkInlineMathContent":"(\\forall x)G,(\\exists x)G"},{"Type":"NodeText","Data":" 也是合式公式；"}]}]},{"ID":"20260305082132-9r4fx8r","Type":"NodeListItem","Data":"4.","ListData":{"Typ":1,"Tight":true,"Start":4,"Delimiter":41,"Padding":3,"Marker":"NC4=","Num":4},"Properties":{"id":"20260305082132-9r4fx8r","updated":"20260305082132"},"Children":[{"ID":"20260305082132-yheg8u3","Type":"NodeParagraph","Properties":{"id":"20260305082132-yheg8u3","updated":"20260305082132"},"Children":[{"Type":"NodeText","Data":"仅仅由 1) - 3) 产生的表达式才是合式公式。"}]}]}]},{"ID":"20260305082132-ghbjkhz","Type":"NodeHeading","HeadingLevel":4,"Properties":{"id":"20260305082132-ghbjkhz","updated":"20260305082132"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"#### "},{"Type":"NodeText","Data":"自由变元和约束变元"}]},{"ID":"20260305082132-5tegazk","Type":"NodeParagraph","Properties":{"id":"20260305082132-5tegazk","updated":"20260305082132"},"Children":[{"Type":"NodeText","Data":"给定一个合式公式 G，若变元 "},{"Type":"NodeTextMark","TextMarkType":"inline-math","TextMarkInlineMathContent":"x"},{"Type":"NodeText","Data":" 出现在使用变元的量词的辖域之内，则称变元 x 的出现为\u003cfont color=\"#ff0000\"\u003e约束出现 (Bound Occurrence)\u003c/font\u003e，此时的变元 "},{"Type":"NodeTextMark","TextMarkType":"inline-math","TextMarkInlineMathContent":"x"},{"Type":"NodeText","Data":" 称为\u003cfont color=\"#ff0000\"\u003e约束变元 (Bound Variable)\u003c/font\u003e。若 "},{"Type":"NodeTextMark","TextMarkType":"inline-math","TextMarkInlineMathContent":"x"},{"Type":"NodeText","Data":" 的出现不是约束出现， 则称它为\u003cfont color=\"#ff0000\"\u003e自由出现 (Free Occurrence)\u003c/font\u003e，此时的变元 "},{"Type":"NodeTextMark","TextMarkType":"inline-math","TextMarkInlineMathContent":"x"},{"Type":"NodeText","Data":" 称为\u003cfont color=\"#ff0000\"\u003e自由变元 (Free Variable)\u003c/font\u003e。"}]},{"ID":"20260305082132-yh0z4gr","Type":"NodeBlockquote","Properties":{"id":"20260305082132-yh0z4gr","updated":"20260305082132"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e "},{"ID":"20260305082132-pvhqdt9","Type":"NodeParagraph","Properties":{"id":"20260305082132-pvhqdt9","updated":"20260305082132"},"Children":[{"Type":"NodeText","Data":"量词辖域的确定方法："}]},{"ID":"20260305082132-b8x0vuq","Type":"NodeList","ListData":{"Typ":1,"Tight":true,"Start":1,"Delimiter":41,"Padding":3,"Marker":"MS4=","Num":1},"Properties":{"id":"20260305082132-b8x0vuq","updated":"20260305082132"},"Children":[{"ID":"20260305082132-g9bw6yg","Type":"NodeListItem","Data":"1.","ListData":{"Typ":1,"Tight":true,"Start":1,"Delimiter":41,"Padding":3,"Marker":"MS4=","Num":1},"Properties":{"id":"20260305082132-g9bw6yg","updated":"20260305082132"},"Children":[{"ID":"20260305082132-c5zug63","Type":"NodeParagraph","Properties":{"id":"20260305082132-c5zug63","updated":"20260305082132"},"Children":[{"Type":"NodeText","Data":"若量词后有括号，则括号内的子公式就是该量词的辖域"}]}]},{"ID":"20260305082132-w7uzopl","Type":"NodeListItem","Data":"2.","ListData":{"Typ":1,"Tight":true,"Start":2,"Delimiter":41,"Padding":3,"Marker":"Mi4=","Num":2},"Properties":{"id":"20260305082132-w7uzopl","updated":"20260305082132"},"Children":[{"ID":"20260305082132-rh52lls","Type":"NodeParagraph","Properties":{"id":"20260305082132-rh52lls","updated":"20260305082132"},"Children":[{"Type":"NodeText","Data":"若量词后无括号，则与量词邻接的子公式为该量词的辖域。"}]}]}]}]},{"ID":"20260305082132-kaojy7w","Type":"NodeHeading","HeadingLevel":4,"Properties":{"id":"20260305082132-kaojy7w","updated":"20260305082132"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"#### "},{"Type":"NodeText","Data":"闭式"}]},{"ID":"20260305082132-2te9rz7","Type":"NodeParagraph","Properties":{"id":"20260305082132-2te9rz7","updated":"20260305082132"},"Children":[{"Type":"NodeText","Data":"设 G 是任意一个公式，若 G 中无自由出现的个体变元，则称 G 为封闭的合式公式，简称闭式。"}]},{"ID":"20260305082132-jqc66wu","Type":"NodeBlockquote","Properties":{"id":"20260305082132-jqc66wu","updated":"20260305082132"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e "},{"ID":"20260305082132-8ynidpi","Type":"NodeParagraph","Properties":{"id":"20260305082132-8ynidpi","updated":"20260305082132"},"Children":[{"Type":"NodeText","Data":"例"}]}]},{"ID":"20260305082132-d30iozb","Type":"NodeMathBlock","Properties":{"id":"20260305082132-d30iozb","updated":"20260305082132"},"Children":[{"Type":"NodeMathBlockOpenMarker"},{"Type":"NodeMathBlockContent","Data":"\\huge\n(\\forall x)(P(x)\\to (\\exists y)R(x,y))"},{"Type":"NodeMathBlockCloseMarker"}]},{"ID":"20260305082132-bvpl59h","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20260305082132-bvpl59h","updated":"20260305082132"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"### "},{"Type":"NodeText","Data":"5.3.3 两个规则"}]},{"ID":"20260305082132-n9fqm3k","Type":"NodeHeading","HeadingLevel":4,"Properties":{"id":"20260305082132-n9fqm3k","updated":"20260305082132"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"#### "},{"Type":"NodeText","Data":"规则一（约束变元的改名规则）"}]},{"ID":"20260305082132-9bzmqpj","Type":"NodeList","ListData":{"Typ":1,"Tight":true,"Start":1,"Delimiter":41,"Padding":3,"Marker":"MS4=","Num":1},"Properties":{"id":"20260305082132-9bzmqpj","updated":"20260305082132"},"Children":[{"ID":"20260305082132-86fbu6l","Type":"NodeListItem","Data":"1.","ListData":{"Typ":1,"Tight":true,"Start":1,"Delimiter":41,"Padding":3,"Marker":"MS4=","Num":1},"Properties":{"id":"20260305082132-86fbu6l","updated":"20260305082132"},"Children":[{"ID":"20260305082132-k4k3iwp","Type":"NodeParagraph","Properties":{"id":"20260305082132-k4k3iwp","updated":"20260305082132"},"Children":[{"Type":"NodeText","Data":"将量词中出现的变元以及该量词辖域中此变量的所有约束出现都用新的个体变元替换；"}]}]},{"ID":"20260305082132-9xtkdqh","Type":"NodeListItem","Data":"2.","ListData":{"Typ":1,"Tight":true,"Start":2,"Delimiter":41,"Padding":3,"Marker":"Mi4=","Num":2},"Properties":{"id":"20260305082132-9xtkdqh","updated":"20260305082132"},"Children":[{"ID":"20260305082132-2bxoihy","Type":"NodeParagraph","Properties":{"id":"20260305082132-2bxoihy","updated":"20260305082132"},"Children":[{"Type":"NodeText","Data":"新的变元一定要有别于改名辖域中的所有其它变量。"}]}]}]},{"ID":"20260305082132-94ybhle","Type":"NodeHeading","HeadingLevel":4,"Properties":{"id":"20260305082132-94ybhle","updated":"20260305082132"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"#### "},{"Type":"NodeText","Data":"规则二 (自由变元的代入规则)"}]},{"ID":"20260305082132-kdo8nyo","Type":"NodeList","ListData":{"Typ":1,"Tight":true,"Start":1,"Delimiter":41,"Padding":3,"Marker":"MS4=","Num":1},"Properties":{"id":"20260305082132-kdo8nyo","updated":"20260305082132"},"Children":[{"ID":"20260305082132-ybl2zrq","Type":"NodeListItem","Data":"1.","ListData":{"Typ":1,"Tight":true,"Start":1,"Delimiter":41,"Padding":3,"Marker":"MS4=","Num":1},"Properties":{"id":"20260305082132-ybl2zrq","updated":"20260305082132"},"Children":[{"ID":"20260305082132-wlry9vi","Type":"NodeParagraph","Properties":{"id":"20260305082132-wlry9vi","updated":"20260305082132"},"Children":[{"Type":"NodeText","Data":"将公式中出现该自由变元的每一处都用新的个体变元替换；"}]}]},{"ID":"20260305082132-7r84ihw","Type":"NodeListItem","Data":"2.","ListData":{"Typ":1,"Tight":true,"Start":2,"Delimiter":41,"Padding":3,"Marker":"Mi4=","Num":2},"Properties":{"id":"20260305082132-7r84ihw","updated":"20260305082132"},"Children":[{"ID":"20260305082132-beo4cip","Type":"NodeParagraph","Properties":{"id":"20260305082132-beo4cip","updated":"20260305082132"},"Children":[{"Type":"NodeText","Data":"新变元不允许在原公式中以任何约束形式出现。"}]}]}]},{"ID":"20260305082132-ib0pizh","Type":"NodeParagraph","Properties":{"id":"20260305082132-ib0pizh","updated":"20260305082132"},"Children":[{"Type":"NodeText","Data":"改名规则和代入规则之间的共同点都是不能改变原有的约束关系，而不同点是："}]},{"ID":"20260305082132-x1hob4v","Type":"NodeList","ListData":{"Typ":1,"Tight":true,"Start":1,"Delimiter":41,"Padding":3,"Marker":"MS4=","Num":1},"Properties":{"id":"20260305082132-x1hob4v","updated":"20260305082132"},"Children":[{"ID":"20260305082132-3mcmki8","Type":"NodeListItem","Data":"1.","ListData":{"Typ":1,"Tight":true,"Start":1,"Delimiter":41,"Padding":3,"Marker":"MS4=","Num":1},"Properties":{"id":"20260305082132-3mcmki8","updated":"20260305082132"},"Children":[{"ID":"20260305082132-23y81tq","Type":"NodeParagraph","Properties":{"id":"20260305082132-23y81tq","updated":"20260305082132"},"Children":[{"Type":"NodeText","Data":"施行的对象不同：改名规则是对约束变元施行， 代入规则是对自由变元施行；"}]}]},{"ID":"20260305082132-360q3av","Type":"NodeListItem","Data":"2.","ListData":{"Typ":1,"Tight":true,"Start":2,"Delimiter":41,"Padding":3,"Marker":"Mi4=","Num":2},"Properties":{"id":"20260305082132-360q3av","updated":"20260305082132"},"Children":[{"ID":"20260305082132-411dpox","Type":"NodeParagraph","Properties":{"id":"20260305082132-411dpox","updated":"20260305082132"},"Children":[{"Type":"NodeText","Data":"施行的范围不同：改名规则可以只对公式中的一个量词及其辖域内施行，即\u003cfont color=\"#ff0000\"\u003e只对公式的一个子公式施行\u003c/font\u003e；而代入规则必须对整个公式同一个自由变元的所有自由出现同时施行，即必须\u003cfont color=\"#ff0000\"\u003e对整个公式施行\u003c/font\u003e；"}]}]},{"ID":"20260305082132-jcuhcbv","Type":"NodeListItem","Data":"3.","ListData":{"Typ":1,"Tight":true,"Start":3,"Delimiter":41,"Padding":3,"Marker":"My4=","Num":3},"Properties":{"id":"20260305082132-jcuhcbv","updated":"20260305082132"},"Children":[{"ID":"20260305082132-ldwbfeu","Type":"NodeParagraph","Properties":{"id":"20260305082132-ldwbfeu","updated":"20260305082132"},"Children":[{"Type":"NodeText","Data":"施行后的结果不同：改名后，公式含义不变， 因为约束变元\u003cfont color=\"#ff0000\"\u003e只改名为另一个个体变元\u003c/font\u003e，约束关系不改变，约束变元不能改名为个体常量；代入后， 不仅可用另一个个体变元进行代入，并且也可用个体常量去代入，从而使公式由具有普遍意义变为仅对该个体常量有意义，即\u003cfont color=\"#ff0000\"\u003e公式的含义改变了\u003c/font\u003e。"}]}]}]},{"ID":"20260305082132-q0346kp","Type":"NodeHeading","HeadingLevel":3,"Properties":{"id":"20260305082132-q0346kp","updated":"20260305082132"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"### "},{"Type":"NodeText","Data":"5.3.4 谓词合式公式的解释"}]},{"ID":"20260305082132-iyjew0x","Type":"NodeParagraph","Properties":{"id":"20260305082132-iyjew0x","updated":"20260305082132"},"Children":[{"Type":"NodeText","Data":"词逻辑中公式"},{"Type":"NodeTextMark","TextMarkType":"em","TextMarkTextContent":"G"},{"Type":"NodeText","Data":" 的每一个解释"},{"Type":"NodeTextMark","TextMarkType":"em","TextMarkTextContent":"I"},{"Type":"NodeText","Data":"(Explanation) 由如下四部分组成："}]},{"ID":"20260305082132-skrmxkd","Type":"NodeList","ListData":{"Typ":1,"Tight":true,"Start":1,"Delimiter":41,"Padding":3,"Marker":"MS4=","Num":1},"Properties":{"id":"20260305082132-skrmxkd","updated":"20260305082132"},"Children":[{"ID":"20260305082132-gr0e2up","Type":"NodeListItem","Data":"1.","ListData":{"Typ":1,"Tight":true,"Start":1,"Delimiter":41,"Padding":3,"Marker":"MS4=","Num":1},"Properties":{"id":"20260305082132-gr0e2up","updated":"20260305082132"},"Children":[{"ID":"20260305082132-s2bau7j","Type":"NodeParagraph","Properties":{"id":"20260305082132-s2bau7j","updated":"20260305082132"},"Children":[{"Type":"NodeText","Data":"非空的个体域集合 "},{"Type":"NodeTextMark","TextMarkType":"em","TextMarkTextContent":"D"},{"Type":"NodeText","Data":" ；"}]}]},{"ID":"20260305082132-pkdqsim","Type":"NodeListItem","Data":"2.","ListData":{"Typ":1,"Tight":true,"Start":2,"Delimiter":41,"Padding":3,"Marker":"Mi4=","Num":2},"Properties":{"id":"20260305082132-pkdqsim","updated":"20260305082132"},"Children":[{"ID":"20260305082132-tuj4atx","Type":"NodeParagraph","Properties":{"id":"20260305082132-tuj4atx","updated":"20260305082132"},"Children":[{"Type":"NodeTextMark","TextMarkType":"em","TextMarkTextContent":