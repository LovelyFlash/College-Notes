kType":"em","TextMarkTextContent":"G,H"},{"Type":"NodeText","Data":" 是公式，对任意解释 "},{"Type":"NodeTextMark","TextMarkType":"em","TextMarkTextContent":"I"},{"Type":"NodeText","Data":"，如果 "},{"Type":"NodeTextMark","TextMarkType":"em","TextMarkTextContent":"I"},{"Type":"NodeText","Data":" 满足 "},{"Type":"NodeTextMark","TextMarkType":"em","TextMarkTextContent":"G"},{"Type":"NodeText","Data":"，那么 "},{"Type":"NodeTextMark","TextMarkType":"em","TextMarkTextContent":"I"},{"Type":"NodeText","Data":" 满足 "},{"Type":"NodeTextMark","TextMarkType":"em","TextMarkTextContent":"H"},{"Type":"NodeText","Data":"，则称 "},{"Type":"NodeTextMark","TextMarkType":"em","TextMarkTextContent":"H"},{"Type":"NodeText","Data":" 是 "},{"Type":"NodeTextMark","TextMarkType":"em","TextMarkTextContent":"G"},{"Type":"NodeText","Data":" 的逻辑结果 (或称 "},{"Type":"NodeTextMark","TextMarkType":"em","TextMarkTextContent":"G"},{"Type":"NodeText","Data":" 蕴涵 H),记为 "},{"Type":"NodeTextMark","TextMarkType":"inline-math","TextMarkInlineMathContent":"G\\Rightarrow H"},{"Type":"NodeText","Data":"，此时称 "},{"Type":"NodeTextMark","TextMarkType":"em","TextMarkTextContent":"G"},{"Type":"NodeText","Data":" 为前提，"},{"Type":"NodeTextMark","TextMarkType":"em","TextMarkTextContent":"H"},{"Type":"NodeText","Data":" 为结论。"}]},{"ID":"20260305082132-v3divhe","Type":"NodeHeading","HeadingLevel":4,"Properties":{"id":"20260305082132-v3divhe","updated":"20260305082132"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"#### "},{"Type":"NodeText","Data":"判定定理"}]},{"ID":"20260305082132-pjywxfo","Type":"NodeList","ListData":{"Typ":1,"Tight":true,"Start":1,"Delimiter":46,"Padding":3,"Marker":"MS4=","Num":1},"Properties":{"id":"20260305082132-pjywxfo","updated":"20260305082132"},"Children":[{"ID":"20260305082132-ykkti9u","Type":"NodeListItem","Data":"1.","ListData":{"Typ":1,"Tight":true,"Start":1,"Delimiter":46,"Padding":3,"Marker":"MS4=","Num":1},"Properties":{"id":"20260305082132-ykkti9u","updated":"20260305082132"},"Children":[{"ID":"20260305082132-rvnil0q","Type":"NodeParagraph","Properties":{"id":"20260305082132-rvnil0q","updated":"20260305082132"},"Children":[{"Type":"NodeText","Data":"设 "},{"Type":"NodeTextMark","TextMarkType":"em","TextMarkTextContent":"G,H"},{"Type":"NodeText","Data":" 是公式，"},{"Type":"NodeTextMark","TextMarkType":"em","TextMarkTextContent":"H"},{"Type":"NodeText","Data":" 是 "},{"Type":"NodeTextMark","TextMarkType":"em","TextMarkTextContent":"G"},{"Type":"NodeText","Data":" 的逻辑结果当且仅当 "},{"Type":"NodeTextMark","TextMarkType":"inline-math","TextMarkInlineMathContent":"G\\to H"},{"Type":"NodeText","Data":" 为永真公式。"}]},{"ID":"20260305082132-mpu1nyj","Type":"NodeBlockquote","Properties":{"id":"20260305082132-mpu1nyj","updated":"20260305082132"},"Children":[{"Type":"NodeBlockquoteMarker","Data":"\u003e "},{"ID":"20260305082132-avxyksr","Type":"NodeParagraph","Properties":{"id":"20260305082132-avxyksr","updated":"20260305082132"},"Children":[{"Type":"NodeText","Data":"推广"},{"Type":"NodeSoftBreak","Data":"\n"},{"Type":"NodeText","Data":"设 "},{"Type":"NodeTextMark","TextMarkType":"inline-math","TextMarkInlineMathContent":"G_1,G_2,…,G_n,H"},{"Type":"NodeText","Data":" 是公式，称 "},{"Type":"NodeTextMark","TextMarkType":"em","TextMarkTextContent":"H"},{"Type":"NodeText","Data":" 是 "},{"Type":"NodeTextMark","TextMarkType":"inline-math","TextMarkInlineMathContent":"G_1,G_2,…, G_n"},{"Type":"NodeText","Data":" 的逻辑结果 ("},{"Type":"NodeTextMark","TextMarkType":"inline-math","TextMarkInlineMathContent":"G_1,G_2,…,G_n"},{"Type":"NodeText","Data":" 共同蕴涵 "},{"Type":"NodeTextMark","TextMarkType":"em","TextMarkTextContent":"H"},{"Type":"NodeText","Data":"),当且仅当 "},{"Type":"NodeTextMark","TextMarkType":"em","TextMarkTextContent":"H"},{"Type":"NodeText","Data":" 是 "},{"Type":"NodeTextMark","TextMarkType":"inline-math","TextMarkInlineMathContent":"G_1\\land G_2\\land …\\land G_n"},{"Type":"NodeText","Data":" 的逻辑结果 (logic conclusion)。记为 "},{"Type":"NodeTextMark","TextMarkType":"inline-math","TextMarkInlineMathContent":"G_1,G_2,…,G_n\\Rightarrow H"},{"Type":"NodeText","Data":"，此时称 "},{"Type":"NodeTextMark","TextMarkType":"inline-math","TextMarkInlineMathContent":"G_1,G_2,…,G_n\\Rightarrow H"},{"Type":"NodeText","Data":" 为有效的 (efficacious)，否则称为无效的 (inefficacious)。 "},{"Type":"NodeTextMark","TextMarkType":"inline-math","TextMarkInlineMathContent":"G_1,G_2,…,G_n"},{"Type":"NodeText","Data":" 称为一组前提 (Premise),有时用集合 "},{"Type":"NodeTextMark","TextMarkType":"inline-math","TextMarkInlineMathContent":"\\Gamma"},{"Type":"NodeText","Data":" 来表示 ， 记 "},{"Type":"NodeTextMark","TextMarkType":"inline-math","TextMarkInlineMathContent":"\\Gamma =\\{G_1,G_2,…,G_n\\}"},{"Type":"NodeText","Data":" 。 H 称为结论 (conclusion)。又称 H 是前提集合 "},{"Type":"NodeTextMark","TextMarkType":"inline-math","TextMarkInlineMathContent":"\\Gamma"},{"Type":"NodeText","Data":" 的逻辑结果。记为 "},{"Type":"NodeTextMark","TextMarkType":"inline-math","TextMarkInlineMathContent":"\\Gamma \\Rightarrow H"},{"Type":"NodeText","Data":"。"}]}]}]},{"ID":"20260305082132-zzr2bby","Type":"NodeListItem","Data":"2.","ListData":{"Typ":1,"Tight":true,"Start":2,"Delimiter":46,"Padding":3,"Marker":"Mi4=","Num":2},"Properties":{"id":"20260305082132-zzr2bby","updated":"20260305082132"},"Children":[{"ID":"20260305082132-dxbymi3","Type":"NodeParagraph","Properties":{"id":"20260305082132-dxbymi3","updated":"20260305082132"},"Children":[{"Type":"NodeText","Data":"公式 "},{"Type":"NodeTextMark","TextMarkType":"em","TextMarkTextContent":"H"},{"Type":"NodeText","Data":" 是前提集合 "},{"Type":"NodeTextMark","TextMarkType":"inline-math","TextMarkInlineMathContent":"\\Gamma ={G_1,G_2,…,G_n}"},{"Type":"NodeText","Data":" 的逻辑结果当且仅当 "},{"Type":"NodeTextMark","TextMarkType":"inline-math","TextMarkInlineMathContent":"G_1\\land G_2\\land …\\land G_n\\to H"},{"Type":"NodeText","Data":" 为永真公式。"}]}]}]},{"ID":"20260305082132-enbczy8","Type":"NodeHeading","HeadingLevel":4,"Properties":{"id":"20260305082132-enbczy8","updated":"20260305082132"},"Children":[{"Type":"NodeHeadingC8hMarker