CloseMarker","Data":"```","CodeBlockFenceLen":3}]},{"ID":"20260305082131-ifetdw9","Type":"NodeParagraph","Properties":{"id":"20260305082131-ifetdw9","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"在派生类成员/"},{"Type":"NodeTextMark","TextMarkType":"block-ref","TextMarkBlockRefID":"20260305082130-32f4jyd","TextMarkBlockRefSubtype":"d","TextMarkTextContent":"友元"},{"Type":"NodeText","Data":" 函数内部（不论父子关系）："}]},{"ID":"20260305082131-wl20iao","Type":"NodeList","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20260305082131-wl20iao","updated":"20260305082131"},"Children":[{"ID":"20260305082131-nnsji0e","Type":"NodeListItem","Data":"-","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20260305082131-nnsji0e","updated":"20260305082131"},"Children":[{"ID":"20260305082131-zrv0qgj","Type":"NodeParagraph","Properties":{"id":"20260305082131-zrv0qgj","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"基类指针可以直接指向该派生类对象；"}]}]},{"ID":"20260305082131-n486r3x","Type":"NodeListItem","Data":"-","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20260305082131-n486r3x","updated":"20260305082131"},"Children":[{"ID":"20260305082131-di2zktb","Type":"NodeParagraph","Properties":{"id":"20260305082131-di2zktb","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"基类被等同地当作派生类的父类。"}]}]}]},{"ID":"20260305082131-fpg8zqh","Type":"NodeParagraph","Properties":{"id":"20260305082131-fpg8zqh","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"基类指针指向或引用派生类对象的作用：在父类有 "},{"Type":"NodeTextMark","TextMarkType":"block-ref","TextMarkBlockRefID":"20260305082130-gf29u2c","TextMarkBlockRefSubtype":"d","TextMarkTextContent":"虚函数"},{"Type":"NodeText","Data":" 时，对 "},{"Type":"NodeTextMark","TextMarkType":"block-ref","TextMarkBlockRefID":"20260305082130-gf29u2c","TextMarkBlockRefSubtype":"d","TextMarkTextContent":"