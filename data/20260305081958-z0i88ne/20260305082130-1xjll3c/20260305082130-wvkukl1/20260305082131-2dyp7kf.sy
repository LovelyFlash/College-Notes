":"20260305082131-0xdrhyn","updated":"20260305082131"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"Qysr"},{"Type":"NodeCodeBlockCode","Data":"A *p = \u0026b;\nZ = p-\u003egetx(); // 若 A 和 B 类都有 getx()，访问的是 A 类中的\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3}]},{"ID":"20260305082131-su0wbok","Type":"NodeParagraph","Properties":{"id":"20260305082131-su0wbok","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"派生类中访问基类函数，函数名前不需要加对象或对象指针。"}]},{"ID":"20260305082131-2tjprma","Type":"NodeHeading","HeadingLevel":1,"Properties":{"id":"20260305082131-2tjprma","updated":"20260305082131"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"# "},{"Type":"NodeText","Data":"构造和析构"}]},{"ID":"20260305082131-go0axrc","Type":"NodeParagraph","Properties":{"id":"20260305082131-go0axrc","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"派生类不能继承基类的构造函数、析构函数，拥有自己的构造函数、析构函数。"}]},{"ID":"20260305082131-81tw6ee","Type":"NodeParagraph","Properties":{"id":"20260305082131-81tw6ee","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"构造函数格式："}]},{"ID":"20260305082131-z18jmfg","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"Qysr","CodeBlockCloseFence":"YGBg","Properties":{"id":"20260305082131-z18jmfg","updated":"20260305082131"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"Qysr"},{"Type":"NodeCodeBlockCode","Data":"派生类名(参数表1):基类名(参数表2),其余派生类成员的构造 {\n\t函数体;\n}; // 若无基类名的构造，则执行基类中无参构造函数\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3}]},{"ID":"20260305082131-865i5c4","Type":"NodeParagraph","Properties":{"id":"20260305082131-865i5c4","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"定义派生类的移动构造函数时，参数表应该显示调用基类的移动构造函数，确保使用移动构造。"}]},{"ID":"20260305082131-gvblrq2","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"Qysr","CodeBlockCloseFence":"YGBg","Properties":{"id":"20260305082131-gvblrq2","updated":"20260305082131"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"Qysr"},{"Type":"NodeCodeBlockCode","Data":"class B : public A {\npublic:\n    std::vector\u003cint\u003e data;\n    \n    B(B\u0026\u0026 other) noexcept // B 的移动构造函数\n        : A(std::move(other)), // !!! 关键：显式调用 A 的移动构造函数\n          data(std::move(other.data)) // 移动 B 自己的成员\n    { std::cout \u003c\u003c \"B Move Ctor\" \u003c\u003c std::endl; }\n    \n    B(const B\u0026 other) // B 的拷贝构造函数\n        : A(other), // 调用 A 的拷贝构造函数\n          data(other.data) // 拷贝 B 自己的成员\n    { std::cout \u003c\u003c \"B Copy Ctor\" \u003c\u003c std::endl; }\n\n    // ... 其他构造函数和析构函数 ...\n};\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3}]},{"ID":"20260305082131-8q70zfi","Type":"NodeParagraph","Properties":{"id":"20260305082131-8q70zfi","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"单继承派生类只有一个（虚）基类，构造顺序优先级："}]},{"ID":"20260305082131-bjvxp2d","Type":"NodeList","ListData":{"Typ":1,"Tight":true,"Start":1,"Delimiter":46,"Padding":3,"Marker":"MS4=","Num":1},"Properties":{"id":"20260305082131-bjvxp2d","updated":"20260305082131"},"Children":[{"ID":"20260305082131-csxj2v8","Type":"NodeListItem","Data":"1.","ListData":{"Typ":1,"Tight":true,"Start":1,"Delimiter":46,"Padding":3,"Marker":"MS4=","Num":1},"Properties":{"id":"20260305082131-csxj2v8","updated":"20260305082131"},"Children":[{"ID":"20260305082131-di9kfvc","Type":"NodeParagraph","Properties":{"id":"20260305082131-di9kfvc","updated":"20260305082131"},"Children":[{"Type":"NodeText","Data":"调用派生类的虚基类的构造函数；（一定会执行）"}]}]},{"ID":"20260305082131-n