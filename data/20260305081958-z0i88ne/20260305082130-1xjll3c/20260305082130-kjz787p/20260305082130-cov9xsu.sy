g","HeadingLevel":1,"Properties":{"id":"20260305082130-8vrj8q7","updated":"20260305082130"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"# "},{"Type":"NodeText","Data":"2.1 可变参数函数"}]},{"ID":"20260305082130-am8rsu0","Type":"NodeParagraph","Properties":{"id":"20260305082130-am8rsu0","updated":"20260305082130"},"Children":[{"Type":"NodeText","Data":"在 C++ 中，函数可以接受可变数量的参数，这在某些需要灵活参数列表的场景中非常有用（例如 ⁠printf 函数）。实现可变参数函数有两种主要方式：C 风格的可变参数宏和现代 C++ 的可变参数模板。"}]},{"ID":"20260305082130-jfosup7","Type":"NodeHeading","HeadingLevel":1,"Properties":{"id":"20260305082130-jfosup7","updated":"20260305082130"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"# "},{"Type":"NodeText","Data":"2.1.1 C 风格的可变参数函数"}]},{"ID":"20260305082130-rr35f20","Type":"NodeParagraph","Properties":{"id":"20260305082130-rr35f20","updated":"20260305082130"},"Children":[{"Type":"NodeText","Data":"C 风格的可变参数函数使用省略号 ⁠"},{"Type":"NodeTextMark","TextMarkType":"code","TextMarkTextContent":"…"},{"Type":"NodeText","Data":" 来表示参数列表的其余部分是可变的。"}]},{"ID":"20260305082130-jgo7g0g","Type":"NodeList","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20260305082130-jgo7g0g","updated":"20260305082130"},"Children":[{"ID":"20260305082130-p5iwyqd","Type":"NodeListItem","Data":"-","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20260305082130-p5iwyqd","updated":"20260305082130"},"Children":[{"ID":"20260305082130-daqlnew","Type":"NodeParagraph","Properties":{"id":"20260305082130-daqlnew","updated":"20260305082130"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"语法："},{"Type":"NodeText","Data":" ⁠"},{"Type":"NodeTextMark","TextMarkType":"code","TextMarkTextContent":"ReturnType functionName(FixedArg1, FixedArg2, …);"}]}]},{"ID":"20260305082130-mmu8io7","Type":"NodeListItem","Data":"-","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20260305082130