pe":"d","TextMarkTextContent":"volatile 和 mutable"},{"Type":"NodeSoftBreak","Data":"\n"},{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"示例："}]},{"ID":"20260305082130-rkr1y18","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"Qysr","CodeBlockCloseFence":"YGBg","Properties":{"id":"20260305082130-rkr1y18","updated":"20260305082130"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"Qysr"},{"Type":"NodeCodeBlockCode","Data":"class MyClass {\n    int value;\n    mutable int accessCount; // accessCount 可以在 const 成员函数中修改\npublic:\n    MyClass(int v) : value(v), accessCount(0) {}\n    void getValue() const { // const 成员函数\n        accessCount++; // OK：accessCount 是 mutable\n        // value++; // 错误：value 不是 mutable\n        std::cout \u003c\u003c \"Value: \" \u003c\u003c value \u003c\u003c \", Accesses: \" \u003c\u003c accessCount \u003c\u003c std::endl;\n    }\n};\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3}]},{"ID":"20260305082130-a98xz8a","Type":"NodeParagraph","Properties":{"id":"20260305082130-a98xz8a","updated":"20260305082130"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"核心目的："},{"Type":"NodeText","Data":" 在保持对象逻辑 "},{"Type":"NodeTextMark","TextMarkType":"code","TextMarkTextContent":"const"},{"Type":"NodeText","Data":" 性的同时，允许修改其内部的物理状态。"}]},{"ID":"20260305082130-ey1usmi","Type":"NodeHeading","HeadingLevel":1,"Properties":{"id":"20260305082130-ey1usmi","updated":"20260305082130"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"# "},{"Type":"NodeText","Data":"7 ⁠"},{"Type":"NodeTextMark","TextMarkType":"code","TextMarkTextContent":"thread_local"},{"Type":"NodeText","Data":" (C++11)"}]},{"ID":"20260305082130-h0fnwie","Type":"NodeParagraph","Properties":{"id":"20260305082130-h0fnwie","updated":"20260305082130"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"作用："},{"Type":"NodeText","Data":" 指定变量具有"},{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"线程存储期 (Thread Storage Duration)"},{"Type":"NodeText","Data":"。"},{"Type":"NodeSoftBreak","Data":"\n"},{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"特点："},{"Type":"NodeText","Data":" 被 "},{"Type":"NodeTextMark","TextMarkType":"code","TextMarkTextContent":"⁠thread_local"},{"Type":"NodeText","Data":" 修饰的变量，每个线程都会拥有该变量的一个"},{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"独立副本"},{"Type":"NodeText","Data":"。当线程启动时，该变量的副本被创建；当线程结束时，该副本被销毁。"},{"Type":"NodeSoftBreak","Data":"\n"},{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"使用场景："},{"Type":"NodeText","Data":" 在多线程环境中，当需要为每个线程维护一份独立的状态数据，而又不希望这些数据成为全局共享资源时。"},{"Type":"NodeSoftBreak","Data":"\n"},{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"示例："}]},{"ID":"20260305082130-w0kdjxl","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"Qysr","CodeBlockCloseFence":"YGBg","Properties":{"id":"20260305082130-w0kdjxl","updated":"20260305082130"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"Qysr"},{"Type":"NodeCodeBlockCode","Data":"#include \u003ciostream\u003e\n#include \u003cthread\u003e\n#include \u003cstring\u003e\n\nthread_local int thread_specific_value = 1; // 每个线程都有自己的 thread_specific_value\n\nvoid func() {\n    thread_specific_value++;\n    std::cout \u003c\u003c \"Thread ID: \" \u003c\u003c std::this_thread::get_id()\n              \u003c\u003c \", Value: \" \u003c\u003c thread_specific_value \u003c\u003c std::endl;\n}\n\nint main() {\n    std::thread t1(func);\n    std::thread t2(func);\n    func(); // 主线程也调用一次\n    t1.join();\n    t2.join();\n\n    // 输出可能类似：\n    // Thread ID: 140735990000000, Value: 2 (主线程)\n    // Thread ID: 140735980000000, Value: 2 (线程 t1)\n    // Thread ID: 140735970000000, Value: 2 (线程 t2)\n    // 每个线程的 thread_specific_value 都是独立的\n    \n    return 0;\n}\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3}]},{"ID":"20260305082130-o44lsdj","Type":"NodeParagraph","Properties":{"id":"20260305082130-o44lsdj","updated":"20260305082130"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"核心目的："},{"Type":"NodeText","Data":" 提供线程局部存储，简化多线程编程中线程私有数据的管理。"}]},{"ID":"20260305082130-rgg2lnt","Type":"NodeHeading","HeadingLevel":1,"Properties":{"id":"20260305082130-rgg2lnt","updated":"20260305082130"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"# "},{"Type":"NodeText","Data":"8 ⁠"},{"Type":"NodeTextMark","TextMarkType":"code","TextMarkTextContent":"constexpr"},{"Type":"NodeText","Data":" (C++11)"}]},{"ID":"20260305082130-1tdycc0","Type":"NodeParagraph","Properties":{"id":"20260305082130-1tdycc0","updated":"20260305082130"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"作用："},{"Type":"NodeText","Data":" 指定变量的值可以在"},{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"编译时 (compile time)"},{"Type":"NodeText","Data":" 确定。"},{"Type":"NodeSoftBreak","Data":"\n"},{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"特点："},{"Type":"NodeText","Data":" 被 "},{"Type":"NodeTextMark","TextMarkType":"code","TextMarkTextContent":"⁠constexpr"},{"Type":"NodeText","Data":" 修饰的变量必须是常量表达式，即其值在编译时就能完全确定。"}]},{"ID":"20260305082130-5ekeqqs","Type":"NodeParagraph","Properties":{"id":"20260305082130-5ekeqqs","updated":"20260305082130"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"使用场景："}]},{"ID":"20260305082130-q5e4wvj","Type":"NodeList","ListData":{"Typ":1,"Tight":true,"Start":1,"Delimiter":46,"Padding":3,"Marker":"MS4=","Num":1},"Properties":{"id":"