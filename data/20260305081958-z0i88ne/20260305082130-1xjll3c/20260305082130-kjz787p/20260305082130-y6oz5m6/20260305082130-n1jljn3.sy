Type":"NodeText","Data":" 编译器会强制执行这一约束。"}]},{"ID":"20260305082130-sm1yyc6","Type":"NodeHeading","HeadingLevel":1,"Properties":{"id":"20260305082130-sm1yyc6","updated":"20260305082130"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"# "},{"Type":"NodeText","Data":"2 "},{"Type":"NodeTextMark","TextMarkType":"code","TextMarkTextContent":"const"},{"Type":"NodeText","Data":" 的使用场景"}]},{"ID":"20260305082130-hgmjoto","Type":"NodeParagraph","Properties":{"id":"20260305082130-hgmjoto","updated":"20260305082130"},"Children":[{"Type":"NodeTextMark","TextMarkType":"code","TextMarkTextContent":"const"},{"Type":"NodeText","Data":" 可以修饰变量、指针、引用、函数参数、函数返回值以及类的成员函数。"}]},{"ID":"20260305082130-qvayk44","Type":"NodeHeading","HeadingLevel":1,"Properties":{"id":"20260305082130-qvayk44","updated":"20260305082130"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"# "},{"Type":"NodeText","Data":"2.1 修饰变量"}]},{"ID":"20260305082130-75wmg6m","Type":"NodeParagraph","Properties":{"id":"20260305082130-75wmg6m","updated":"20260305082130"},"Children":[{"Type":"NodeText","Data":"常量变量：定义一个值不能被改变的变量。必须在声明时初始化。"},{"Type":"NodeSoftBreak","Data":"\n"},{"Type":"NodeTextMark","TextMarkType":"code","TextMarkTextContent":"const"},{"Type":"NodeText","Data":" 的位置："},{"Type":"NodeTextMark","TextMarkType":"code","TextMarkTextContent":"const"},{"Type":"NodeText","Data":" 可以在类型前或类型后，效果相同。"}]},{"ID":"20260305082130-kpo60xf","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"Qysr","CodeBlockCloseFence":"YGBg","Properties":{"id":"20260305082130-kpo60xf","updated":"20260305082130"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"Qysr"},{"Type":"NodeCodeBlockCode","Data":"const int MAX_VALUE = 100; // MAX_VALUE 是一个常量，不能被修改\n// MAX_VALUE = 200; // 错误\nint const MIN_VALUE = 0; // 与 const int MIN_VALUE = 0; 相同\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3}]},{"ID":"20260305082130-ea8b189","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20260305082130-ea8b189","updated":"20260305082130"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"## "},{"Type":"NodeText","Data":"2.2 修饰指针"}]},{"ID":"20260305082130-0t4ljdg","Type":"NodeParagraph","Properties":{"id":"20260305082130-0t4ljdg","updated":"20260305082130"},"Children":[{"Type":"NodeText","Data":"修饰指针时，"},{"Type":"NodeTextMark","TextMarkType":"code","TextMarkTextContent":"const"},{"Type":"NodeText","Data":" 的位置决定了是"},{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"指针本身"},{"Type":"NodeText","Data":"是常量，还是"},{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"指针指向的数据"},{"Type":"NodeText","Data":"是常量。"}]},{"ID":"20260305082130-um20kav","Type":"NodeParagraph","Properties":{"id":"20260305082130-um20kav","updated":"20260305082130"},"Children":[{"Type":"NodeText","Data":"可以将一个指针赋给一个常量指针，但不能将一个常量指针赋给一个指针"}]},{"ID":"20260305082130-hf6uicl","Type":"NodeParagraph","Properties":{"id":"20260305082130-hf6uicl","updated":"20260305082130"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"1. 指向常量的指针："},{"Type":"NodeText","Data":" 数据是常量，指针可以改变。"},{"Type":"NodeSoftBreak","Data":"\n"},{"Type":"NodeTextMark","TextMarkType":"code","TextMarkTextContent":"const int* ptr;"},{"Type":"NodeText","Data":" 或 "},{"Type":"NodeTextMark","TextMarkType":"code","TextMarkTextContent":"int const* ptr;"},{"Type":"NodeSoftBreak","Data":"\n"},{"Type":"NodeText","Data":"指针 "},{"Type":"NodeTextMark","TextMarkType":"code","TextMarkTextContent":"ptr"},{"Type":"NodeText","Data":" 可以指向不同的 int 变量，但不能通过 ptr 来修改它所指向的 int 变量的值。"}]},{"ID":"20260305082130-vxoxs49","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"Qysr","CodeBlockCloseFence":"YGBg","Properties":{"id":"20260305082130-vxoxs49","updated":"20260305082130"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"Qysr"},{"Type":"NodeCodeBlockCode","Data":"int a = 10, b = 20;\nconst int* ptr = \u0026a; // ptr 指向常量 int\n// *ptr = 15; // 错误：不能通过 ptr 修改 a 的值\nptr = \u0026b;    // OK：ptr 可以指向另一个变量\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3}]},{"ID":"20260305082130-wha0ypf","Type":"NodeParagraph","Properties":{"id":"20260305082130-wha0ypf","updated":"20260305082130"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"2. 常量指针："},{"Type":"NodeText","Data":" 指针本身是常量，不能改变指向，但指向的数据可以改变。"},{"Type":"NodeSoftBreak","Data":"\n"},{"Type":"NodeTextMark","TextMarkType":"code","TextMarkTextContent":"int* const ptr;"},{"Type":"NodeSoftBreak","Data":"\n"},{"Type":"NodeText","Data":"指针 "},{"Type":"NodeTextMark","TextMarkType":"code","TextMarkTextContent":"ptr"},{"Type":"NodeText","Data":" 一旦初始化，就不能再指向其他变量，但可以通过 "},{"Type":"NodeTextMark","TextMarkType":"code","TextMarkTextContent":"ptr"},{"Type":"NodeText","Data":" 来修改它所指向的 "},{"Type":"NodeTextMark","TextMarkType":"code","TextMarkTextContent":"int"},{"Type":"NodeText","Data":" 变量的值。"}]},{"ID":"20260305082130-rzmoic2","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"Qysr","CodeBlockCloseFence":"YGBg","Properties":{"id":"20260305082130-rzmoic2","updated":"20260305082130"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"Qysr"},{"Type":"NodeCodeBlockCode","Data":"int a = 10, b = 20;\nint* const ptr = \u0026a; // ptr 是一个常量指针，必须初始化\n*ptr = 15; // OK：可以通过 ptr 修改 a 的值\n// ptr = \u0026b; // 错误：ptr 是常量，不能改变指向\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3}]},{"ID":"20260305082130-bouixe6","Type":"NodeParagraph","Properties":{"id":"20260305082130-bouixe6","updated":"20260305082130"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"3. 指向常量的常量指针："},{"Type":"NodeText","Data":" 指针和它指向的数据都是常量。"},{"Type":"NodeSoftBreak","Data":"\n"},{"Type":"NodeTextMark","TextMarkType":"code","TextMarkTextContent":"const int* const ptr;"},{"Type":"NodeSoftBreak","Data":"\n"},{"Type":"NodeText","Data":"既不能通过 ptr 修改数据，也不能改变 ptr 的指向。"}]},{"ID":"20260305082130-26spjbi","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockFenceOffset":2,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"Qysr","CodeBlockCloseFence":"YGBg","Properties":{"id":"20260305082130-26spjbi","updated":"20260305082130"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"Qysr"},{"Type":"NodeCodeBlockCode","Data":"int a = 10;\nconst int* const ptr = \u0026a;\n// *ptr = 15; // 错误\n// ptr = \u0026b; // 错误\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3}]},{"ID":"20260305082130-3aw6hl0","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20260305082130-3aw6hl0","updated":"20260305082130"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"## "},{"Type":"NodeText","Data":"2.3 修饰引用"}]},{"ID":"20260305082130-eemj4yy","Type":"NodeParagraph","Properties":{"id":"20260305082130-eemj4yy","updated":"20260305082130"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"常量引用 (Reference to const)："},{"Type":"NodeText","Data":" 引用所绑定的数据是常量，不能通过引用修改数据。"},{"Type":"NodeSoftBreak","Data":"\n"},{"Type":"NodeTextMark","TextMarkType":"code","TextMarkTextContent":"const int\u0026amp; ref = x;"},{"Type":"NodeSoftBreak","Data":"\n"},{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"重要特性："},{"Type":"NodeText","Data":" const 引用可以绑定到"},{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"左值"},{"Type":"NodeText","Data":"，也可以绑定到"},{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"右值"},{"Type":"NodeText","Data":"（临时对象），并且在绑定到右值时会延长右值的生命周期。"}]},{"ID":"20260305082130-hzl1c8u","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"Qysr","CodeBlockCloseFence":"YGBg","Properties":{"id":"20260305082130-hzl1c8u","updated":"20260305082130"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"Qysr"},{"Type":"NodeCodeBlockCode","Data":"int a = 10;\nconst int\u0026 ref = a; // ref 绑定到 a，不能通过 ref 修改 a\n// ref = 15; // 错误\nconst int\u0026 temp_ref = 20; // OK：const 引用可以绑定到右值 20\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3}]},{"ID":"20260305082130-9jbws1j","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20260305082130-9jbws1j","updated":"20260305082130"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"## "},{"Type":"NodeText","Data":"2.4 修饰函数参数"}]},{"ID":"20260305082130-dullnrd","Type":"NodeParagraph","Properties":{"id":"20260305082130-dullnrd","updated":"20260305082130"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"防止函数修改参数："},{"Type":"NodeText","Data":" 当参数以 const 引用或 const 指针传递时，函数内部不能修改该参数所指向或引用的数据。"},{"Type":"NodeSoftBreak","Data":"\n"},{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"优势："},{"Type":"NodeText","Data":" 提高函数安全性，明确函数意图，避免不必要的拷贝（对于大对象）。"}]},{"ID":"20260305082130-rklj6i2","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockFenceOffset":2,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"Qysr","CodeBlockCloseFence":"YGBg","Properties":{"id":"20260305082130-rklj6i2","updated":"20260305082130"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"Qysr"},{"Type":"NodeCodeBlockCode","Data":"void printValue(const int\u0026 value) {\n    // value = 10; // 错误：不能修改 const 引用\n    std::cout \u003c\u003c value \u003c\u003c std::endl;\n}\n\nvoid processData(const std::vector\u003cint\u003e* data) {\n    // (*data)[0] = 5; // 错误：不能通过 const 指针修改数据\n}\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3}]},{"ID":"20260305082130-min4au9","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20260305082130-min4au9","updated":"20260305082130"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"## "},{"Type":"NodeText","Data":"2.5 修饰函数返回值"}]},{"ID":"20260305082130-vldpwb8","Type":"NodeParagraph","Properties":{"id":"20260305082130-vldpwb8","updated":"20260305082130"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"返回常量值："},{"Type":"NodeText","Data":" 函数返回一个 const 值。"},{"Type":"NodeSoftBreak","Data":"\n"},{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"目的："},{"Type":"NodeText","Data":" 防止对函数返回的临时对象进行修改。"},{"Type":"NodeSoftBreak","Data":"\n"},{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"注意："},{"Type":"NodeText","Data":" 对于按值返回，通常是多余的，因为临时对象本身不能被修改。对于返回引用或指针，const 才有实际意义。"}]},{"ID":"20260305082130-a1k984a","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"Qysr","CodeBlockCloseFence":"YGBg","Properties":{"id":"20260305082130-a1k984a","updated":"20260305082130"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"Qysr"},{"Type":"NodeCodeBlockCode","Data":"const std::string getGreeting() {\n    return \"Hello\";\n}\n// getGreeting() = \"Hi\"; // 错误：不能修改 const 返回值\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3}]},{"ID":"20260305082130-7knl7dc","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20260305082130-7knl7dc","updated":"20260305082130"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"## "},{"Type":"NodeText","Data":"2.6 修饰成员函数 (const 成员函数)"}]},{"ID":"20260305082130-devziuo","Type":"NodeParagraph","Properties":{"id":"20260305082130-devziuo","updated":"20260305082130"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"语法："},{"Type":"NodeText","Data":" 在成员函数声明和定义末尾加上 const 关键字。"},{"Type":"NodeSoftBreak","Data":"\n"},{"Type":"NodeTextMark","TextMarkType":"code","TextMarkTextContent":"ReturnType memberFunction() const;"},{"Type":"NodeSoftBreak","Data":"\n"},{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"目的："},{"Type":"NodeText","Data":" 承诺该成员函数不会修改对象的任何"},{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"非"},{"Type":"NodeText","Data":" "},{"Type":"NodeTextMark","TextMarkType":"code","TextMarkTextContent":"mutable"},{"Type":"NodeText","Data":" "},{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"数据成员"},{"Type":"NodeText","Data":"。"}]},{"ID":"20260305082130-9qqcqom","Type":"NodeParagraph","Properties":{"id":"20260305082130-9qqcqom","updated":"20260305082130"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"优势："}]},{"ID":"20260305082130-zbm9sht","Type":"NodeList","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20260305082130-zbm9sht","updated":"20260305082130"},"Children":[{"ID":"20260305082130-0z14m7y","Type":"NodeListItem","Data":"-","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20260305082130-0z14m7y","updated":"20260305082130"},"Children":[{"ID":"20260305082130-m9y14kc","Type":"NodeParagraph","Properties":{"id":"20260305082130-m9y14kc","updated":"20260305082130"},"Children":[{"Type":"NodeTextMark","TextMarkType":"code","TextMarkTextContent":"const"},{"Type":"NodeText","Data":" "},{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"对象调用："},{"Type":"NodeText","Data":" 只有 const 成员函数才能被 const 对象调用。这使得你的类接口更加健壮。"}]}]},{"ID":"20260305082130-jsw4gjn","Type":"NodeListItem","Data":"-","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20260305082130-jsw4gjn","updated":"20260305082130"},"Children":[{"ID":"20260305082130-u4gu9r3","Type":"NodeParagraph","Properties":{"id":"20260305082130-u4gu9r3","updated":"20260305082130"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"安全性："},{"Type":"NodeText","Data":" 保证了对象的状态不会被意外改变。"}]}]},{"ID":"20260305082130-wut8q3f","Type":"NodeListItem","Data":"-","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20260305082130-wut8q3f","updated":"20260305082130"},"Children":[{"ID":"20260305082130-d34fli0","Type":"NodeParagraph","Properties":{"id":"20260305082130-d34fli0","updated":"20260305082130"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"重载："},{"Type":"NodeText","Data":" const 和非 const 成员函数可以重载，允许根据对象的 const 属性调用不同的版本。"}]}]}]},{"ID":"20260305082130-pzavivn","Type":"NodeParagraph","Properties":{"id":"20260305082130-pzavivn","updated":"20260305082130"},"Children":[{"Type":"NodeTextMark","TextMarkType":"code","TextMarkTextContent":"mutable"},{"Type":"NodeText","Data":" "},{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"关键字："},{"Type":"NodeSoftBreak","Data":"\n"},{"Type":"NodeText","Data":"可以修饰类的非静态数据成员。被 "},{"Type":"NodeTextMark","TextMarkType":"code","TextMarkTextContent":"mutable"},{"Type":"NodeText","Data":" 修饰的成员即使在 "},{"Type":"NodeTextMark","TextMarkType":"code","TextMarkTextContent":"const"},{"Type":"NodeText","Data":" 成员函数中也可以被修改。这通常用于那些不影响对象逻辑状态，但需要内部缓存或统计的成员。"}]},{"ID":"20260305082130-ajlpvrd","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"Qysr","CodeBlockCloseFe