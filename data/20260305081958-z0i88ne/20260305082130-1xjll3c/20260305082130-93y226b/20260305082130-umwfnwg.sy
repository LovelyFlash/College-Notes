5082130-2njgj8x","updated":"20260305082130"},"Children":[{"ID":"20260305082130-gnqk8b6","Type":"NodeParagraph","Properties":{"id":"20260305082130-gnqk8b6","updated":"20260305082130"},"Children":[{"Type":"NodeText","Data":"如果使用 "},{"Type":"NodeTextMark","TextMarkType":"code","TextMarkTextContent":"new"},{"Type":"NodeText","Data":" 分配了内存，但没有使用 "},{"Type":"NodeTextMark","TextMarkType":"code","TextMarkTextContent":"delete"},{"Type":"NodeText","Data":" 释放，就会导致内存泄漏。在复杂的程序中，确保每一个 "},{"Type":"NodeTextMark","TextMarkType":"code","TextMarkTextContent":"new"},{"Type":"NodeText","Data":" 都有对应的 "},{"Type":"NodeTextMark","TextMarkType":"code","TextMarkTextContent":"delete"},{"Type":"NodeText","Data":" 可能会很困难，尤其是在异常发生时。"}]}]},{"ID":"20260305082130-eue1mdf","Type":"NodeListItem","Data":"-","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20260305082130-eue1mdf","updated":"20260305082130"},"Children":[{"ID":"20260305082130-x4p9ykl","Type":"NodeParagraph","Properties":{"id":"20260305082130-x4p9ykl","updated":"20260305082130"},"Children":[{"Type":"NodeText","Data":"当指针指向的内存已经被释放，但指针仍然保留着原来的地址，这时就产生了悬空指针。如果后续通过这个悬空指针访问内存，会导致未定义行为。"}]}]},{"ID":"20260305082130-hm938wu","Type":"NodeListItem","Data":"-","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20260305082130-hm938wu","updated":"20260305082130"},"Children":[{"ID":"20260305082130-aj24vdh","Type":"NodeParagraph","Properties":{"id":"20260305082130-aj24vdh","updated":"20260305082130"},"Children":[{"Type":"NodeText","Data":"同一个内存块被释放两次（重复释放），这会导致运行时错误。"}]}]},{"ID":"20260305082130-kngz91x","Type":"NodeListItem","Data":"-","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20260305082130-kngz91x","updated":"20260305082130"},"Children":[{"ID":"20260305082130-rb7urbo","Type":"NodeParagraph","Properties":{"id":"20260305082130-rb7urbo","updated":"20260305082130"},"Children":[{"Type":"NodeText","Dat