```","CodeBlockFenceLen":3}]},{"ID":"20260305082130-j32r19g","Type":"NodeParagraph","Properties":{"id":"20260305082130-j32r19g","updated":"20260305082130"},"Children":[{"Type":"NodeText","Data":"取函数地址时，有无 "},{"Type":"NodeTextMark","TextMarkType":"code","TextMarkTextContent":"\u0026amp;"},{"Type":"NodeText","Data":" 一样；调用 "},{"Type":"NodeTextMark","TextMarkType":"block-ref","TextMarkBlockRefID":"20260305082130-3tloe19","TextMarkBlockRefSubtype":"d","TextMarkTextContent":"函数指针"},{"Type":"NodeText","Data":" 时，有无 "},{"Type":"NodeTextMark","TextMarkType":"code","TextMarkTextContent":"*"},{"Type":"NodeText","Data":" 一样。"}]},{"ID":"20260305082130-zgffrlx","Type":"NodeParagraph","Properties":{"id":"20260305082130-zgffrlx","updated":"20260305082130"},"Children":[{"Type":"NodeText","Data":"\u003cfont color=\"#d83931\"\u003e成员函数指针\u003c/font\u003e的定义和使用："}]},{"ID":"20260305082130-m9e1e8u","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"Qysr","CodeBlockCloseFence":"YGBg","Properties":{"id":"20260305082130-m9e1e8u","updated":"20260305082130"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"Qysr"},{"Type":"NodeCodeBlockCode","Data":"class Student { \n\tpublic:\n\t\tvoid SetNumber(int x) { \n\t\t\tnumber=x; \n\t\t} \n}; \nStudent xu(123,\"Xu\",100); \nvoid (Student:: *pf) (int) ; //成员函数指针定义 \nvoid (*pq)(int) ; // 函数指针 \npf=\u0026Student::SetNumber; \n(xu.*pf)(200); \nxu.SetNumber(200); // 等同语句\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3}]},{"ID":"20260305082130-thng6p9","Type":"NodeParagraph","Properties":{"id":"20260305082130-thng6p9","updated":"20260305082130"},"Children":[{"Type":"NodeText","Data":"使用实例成员指针访问成员时必须和对象关联，通过 "},{"Type":"NodeTextMark","TextMarkType":"code","TextMarkTextContent":"object.*memberpointer"},{"Type":"NodeText","Data":" 和 "},{"Type":"NodeTextMark","TextMarkType":"code","TextMarkTextContent":"objectpointer-\u0026gt;*memberpointer"},{"Type":"NodeText","Data":" 访问对象成员。"}]},{"ID":"20260305082130-fxzfevz","Type":"NodeParagraph","Properties":{"id":"20260305082130-fxzfevz","updated":"20260305082130"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"成员指针相比于普通指针的优势"},{"Type":"NodeText","Data":"："}]},{"ID":"20260305082130-denymjc","Type":"NodeList","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20260305082130-denymjc","updated":"20260305082130"},"Children":[{"ID":"20260305082130-j0b8ocz","Type":"NodeListItem","Data":"-","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20260305082130-j0b8ocz","updated":"20260305082130"},"Children":[{"ID":"20260305082130-a9224l4","Type":"NodeParagraph","Properties":{"id":"20260305082130-a9224l4","updated":"20260305082130"},"Children":[{"Type":"NodeText","Data":"抽象和泛化编程"}]}]},{"ID":"20260305082130-tko2vji","Type":"NodeListItem","Data":"-","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20260305082130-tko2vji","updated":"20260305082130"},"Children":[{"ID":"20260305082130-5q8xsbt","Type":"NodeParagraph","Properties":{"id":"20260305082130-5q8xsbt","updated":"20260305082130"},"Children":[{"Type":"NodeText","Data":"类型安全"}]}]},{"ID":"20260305082130-jlwmg0j","Type":"NodeListItem","Data":"-","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20260305082130-jlwmg0j","updated":"20260305082130"},"Children":[{"ID":"20260305082130-ml08vqz","Type":"NodeParagraph","Properties":{"id":"20260305082130-ml08vqz","updated":"20260305082130"},"Children":[{"Type":"NodeText","Data":"封装性的补充（不会暴露内存布局）"}]}]},{"ID":"20260305082130-jqf1n02","Type":"NodeListItem","Data":"-","ListData":{"Tight":true,"BulletChar":45,"Padding":2,"Marker":"LQ==","Num":-1},"Properties":{"id":"20260305082130-jqf1n02","updated":"20260305082130"},"Children":[{"ID":"20260305082130-ciplz6o","Type":"NodeParagraph","Properties":{"id":"20260305082130-ciplz6o","updated":"20260305082130"},"Children":[{"Type":"NodeText","Data":"与虚函数的结合"}]}]}]},{"ID":"20260305082130-dvhaf5m","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20260305082130-dvhaf5m","updated":"20260305082130"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"## "},{"Type":"NodeText","Data":"2 静态成员指针"}]},{"ID":"20260305082130-u925jlw","Type":"NodeParagraph","Properties":{"id":"20260305082130-u925jlw","updated":"20260305082130"},"Children":[{"Type":"NodeText","Data":"静态成员相当于具有访问权限的变量和函数，同普通变量和函数相比，除访问权限外没有区别。因此，静态成员指针和普通指针形式上也没有区别。"}]},{"ID":"20260305082130-f5aegc8","Type":"NodeTable","Data":"| 静态成员指针   | 实例成员指针   |\n| -------- | -------- |\n| 存放静态成员地址 | 存放普通成员偏移 |\n| 可以移动     | 不能移动     |\n| 可以转换类型   | 不能转换类型   |","TableAligns":[0,0],"Properties":{"id":"20260305082130-f5aegc8","updated":"20260305082130"},"Children":[{"Type":"NodeTableHead","Children":[{"Type":"NodeTableRow","Children":[{"Type":"NodeTableCell","Children":[{"Type":"NodeText","Data":"静态成员指针"}]},{"Type":"NodeTableCell","Children":[{"Type":"NodeText","Data":"实例成员指针"}]}]}]},{"Type":"NodeTableRow","TableAligns":[0,0],"Children":[{"Type":"NodeTableCell","Children":[{"Type":"NodeText","Data":"存放静态成员地址"}]},{"Type":"NodeTableCell","Children":[{"Type":"NodeText","Data":"存放普通成员偏移"}]}]},{"Type":"NodeTableRow","TableAligns":[0,0],"Children":[{"Type":"NodeTableCell","Children":[{"Type":"NodeText","Data":"可以移动"}]},{"Type":"NodeTableCell","Children":[{"Type":"NodeText","Data":"不能移动"}]}]},{"Type":"NodeTableRow","TableAligns":[0,0],"Children":[{"Type":"NodeTableCell","Children":[{"Type":"NodeText","Data":"可以转换类型"}]},{"Type":"NodeTableCell","Children":[{"Type":"NodeText","Data":"不能转换类型"}]}]}]}]}