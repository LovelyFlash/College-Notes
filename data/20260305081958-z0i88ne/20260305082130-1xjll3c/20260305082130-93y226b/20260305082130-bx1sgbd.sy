oMarker","CodeBlockInfo":"Qysr"},{"Type":"NodeCodeBlockCode","Data":"struct A{\n\tint a;\n\tA(int x) { a=x; }\n};\n\nclass B{\n\tA x;\npublic:\n\tA *operator -\u003e( ){ return \u0026x; }; // 重载-\u003e\n\tB(int v):x(v) { }\n}b(5);\n\nvoid main(void){\n\tint i=b-\u003ea; //等价于下一条语句，i=b.x.a=5\n\ti=b.operator -\u003e( )-\u003ea; //i=b.x.a=5\n\ti =( b.operator -\u003e( )) -\u003ea;\n\ti=*(b.operator-\u003e( )).a; //i = b.operator -\u003e( )-\u003ea\n}\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3}]},{"ID":"20260305082130-uhh3ksh","Type":"NodeHeading","HeadingLevel":1,"Properties":{"id":"20260305082130-uhh3ksh","updated":"20260305082130"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"# "},{"Type":"NodeText","Data":"3 强制类型转换"}]},{"ID":"20260305082130-kmtcgei","Type":"NodeParagraph","Properties":{"id":"20260305082130-kmtcgei","updated":"20260305082130"},"Children":[{"Type":"NodeText","Data":"强制类型转换的格式为 "},{"Type":"NodeTextMark","TextMarkType":"code","TextMarkTextContent":"operator class1()；"},{"Type":"NodeText","Data":"，无参数，无返回值，用于将 "},{"Type":"NodeTextMark","TextMarkType":"code","TextMarkTextContent":"ClassName"},{"Type":"NodeText","Data":" 转化为 "},{"Type":"NodeTextMark","TextMarkType":"code","TextMarkTextContent":"class1"},{"Type":"NodeText","Data":"。类型转换的结果通常为\u003cfont color=\"#d83931\"\u003e右值\u003c/font\u003e，也不应当修改当前被转换对象。"}]},{"ID":"20260305082130-ie1g8ey","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"Qysr","CodeBlockCloseFence":"YGBg","Properties":{"id":"20260305082130-ie1g8ey","updated":"20260305082130"},"Children":[{"Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"Qysr"},{"Type":"NodeCodeBlockCode","Data":"class COMPLEX { \n\tdouble r, v; \npublic: \n\tCOMPLEX(double r1, double v1=0) { // double 转换为 complex\n\t\tr=r1; v=v1; \n\t} // 构造函数可以用于强制类型转换\n\toperator double() { // conplex 转换为 double\n\t\treturn r; \n\t} // 强制类型转换函数： operator 类型(……)\n\tCOMPLEX operator+(const COMPLEX \u0026c)const; \n\tCOMPLEX operator**-**(const COMPLEX \u0026c)const; \n};\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3}]},{"ID":"20260305082130-ky31kbe","Type":"NodeParagraph","Properties":{"id":"20260305082130-ky31kbe","updated":"20260305082130"},"Children":[{"Type":"NodeText","Data":"单参数的构造函数具备类型转换作用，用于将其他类型转化为当前定义的类型，能自动将参数类型的值转换为要构造的类型。关键字 "},{"Type":"NodeTextMark","TextMarkType":"code","TextMarkTextContent":"explicit"},{"Type":"NodeText","Data":"，用来\u003cfont color=\"#d83931\"\u003e禁止隐式类型转换\u003c/font\u003e。"},{"Type":"NodeSoftBreak","Data":"\n"},{"Type":"NodeText","Data":"用其修饰单参数构造函数（或多参数，但提供缺省值）时，禁止其作为类型转换。"},{"Type":"NodeSoftBreak","Data":"\n"},{"Type":"NodeTextMark","TextMarkType":"code","TextMarkTextContent":"String s(\"hello\")"},{"Type":"NodeText","Data":" 为显示构造；"},{"Type":"NodeTextMark","TextMarkType":"code","TextMarkTextContent":"String s = \"hello\""},{"Type":"NodeText","Data":" 为隐式转换。"}]},{"ID":"20260305082130-iucypxh","Type":"NodeHeading","HeadingLevel":1,"Properties":{"id":"20260305082130-iucypxh","updated":"20260305082130"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"# "},{"Type":"NodeText","Data":"4 重载 new 和 delete"}]},{"ID":"20260305082130-70etek5","Type":"NodeParagraph","Properties":{"id":"20260305082130-70etek5","updated":"20260305082130"},"Children":[{"Type":"NodeTextMark","TextMarkType":"code","TextMarkTextContent":"new"},{"Type":"NodeText","Data":" 和 "},{"Type":"NodeTextMark","TextMarkType":"code","TextMarkTextContent":"delete"},{"Type":"NodeText","Data":" 可以重载为\u003cfont color=\"#c0504d\"\u003e普通函数\u003c/font\u003e和\u003cfont color=\"#c0504d\"\u003e静态函数成员\u003c/font\u003e。"}]},{"ID":"20260305082130-w4e1s9n","Type":"NodeCodeBlock","IsFencedCodeBlock":true,"CodeBlockFenceChar":96,"CodeBlockFenceLen":3,"CodeBlockOpenFence":"YGBg","CodeBlockInfo":"Qysr","CodeBlockCloseFence":"YGBg"