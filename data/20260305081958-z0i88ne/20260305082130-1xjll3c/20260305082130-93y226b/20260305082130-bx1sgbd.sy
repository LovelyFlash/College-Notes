Type":"NodeCodeBlockFenceOpenMarker","Data":"```","CodeBlockFenceLen":3},{"Type":"NodeCodeBlockFenceInfoMarker","CodeBlockInfo":"Qysr"},{"Type":"NodeCodeBlockCode","Data":"// 恰当定义方法: ClassName \u0026 operator=(ClassName \u0026\u0026obj)；\nMAT\u0026 MAT::operator=(MAT \u0026\u0026 a) { //移动赋值运算 \n\tif (this == \u0026a) \n\t\treturn *this; \n\tcout \u003c\u003c \"moving assign operation ...\" \u003c\u003c endl; \n\tr = a.r; \n\tc = a.c; \n\tif (e) \n\t\tdelete e; \n\te = a.e; \n\ta.e = nullptr; \n\treturn *this;\n}\n"},{"Type":"NodeCodeBlockFenceCloseMarker","Data":"```","CodeBlockFenceLen":3}]},{"ID":"20260305082130-oxoaltf","Type":"NodeParagraph","Properties":{"id":"20260305082130-oxoaltf","updated":"20260305082130"},"Children":[{"Type":"NodeText","Data":"重载 "},{"Type":"NodeTextMark","TextMarkType":"code","TextMarkTextContent":"+="},{"Type":"NodeText","Data":"、"},{"Type":"NodeTextMark","TextMarkType":"code","TextMarkTextContent":"-="},{"Type":"NodeText","Data":"、"},{"Type":"NodeTextMark","TextMarkType":"code","TextMarkTextContent":"*="},{"Type":"NodeText","Data":"：定义类似深拷贝。"},{"Type":"NodeSoftBreak","Data":"\n"},{"Type":"NodeTextMark","TextMarkType":"code","TextMarkTextContent":"ClassName\u0026amp; operator +=(const ClassName\u0026amp;obj);"}]},{"ID":"20260305082130-mb352tm","Type":"NodeHeading","HeadingLevel":2,"Properties":{"id":"20260305082130-mb352tm","updated":"20260305082130"},"Children":[{"Type":"NodeHeadingC8hMarker","Data":"## "},{"Type":"NodeText","Data":"2.2 重载 "},{"Type":"NodeTextMark","TextMarkType":"code","TextMarkTextContent":"+"},{"Type":"NodeText","Data":"、"},{"Type":"NodeTextMark","TextMarkType":"code","TextMarkTextContent":"-"},{"Type":"NodeText","Data":" 等："}]},{"ID":"20260305082130-f7t3njf","Type":"NodeParagraph","Properties":{"id":"20260305082130-f7t3njf","updated":"20260305082130"},"Children":[{"Type":"NodeTextMark","TextMarkType":"code","TextMarkTextContent":"ClassName operator +(const ClassName \u0026amp; obj) const;"}]},{"ID":"20260305082130