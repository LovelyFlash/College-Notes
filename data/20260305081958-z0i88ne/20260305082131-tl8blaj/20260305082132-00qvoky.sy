2132-88il4j9","updated":"20260305082132"},"Children":[{"Type":"NodeMathBlockOpenMarker"},{"Type":"NodeMathBlockContent","Data":"- **磁通量**"},{"Type":"NodeMathBlockCloseMarker"}]},{"ID":"20260305082132-cjzx7e1","Type":"NodeParagraph","Properties":{"id":"20260305082132-cjzx7e1","updated":"20260305082132"},"Children":[{"Type":"NodeText","Data":"\\large\\varPhi=\\iint_S\\vec{B}\\cdot\\d\\vec{S}"}]},{"ID":"20260305082132-n43cum6","Type":"NodeMathBlock","Properties":{"id":"20260305082132-n43cum6","updated":"20260305082132"},"Children":[{"Type":"NodeMathBlockOpenMarker"},{"Type":"NodeMathBlockContent","Data":"- **全磁通**\n\n对于多匝线圈，各匝的磁通量分别为 $\\varPhi_1,\\varPhi_2,…,\\varPhi_N$，则"},{"Type":"NodeMathBlockCloseMarker"}]},{"ID":"20260305082132-yj79d9v","Type":"NodeParagraph","Properties":{"id":"20260305082132-yj79d9v","updated":"20260305082132"},"Children":[{"Type":"NodeText","Data":"\\large \\varPsi=\\sum_{i=1}^N\\varPhi_i"}]},{"ID":"20260305082132-le2t0dd","Type":"NodeMathBlock","Properties":{"id":"20260305082132-le2t0dd","updated":"20260305082132"},"Children":[{"Type":"NodeMathBlockOpenMarker"},{"Type":"NodeMathBlockContent","Data":"### 2.电磁感应定律\n\n当回路中的磁通量发生变化时，回路中会产生感应电动势"},{"Type":"NodeMathBlockCloseMarker"}]},{"ID":"20260305082132-29b536a","Type":"NodeParagraph","Properties":{"id":"20260305082132-29b536a","updated":"20260305082132"},"Children":[{"Type":"NodeText","Data":"\\large \\varepsilon=-\\dfrac{\\d\\varPhi}{\\d t}\\left(=-\\dfrac{\\d\\varPsi}{\\d t}\\right)"}]},{"ID":"20260305082132-kk6yw5c","Type":"NodeMathBlock","Properties":{"id":"20260305082132-kk6yw5c","updated":"20260305082132"},"Children":[{"Type":"NodeMathBlockOpenMarker"},{"Type":"NodeMathBlockContent","Data":"\u003e 电动势正方向由磁通量正方向根据右手定则确定\n\n### 3.动生电动势\n\n在磁场中切割磁感线运动的导体棒会产生电动势"},{"Type":"NodeMathBlockCloseMarker"}]},{"ID":"20260305082132-e16pnyd","Type":"NodeParagraph","Properties":{"id":"20260305082132-e16pnyd","updated":"20260305082132"},"Children":[{"Type":"NodeText","Data":"\\large \\d\\varepsilon=(\\vec{v}\\times\\vec{B})\\cdot\\d\\vec{l}"}]},{"ID":"20260305082132-79ymh00","Type":"NodeMathBlock","Properties":{"id":"20260305082132-79ymh00","updated":"20260305082132"},"Children":[{"Type":"NodeMathBlockOpenMarker"},{"Type":"NodeMathBlockContent","Data":"\u003e 产生电动势不要求构成回路，构成回路仅仅是可以形成电流\n\n### 4.感生电动势 感应电场\n\n变化的磁场会激发出感应电场"},{"Type":"NodeMathBlockCloseMarker"}]},{"ID":"20260305082132-o6huce9","Type":"NodeParagraph","Properties":{"id":"20260305082132-o6huce9","updated":"20260305082132"},"Children":[{"Type":"NodeText","Data":"\\large\\varepsilon_i=\\oint_L\\vec{E}_i\\cdot\\d\\vec{l}=-\\iint\\dfrac{\\partial\\vec{B}}{\\partial t}\\cdot\\d\\vec{S}"}]},{"ID":"20260305082132-kwbljx6","Type":"NodeMathBlock","Properties":{"id":"20260305082132-kwbljx6","updated":"20260305082132"},"Children":[{"Type":"NodeMathBlockOpenMarker"},{"Type":"NodeMathBlockContent","Data":"\u003e 可见感应电场做功与路径有关\n\n导体棒感生电动势求法\n\n- 通过感应电场定义求出感应电场，再根据电动势定义求出\n![[定义法求感生电动势.svg]]\n- 对称分布的磁场中，半径方向电动势为零。利用半径构造回路再通过电磁感应定律求出\n![[公式法求感生电动势.svg]]\n\n### 5.互感\n\n- 互感系数"},{"Type":"NodeMathBlockCloseMarker"}]},{"ID":"20260305082132-ud4orkr","Type":"NodeParagraph","Properties":{"id":"20260305082132-ud4orkr","updated":"20260305082132"},"Children":[{"Type":"NodeText","Data":"\\large \\varPsi_{12}=Mi_1,\\quad\\varPsi_{21}=Mi_2"}]},{"ID":"20260305082132-865i3po","Type":"NodeMathBlock","Properties":{"id":"20260305082132-865i3po","updated":"20260305082132"},"Children":[{"Type":"NodeMathBlockOpenMarker"},{"Type":"NodeMathBlockContent","Data":"\u003e 线圈对另一线圈的全磁通与该线圈的电流成正比，比例系数为互感系数，单位为 $\\text{H}$（亨利）\n\n- 互感电动势"},{"Type":"NodeMathBlockCloseMarker"}]},{"ID":"20260305082132-ka12lss","Type":"NodeParagraph","Properties":{"id":"20260305082132-ka12lss","updated":"20260305082132"},"Children":[{"Type":"NodeText","Data":"\\large\\varepsilon_{12}=-\\dfrac{\\d\\varPsi_{12}}{\\d t}=-M\\dfrac{\\d i_1}{\\d t}-i_1\\dfrac{\\d M}{\\d t}"}]},{"ID":"20260305082132-b3auffa","Type":"NodeMathBlock","Properties":{"id":"20260305082132-b3auffa","updated":"20260305082132"},"Children":[{"Type":"NodeMathBlockOpenMarker"},{"Type":"NodeMathBlockContent","Data":"### 6.自感\n\n- 自感系数"},{"Type":"NodeMathBlockCloseMarker"}]},{"ID":"20260305082132-f4e9kxc","Type":"NodeParagraph","Properties":{"id":"20260305082132-f4e9kxc","updated":"20260305082132"},"Children":[{"Type":"NodeText","Data":"\\large \\varPsi=Li"}]},{"ID":"20260305082132-0ra38hm","Type":"NodeMathBlock","Properties":{"id":"20260305082132-0ra38hm","updated":"20260305082132"},"Children":[{"Type":"NodeMathBlockOpenMarker"},{"Type":"NodeMathBlockContent","Data":"- 自感电动势"},{"Type":"NodeMathBlockCloseMarker"}]},{"ID":"20260305082132-6tivb0p","Type":"NodeParagraph","Properties":{"id":"20260305082132-6tivb0p","updated":"20260305082132"},"Children":[{"Type":"NodeText","Data":"\\large \\varepsilon_L=-\\dfrac{\\d\\varPsi}{\\d t}=-L\\dfrac{\\d i}{\\d t}-i\\dfrac{\\d L}{\\d t}"}]},{"ID":"20260305082132-z52txm3","Type":"NodeMathBlock","Properties":{"id":"20260305082132-z52txm3","updated":"20260305082132"},"Children":[{"Type":"NodeMathBlockOpenMarker"},{"Type":"NodeMathBlockContent","Data":"### 7.RL 暂态电路\n\n由电阻 $R$ 和自感线圈 $L$ 串联而成的电路，在充放电时电流不会突变\n\n- 充电"},{"Type":"NodeMathBlockCloseMarker"}]},{"ID":"20260305082132-qlz77m2","Type":"NodeParagraph","Properties":{"id":"20260305082132-qlz77m2","updated":"20260305082132"},"Children":[{"Type":"NodeText","Data":"\\large \\varepsilon-L\\dfrac{\\d i}{\\d t}-iR=0"}]},{"ID":"20260305082132-52k1s9i","Type":"NodeMathBlock","Properties":{"id":"20260305082132-52k1s9i","updated":"20260305082132"},"Children":[{"Type":"NodeMathBlockOpenMarker"},{"Type":"NodeMathBlockContent","Data":"解得"},{"Type":"NodeMathBlockCloseMarker"}]},{"ID":"20260305082132-i8yyism","Type":"NodeParagraph","Properties":{"id":"20260305082132-i8yyism","updated":"20260305082132"},"Children":[{"Type":"NodeText","Data":"\\large i=\\dfrac{\\varepsilon}{R}\\left(1-e^{-\\frac{R}{L}t}\\right)"}]},{"ID":"20260305082132-d9dv1b6","Type":"NodeMathBlock","Properties":{"id":"20260305082132-d9dv1b6","updated":"20260305082132"},"Children":[{"Type":"NodeMathBlockOpenMarker"},{"Type":"NodeMathBlockContent","Data":"\u003e 时间常量 $\\tau=\\frac{L}{R}$，衡量电流变化的快慢\n\n- 放电"},{"Type":"NodeMathBlockCloseMarker"}]},{"ID":"20260305082132-qy7wf4p","Type":"NodeParagraph","Properties":{"id":"20260305082132-qy7wf4p","updated":"20260305082132"},"Children":[{"Type":"NodeText","Data":"\\large -L\\dfrac{\\d i}{\\d t}-iR=0"}]},{"ID":"20260305082132-rutn6b3","Type":"NodeMathBlock","Properties":{"id":"20260305082132-rutn6b3","updated":"20260305082132"},"Children":[{"Type":"NodeMathBlockOpenMarker"},{"Type":"NodeMathBlockContent","Data":"解得"},{"Type":"NodeMathBlockCloseMarker"}]},{"ID":"20260305082132-aimgqfz","Type":"NodeParagraph","Properties":{"id":"20260305082132-aimgqfz","updated":"20260305082132"},"Children":[{"Type":"NodeText","Data":"\\large i=\\dfrac{\\varepsilon}{R}e^{-\\frac{R}{L}t}"}]},{"ID":"20260305082132-9c44byq","Type":"NodeMathBlock","Properties":{"id":"20260305082132-9c44byq","updated":"20260305082132"},"Children":[{"Type":"NodeMathBlockOpenMarker"},{"Type":"NodeMathBlockContent","Data":"### 8.磁能\n\n- **磁场能量密度**"},{"Type":"NodeMathBlockCloseMarker"}]},{"ID":"20260305082132-ygun0sq","Type":"NodeParagraph","Properties":{"id":"20260305082132-ygun0sq","updated":"20260305082132"},"Children":[{"Type":"NodeText","Data":"\\large w_m=\\dfrac{B^2}{2\\mu}=\\dfrac{1}{2}\\vec{B}\\cdot\\vec{H}"}]},{"ID":"20260305082132-8zwmwq1","Type":"NodeMathBlock","Properties":{"id":"20260305082132-8zwmwq1","updated":"20260305082132"},"Children":[{"Type":"NodeMathBlockOpenMarker"},{"Type":"NodeMathBlockContent","Data":"对于螺线管，有"},{"Type":"NodeMathBlockCloseMarker"}]},{"ID":"20260305082132-eigl9kd","Type":"NodeParagraph","Properties":{"id":"20260305082132-eigl9kd","updated":"20260305082132"},"Children":[{"Type":"NodeText","Data":"\\large W_m=\\dfrac{1}{2}LI^2"}]},{"ID":"20260305082132-w1kqpri","Type":"NodeMathBlock","Properties":{"id":"20260305082132-w1kqpri","updated":"20260305082132"},"Children":[{"Type":"NodeMathBlockOpenMarker"},{"Type":"NodeMathBlockContent","Data":"### 9.位移电流与麦克斯韦方程组\n\n- **位移电流**\n电流密度"},{"Type":"NodeMathBlockCloseMarker"}]},{"ID":"20260305082132-ajj653y","Type":"NodeParagraph","Properties":{"id":"20260305082132-ajj653y","updated":"20260305082132"},"Children":[{"Type":"NodeText","Data":"\\large\\vec{j}_d=\\dfrac{\\partial\\vec{D}}{\\partial t}"}]},{"ID":"20260305082132-djpc4kz","Type":"NodeMathBlock","Properties":{"id":"20260305082132-djpc4kz","updated":"20260305082132"},"Children":[{"Type":"NodeMathBlockOpenMarker"},{"Type":"NodeMathBlockContent","Data":"通过任意曲面 $S$ 的位移电流"},{"Type":"NodeMathBlockCloseMarker"}]},{"ID":"20260305082132-buiwm66","Type":"NodeParagraph","Properties":{"id":"20260305082132-buiwm66","updated":"20260305082132"},"Children":[{"Type":"NodeText","Data":"\\large I_d=\\iint_S\\vec{j}_d\\cdot\\d\\vec{S}"}]},{"ID":"20260305082132-1gzjxp0","Type":"NodeMathBlock","Properties":{"id":"20260305082132-1gzjxp0","updated":"20260305082132"},"Children":[{"Type":"NodeMathBlockOpenMarker"},{"Type":"NodeMathBlockContent","Data":"\u003e 变化的电场产生位移电流\n\n- **全电流定理**"},{"Type":"NodeMathBlockCloseMarker"}]},{"ID":"20260305082132-sfrqbck","Type":"NodeParagraph","Properties":{"id":"20260305082132-sfrqbck","updated":"20260305082132"},"Children":[{"Type":"NodeText","Data":"\\large\\oint_L\\vec{H}\\cdot\\d\\vec{l}=\\sum_{L内}I+\\iint_S\\dfrac{\\partial\\vec{D}}{\\partial t}\\cdot\\d\\vec{S}"}]},{"ID":"20260305082132-7kl2w6u","Type":"NodeMathBlock","Properties":{"id":"20260305082132-7kl2w6u","updated":"20260305082132"},"Children":[{"Type":"NodeMathBlockOpenMarker"},{"Type":"NodeMathBlockContent","Data":"- **麦克斯韦方程组**\n\n积分形式"},{"Type":"NodeMathBlockCloseMarker"}]},{"ID":"20260305082132-wnhu70d","Type":"NodeParagraph","Properties":{"id":"20260305082132-wnhu70d","updated":"20260305082132"},"Children":[{"Type":"NodeText","Data":"\\large\\oiint_S\\vec{D}\\cdot\\d\\vec{S}=\\sum_{S内}q"}]},{"ID":"20260305082132-pu1x4m3","Type":"NodeMathBlock","Properties":{"id":"20260305082132-pu1x4m3","updated":"20260305082132"},"Children":[{"Type":"NodeMathBlockOpenMarker"},{"Type":"NodeMathBlockContent"},{"Type":"NodeMathBlockCloseMarker"}]},{"ID":"20260305082132-5d5o6tu","Type":"NodeParagraph","Properties":{"id":"20260305082132-5d5o6tu","updated":"20260305082132"},"Children":[{"Type":"NodeText","Data":"\\large \\oiint_S\\vec{B}\\cdot\\d\\vec{S}=0"}]},{"ID":"20260305082132-4ztdcjg","Type":"NodeMathBlock","Properties":{"id":"20260305082132-4ztdcjg","updated":"20260305082132"},"Children":[{"Type":"NodeMathBlockOpenMarker"},{"Type":"NodeMathBlockContent"},{"Type":"NodeMathBlockCloseMarker"}]},{"ID":"20260305082132-pt5slgf","Type":"NodeParagraph","Properties":{"id":"20260305082132-pt5slgf","updated":"20260305082132"},"Children":[{"Type":"NodeText","Data":"\\large\\oint_L\\vec{E}\\cdot\\d\\vec{l}=-\\iint_S\\dfrac{\\partial\\vec{B}}{\\partial t}\\cdot\\d\\vec{S}"}]},{"ID":"20260305082132-49ziaul","Type":"NodeMathBlock","Properties":{"id":"20260305082132-49ziaul","updated":"20260305082132"},"Children":[{"Type":"NodeMathBlockOpenMarker"},{"Type":"NodeMathBlockContent"},{"Type":"NodeMathBlockCloseMarker"}]},{"ID":"20260305082132-v9vsiw7","Type":"NodeParagraph","Properties":{"id":"20260305082132-v9vsiw7","updated":"20260305082132"},"Children":[{"Type":"NodeText","Data":"\\large\\oint_L\\vec{H}\\cdot\\d\\vec{l}=\\sum_{L内}I+\\iint_S\\dfrac{\\partial\\vec{D}}{\\partial t}\\cdot\\d\\vec{S}"}]},{"ID":"20260305082132-2nrc24p","Type":"NodeMathBlock","Properties":{"id":"20260305082132-2nrc24p","updated":"20260305082132"},"Children":[{"Type":"NodeMathBlockOpenMarker"},{"Type":"NodeMathBlockContent","Data":"微分形式"},{"Type":"NodeMathBlockCloseMarker"}]},{"ID":"20260305082132-eyh2aev","Type":"NodeParagraph","Properties":{"id":"20260305082132-eyh2aev","updated":"20260305082132"},"Children":[{"Type":"NodeText","Data":"\\large\\nabla\\cdot\\vec{D}=\\rho"}]},{"ID":"20260305082132-c7srmq7","Type":"NodeMathBlock","Properties":{"id":"20260305082132-c7srmq7","updated":"20260305082132"},"Children":[{"Type":"NodeMathBlockOpenMarker"},{"Type":"NodeMathBlockContent"},{"Type":"NodeMathBlockCloseMarker"}]},{"ID":"20260305082132-bav0jd6","Type":"NodeParagraph","Properties":{"id":"20260305082132-bav0jd6","updated":"20260305082132"},"Children":[{"Type":"NodeText","Data":"\\large \\nabla\\cdot\\vec{B}=0"}]},{"ID":"20260305082132-rmmouek","Type":"NodeMathBlock","Properties":{"id":"20260305082132-rmmouek","updated":"20260305082132"},"Children":[{"Type":"NodeMathBlockOpenMarker"},{"Type":"NodeMathBlockContent"},{"Type":"NodeMathBlockCloseMarker"}]},{"ID":"20260305082132-av19666","Type":"NodeParagraph","Properties":{"id":"20260305082132-av19666","updated":"20260305082132"},"Children":[{"Type":"NodeText","Data":"\\large \\nabla\\times\\vec{E}=-\\dfrac{\\partial\\vec{B}}{\\partial t}"}]},{"ID":"20260305082132-7mlvtw8","Type":"NodeMathBlock","Properties":{"id":"20260305082132-7mlvtw8","updated":"20260305082132"},"Children":[{"Type":"NodeMathBlockOpenMarker"},{"Type":"NodeMathBlockContent"},{"Type":"NodeMathBlockCloseMarker"}]},{"ID":"20260305082132-iy41dcs","Type":"NodeParagraph","Properties":{"id":"20260305082132-iy41dcs","updated":"20260305082132"},"Children":[{"Type":"NodeText","Data":"\\large\\nabla\\times\\vec{H}=\\vec{j}+\\dfrac{\\partial\\vec{D}}{\\partial t}"}]},{"ID":"20260305082132-0e17mwm","Type":"NodeMathBlock","Properties":{"id":"20260305082132-0e17mwm","updated":"20260305082132"},"Children":[{"Type":"NodeMathBlockOpenMarker"},{"Type":"NodeMathBlockContent","Data":"# 四、振动与波动\n\n## （一）简谐振动\n\n### 1.振动方程"},{"Type":"NodeMathBlockCloseMarker"}]},{"ID":"20260305082132-euhl4gu","Type":"NodeParagraph","Properties":{"id":"20260305082132-euhl4gu","updated":"20260305082132"},"Children":[{"Type":"NodeText","Data":"\\large x=A\\cos{(\\omega t+\\varphi)}"}]},{"ID":"20260305082132-ghrx2h8","Type":"NodeMathBlock","Properties":{"id":"20260305082132-ghrx2h8","updated":"20260305082132"},"Children":[{"Type":"NodeMathBlockOpenMarker"},{"Type":"NodeMathBlockContent","Data":"其中，$A$ 是振幅，$\\omega$ 是角频率，$\\varphi$ 是初相位\n\n#### （1）振幅\n\n振幅 $A$ 是物体做简谐振动偏离平衡点的最大位移\n\n#### （2）频率与周期\n\n简谐振动的周期为 $T=\\dfrac{2\\pi}{\\omega}$，频率为 $\\nu=\\dfrac{1}{T}=\\dfrac{\\omega}{2\\pi}$\n\n对于弹簧振子有："},{"Type":"NodeMathBlockCloseMarker"}]},{"ID":"20260305082132-fp1uqxd","Type":"NodeParagraph","Properties":{"id":"20260305082132-fp1uqxd","updated":"20260305082132"},"Children":[{"Type":"NodeText","Data":"\\large\\omega=\\sqrt{\\dfrac{k}{m}},T=2\\pi\\sqrt{\\dfrac{m}{k}},\\nu=\\dfrac{1}{2\\pi}\\sqrt{\\dfrac{k}{m}}"}]},{"ID":"20260305082132-u5o97j3","Type":"NodeMathBlock","Properties":{"id":"20260305082132-u5o97j3","updated":"20260305082132"},"Children":[{"Type":"NodeMathBlockOpenMarker"},{"Type":"NodeMathBlockContent","Data":"#### （3）相位\n\n$t$ 时刻的相位为 $\\omega t+\\varphi$，量纲为 $1$。\n\n若振动物体初始位移为 $x_0$，初始速度为 $v_0$，则"},{"Type":"NodeMathBlockCloseMarker"}]},{"ID":"20260305082132-69u2fg6","Type":"NodeParagraph","Properties":{"id":"20260305082132-69u2fg6","updated":"20260305082132"},"Children":[{"Type":"NodeText","Data":"\\large A=\\sqrt{x_0"},{"Type":"NodeTextMark","TextMarkType":"sup","TextMarkTextContent":"2+\\dfrac{v_0"},{"Type":"NodeText","Data":"2}{\\omega^2}},\\tan\\varphi=-\\dfrac{v_0}{\\omega x_0}"}]},{"ID":"20260305082132-y86p9g9","Type":"NodeMathBlock","Properties":{"id":"20260305082132-y86p9g9","updated":"20260305082132"},"Children":[{"Type":"NodeMathBlockOpenMarker"},{"Type":"NodeMathBlockContent","Data":"### 2.能量\n\n以弹簧振子为例，振动动能和势能分别为"},{"Type":"NodeMathBlockCloseMarker"}]},{"ID":"20260305082132-4u1whvl","Type":"NodeParagraph","Properties":{"id":"20260305082132-4u1whvl","updated":"20260305082132"},"Children":[{"Type":"NodeText","Data":"\\large E_k=\\dfrac{1}{2}m\\omega"},{"Type":"NodeTextMark","TextMarkType":"sup","TextMarkTextContent":"2A"},{"Type":"NodeText","Data":"2\\sin^2(\\omega t+\\varphi)"}]},{"ID":"20260305082132-op4fn79","Type":"NodeMathBlock","Properties":{"id":"20260305082132-op4fn79","updated":"20260305082132"},"Children":[{"Type":"NodeMathBlockOpenMarker"},{"Type":"NodeMathBlockContent"},{"Type":"NodeMathBlockCloseMarker"}]},{"ID":"20260305082132-ux8e6pb","Type":"NodeParagraph","Properties":{"id":"20260305082132-ux8e6pb","updated":"20260305082132"},"Children":[{"Type":"NodeText","Data":"\\large E_p=\\dfrac{1}{2}kA"},{"Type":"NodeTextMark","TextMarkType":"sup","TextMarkTextContent":"2\\cos"},{"Type":"NodeText","Data":"2(\\omega t+\\varphi)"}]},{"ID":"20260305082132-n9si4nk","Type":"NodeMathBlock","Properties":{"id":"20260305082132-n9si4nk","updated":"20260305082132"},"Children":[{"Type":"NodeMathBlockOpenMarker"},{"Type":"NodeMathBlockContent","Data":"总机械能为"},{"Type":"NodeMathBlockCloseMarker"}]},{"ID":"20260305082132-n2nlt6b","Type":"NodeParagraph","Properties":{"id":"20260305082132-n2nlt6b","updated":"20260305082132"},"Children":[{"Type":"NodeText","Data":"\\large E=E_k+E_p=\\dfrac{1}{2}kA^2"}]},{"ID":"20260305082132-vaci926","Type":"NodeMathBlock","Properties":{"id":"20260305082132-vaci926","updated":"20260305082132"},"Children":[{"Type":"NodeMathBlockOpenMarker"},{"Type":"NodeMathBlockContent","Data":"## （二）振动的合成与分解\n\n### 1.同方向简谐振动合成\n\n#### （1）同频率\n\n设"},{"Type":"NodeMathBlockCloseMarker"}]},{"ID":"20260305082132-g5c2ho1","Type":"NodeParagraph","Properties":{"id":"20260305082132-g5c2ho1","updated":"20260305082132"},"Children":[{"Type":"NodeText","Data":"\\large x_1=A_1\\cos(\\omega t+\\varphi_1),x_2=A_2\\cos(\\omega t+\\varphi_2)"}]},{"ID":"20260305082132-vgum8s3","Type":"NodeMathBlock","Properties":{"id":"20260305082132-vgum8s3","updated":"20260305082132"},"Children":[{"Type":"NodeMathBlockOpenMarker"},{"Type":"NodeMathBlockContent","Data":"则合振动仍为简谐振动"},{"Type":"NodeMathBlockCloseMarker"}]},{"ID":"20260305082132-xbf6eoz","Type":"NodeParagraph","Properties":{"id":"20260305082132-xbf6eoz","updated":"20260305082132"},"Children":[{"Type":"NodeText","Data":"\\large x=x_1+x_2=A\\cos(\\omega t+\\varphi)"}]},{"ID":"20260305082132-j7t7585","Type":"NodeMathBlock","Properties":{"id":"20260305082132-j7t7585","updated":"20260305082132"},"Children":[{"Type":"NodeMathBlockOpenMarker"},{"Type":"NodeMathBlockContent","Data":"其中"},{"Type":"NodeMathBlockCloseMarker"}]},{"ID":"20260305082132-4quvwn0","Type":"NodeParagraph","Properties":{"id":"20260305082132-4quvwn0","updated":"20260305082132"},"Children":[{"Type":"NodeText","Data":"\\large A=\\sqrt{A_1"},{"Type":"NodeTextMark","TextMarkType":"sup","TextMarkTextContent":"2+A_2"},{"Type":"NodeText","Data":"2+2A_1A_2\\cos(\\varphi_2-\\varphi_1)}"}]},{"ID":"20260305082132-1u0dklo","Type":"NodeMathBlock","Properties":{"id":"20260305082132-1u0dklo","updated":"20260305082132"},"Children":[{"Type":"NodeMathBlockOpenMarker"},{"Type":"NodeMathBlockContent"},{"Type":"NodeMathBlockCloseMarker"}]},{"ID":"20260305082132-jgo715n","Type":"NodeParagraph","Properties":{"id":"20260305082132-jgo715n","updated":"20260305082132"},"Children":[{"Type":"NodeText","Data":"\\large \\tan\\varphi=\\dfrac{A_1\\sin\\varphi_1+A_2\\sin\\varphi_2}{A_1\\cos\\varphi_1+A_2\\cos\\varphi_2}"}]},{"ID":"20260305082132-621zg97","Type":"NodeMathBlock","Properties":{"id":"20260305082132-621zg97","updated":"20260305082132"},"Children":[{"Type":"NodeMathBlockOpenMarker"},{"Type":"NodeMathBlockContent","Data":"\u003e 利用旋转矢量合成来求解合振动的振幅与相位\n\n![[简谐振动旋转矢量合成.svg]]\n\n#### （2）不同频率\n\n设"},{"Type":"NodeMathBlockCloseMarker"}]},{"ID":"20260305082132-9ztgw9g","Type":"NodeParagraph","Properties":{"id":"20260305082132-9ztgw9g","updated":"20260305082132"},"Children":[{"Type":"NodeText","Data":"\\large x_1=A\\cos\\omega_1t,x_2=A\\cos\\omega_2t\\quad(\\omega_1\u003c\\omega_2)"}]},{"ID":"20260305082132-pwywah7","Type":"NodeMathBlock","Properties":{"id":"20260305082132-pwywah7","updated":"20260305082132"},"Children":[{"Type":"NodeMathBlockOpenMarker"},{"Type":"NodeMathBlockContent","Data":"合振动为"},{"Type":"NodeMathBlockCloseMarker"}]},{"ID":"20260305082132-tgfkcrk","Type":"NodeParagraph","Properties":{"id":"20260305082132-tgfkcrk","updated":"20260305082132"},"Children":[{"Type":"NodeText","Data":"\\large x=2A\\cos\\left(\\dfrac{\\omega_2-\\omega_1}{2}t\\right)\\cos\\left(\\dfrac{\\omega_2+\\omega_1}{2}t\\right)"}]},{"ID":"20260305082132-w7eu22u","Type":"NodeMathBlock","Properties":{"id":"20260305082132-w7eu22u","updated":"20260305082132"},"Children":[{"Type":"NodeMathBlockOpenMarker"},{"Type":"NodeMathBlockContent","Data":"若设"},{"Type":"NodeMathBlockCloseMarker"}]},{"ID":"20260305082132-88la0qc","Type":"NodeParagraph","Properties":{"id":"20260305082132-88la0qc","updated":"20260305082132"},"Children":[{"Type":"NodeText","Data":"\\large A(t)=2A\\cos\\left(\\dfrac{\\omega_2-\\omega_1}{2}t\\right)"}]},{"ID":"20260305082132-h5f786t","Type":"NodeMathBlock","Properties":{"id":"20260305082132-h5f786t","updated":"20260305082132"},"Children":[{"Type":"NodeMathBlockOpenMarker"},{"Type":"NodeMathBlockContent","Data":"则有"},{"Type":"NodeMathBlockCloseMarker"}]},{"ID":"20260305082132-5w1e3wo","Type":"NodeParagraph","Properties":{"id":"20260305082132-5w1e3wo","updated":"20260305082132"},"Children":[{"Type":"NodeText","Data":"\\large x=A(t)\\cos\\left(\\dfrac{\\omega_2+\\omega_1}{2}t\\right)"}]},{"ID":"20260305082132-pc2gn0r","Type":"NodeMathBlock","Properties":{"id":"20260305082132-pc2gn0r","updated":"20260305082132"},"Children":[{"Type":"NodeMathBlockOpenMarker"},{"Type":"NodeMathBlockContent","Data":"当 $\\omega_2-\\omega_1\u003c\u003c\\omega_2+\\omega_1$ 时，可近似视为振幅为 $|A(t)|$，角频率为 $\\dfrac{\\omega_2+\\omega_1}{2}$ 的简谐振动。\n\n##### 拍频\n\n合振幅的变化频率称为**拍频**"},{"Type":"NodeMathBlockCloseMarker"}]},{"ID":"20260305082132-t726dyq","Type":"NodeParagraph","Properties":{"id":"20260305082132-t726dyq","updated":"20260305082132"},"Children":[{"Type":"NodeText","Data":"\\large \\nu=2\\times\\dfrac{1}{2\\pi}\\left(\\dfrac{\\omega_2-\\omega_1}{2}\\right)=\\nu_2-\\nu_1"}]},{"ID":"20260305082132-s30xcxf","Type":"NodeMathBlock","Properties":{"id":"20260305082132-s30xcxf","updated":"20260305082132"},"Children":[{"Type":"NodeMathBlockOpenMarker"},{"Type":"NodeMathBlockContent","Data":"即为两分振动频率之差\n\n### 2.相互垂直的简谐振动合成\n\n#### （1）同频率\n\n设两个方向的简谐振动为"},{"Type":"NodeMathBlockCloseMarker"}]},{"ID":"20260305082132-zqs1wje","Type":"NodeParagraph","Properties":{"id":"20260305082132-zqs1wje","updated":"20260305082132"},"Children":[{"Type":"NodeText","Data":"\\large \\begin{cases}"},{"Type":"NodeSoftBreak","Data":"\n"},{"Type":"NodeText","Data":"x=A_1\\cos(\\omega t+\\varphi_1)"},{"Type":"NodeBackslash","Children":[{"Type":"NodeBackslashContent","Data":"\\"}]},{"Type":"NodeSoftBreak","Data":"\n"},{"Type":"NodeText","Data":"y=A_2\\cos(\\omega t+\\varphi_2)"},{"Type":"NodeSoftBreak","Data":"\n"},{"Type":"NodeText","Data":"\\end{cases}"}]},{"ID":"20260305082132-8qm0wd1","Type":"NodeMathBlock","Properties":{"id":"20260305082132-8qm0wd1","updated":"20260305082132"},"Children":[{"Type":"NodeMathBlockOpenMarker"},{"Type":"NodeMathBlockContent","Data":"消去时间可得轨迹方程\n\n$$\\large \\dfrac{x^2}{A_1^2}+\\dfrac{y^2}{A_2^2}-\\dfrac{2xy}{A_1A_2}\\cos(\\varphi_2-\\varphi_1)=\\sin^2(\\varphi_2-\\varphi_1)"},{"Type":"NodeMathBlockCloseMarker"}]},{"ID":"20260305082132-vvdd69v","Type":"NodeParagraph","Properties":{"id":"20260305082132-vvdd69v","updated":"20260305082132"},"Children":[{"Type":"NodeText","Data":"该轨迹为一椭圆，椭圆的形状由相位差 "},{"Type":"NodeTextMark","TextMarkType":"inline-math","TextMarkInlineMathContent":"\\Delta\\varphi=\\varphi_2-\\varphi_1"},{"Type":"NodeText","Data":" 决定"}]},{"ID":"20260305082132-tcj2wg3","Type":"NodeParagraph","Properties":{"id":"20260305082132-tcj2wg3","updated":"20260305082132"},"Children":[{"Type":"NodeTextMark","TextMarkType":"strong","TextMarkTextContent":"旋转方向判断"},{"Type":"NodeText","Data":"如下："},{"Type":"NodeSoftBreak","Data":"\n"},{"Type":"NodeText","Data":"计算 "},{"Type":"NodeTextMark","TextMarkType":"inline-math","TextMarkInlineMathContent":"t=0"},{"Type":"NodeText","Data":" 时的 "},{"Type":"NodeTextMark","TextMarkType":"inline-math","TextMarkInlineMathContent":"x_0,y_0"},{"Type":"NodeText","Data":"，再判断 "},{"Type"